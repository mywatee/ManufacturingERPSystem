<UserControl x:Class="ManufacturingERP.Views.CreateWarehouseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ManufacturingERP.Views"
             xmlns:core="clr-namespace:ManufacturingERP.Core"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="#F8FAFC">
    
    <UserControl.Resources>
        <!-- Modern Card Style -->
        <Style x:Key="ModernCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.04" Color="#1E293B"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Form Label Style -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Action Button Style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Custom TextBox with Placeholder Style -->
        <Style x:Key="ModernTextBoxWithPlaceholder" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <Grid>
                                <TextBlock Text="{TemplateBinding Tag}" Margin="{TemplateBinding Padding}" Foreground="#94A3B8" IsHitTestVisible="False" VerticalAlignment="Center" FontSize="{TemplateBinding FontSize}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="12"/>
                </Style>
            </Style.Resources>
        </Style>

        <core:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        
        <Style x:Key="SaveButtonVisibilityStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
            <StackPanel Margin="30,20,30,40" Background="Transparent">
                
                <!-- Refined Balanced Header -->
                <Grid Margin="0,0,0,40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Command="{Binding CancelCommand}" 
                            Background="Transparent" BorderThickness="0" Padding="0" HorizontalAlignment="Left" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32" Height="32" Background="#F1F5F9" CornerRadius="16" Margin="0,0,12,0">
                                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Quay lại danh sách nhà kho" Foreground="#64748B" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Grid.Column="1" Text="{Binding PageTitle}" FontSize="32" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center"/>
                    
                    <Button Grid.Column="2" Content="Lưu nhà kho" Command="{Binding SaveCommand}" Style="{StaticResource SaveButtonVisibilityStyle}" 
                            Background="#2563EB" Foreground="White" Width="200" HorizontalAlignment="Right"/>
                </Grid>

                <Grid IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBooleanConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,30,0">
                        <!-- CARD 1: GENERAL INFO -->
                        <Border Style="{StaticResource ModernCardStyle}" Padding="30" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="THÔNG TIN CƠ BẢN" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,15"/>
                                
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <Grid>
                                            <TextBlock Text="Mã nhà kho" Style="{StaticResource FormLabelStyle}" HorizontalAlignment="Left"/>
                                            <CheckBox IsChecked="{Binding IsAutoCode, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,-4,0,0">
                                                <CheckBox.Style>
                                                    <Style TargetType="CheckBox">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsReadOnly}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding IsEditMode}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </CheckBox.Style>
                                                <TextBlock Text="Tự động" Foreground="#3B82F6" FontSize="11" FontWeight="SemiBold"/>
                                            </CheckBox>
                                        </Grid>
                                        <TextBox Text="{Binding WarehouseCode, Mode=TwoWay}" Style="{StaticResource ModernTextBoxWithPlaceholder}" Tag="VD: KHO-001..." Height="45" FontSize="14" MaxLength="50" IsReadOnly="{Binding IsAutoCode}"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Phân loại" Style="{StaticResource FormLabelStyle}"/>
                                        <ComboBox SelectedItem="{Binding WarehouseType, Mode=TwoWay}" ItemsSource="{Binding WarehouseTypes}" Style="{StaticResource ModernComboBoxStyle}" Height="45" FontSize="14"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Trạng thái" Style="{StaticResource FormLabelStyle}"/>
                                        <ComboBox SelectedItem="{Binding Status, Mode=TwoWay}" ItemsSource="{Binding StatusList}" Style="{StaticResource ModernComboBoxStyle}" Height="45" FontSize="14"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock Text="Tên nhà kho *" Style="{StaticResource FormLabelStyle}"/>
                                    <TextBox Text="{Binding WarehouseName, Mode=TwoWay}" Style="{StaticResource ModernTextBoxWithPlaceholder}" Tag="Nhập tên nhà kho..." Height="45" FontSize="14" MaxLength="100"/>
                                </StackPanel>

                                <StackPanel>
                                    <TextBlock Text="Vị trí vật lý *" Style="{StaticResource FormLabelStyle}"/>
                                    <TextBox Text="{Binding Location, Mode=TwoWay}" Style="{StaticResource ModernTextBoxWithPlaceholder}" Tag="Địa chỉ chi tiết hoặc tọa độ..." Height="45" FontSize="14" MaxLength="150"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- CARD 2: CONTACT INFO -->
                        <Border Style="{StaticResource ModernCardStyle}" Padding="30" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="THÔNG TIN LIÊN HỆ" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,15"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Số điện thoại" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding ContactPhone, Mode=TwoWay}" Style="{StaticResource ModernTextBoxWithPlaceholder}" Tag="Số máy lẻ hoặc hotline..." Height="45" FontSize="14"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Email liên hệ" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding ContactEmail, Mode=TwoWay}" Style="{StaticResource ModernTextBoxWithPlaceholder}" Tag="Email nhận phiếu điều phối..." Height="45" FontSize="14"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <!-- CARD 3: CAPACITY INFO -->
                        <Border Style="{StaticResource ModernCardStyle}" Padding="30" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="THÔNG SỐ VÀ QUẢN LÝ" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,15"/>
                                
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Công suất tối đa" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding Capacity, Mode=TwoWay}" Style="{StaticResource ModernTextBoxWithPlaceholder}" Tag="Số lượng..." Height="45" FontSize="14"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Đơn vị tính" Style="{StaticResource FormLabelStyle}"/>
                                        <ComboBox SelectedItem="{Binding CapacityUnit, Mode=TwoWay}" ItemsSource="{Binding UnitList}" Style="{StaticResource ModernComboBoxStyle}" Height="45" FontSize="14"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Ngưỡng an toàn (%)" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding SafetyThreshold, Mode=TwoWay}" Style="{StaticResource ModernTextBoxWithPlaceholder}" Tag="Cảnh báo khi đầy..." Height="45" FontSize="14"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel>
                                    <TextBlock Text="Người quản lý kho" Style="{StaticResource FormLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding Managers}" SelectedItem="{Binding SelectedManager, Mode=TwoWay}" Style="{StaticResource ModernComboBoxStyle}" DisplayMemberPath="FullName" Height="45" FontSize="14"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- CARD 4: DESCRIPTION -->
                        <Border Style="{StaticResource ModernCardStyle}" Padding="30" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="MÔ TẢ CHI TIẾT" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,15"/>
                                <TextBox Text="{Binding Description, Mode=TwoWay}" Style="{StaticResource ModernTextBoxWithPlaceholder}" 
                                         Tag="Mô tả thêm về đặc điểm kho, ghi chú quan trọng..." 
                                         Height="100" FontSize="14" AcceptsReturn="True" TextWrapping="Wrap" Padding="16,12"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- SIDEBAR: Guidelines & Help -->
                    <StackPanel Grid.Column="1">
                        <Border Style="{StaticResource ModernCardStyle}" Padding="24" Background="#F8FAFC">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <Border Width="24" Height="24" Background="#3B82F6" CornerRadius="12" Margin="0,0,10,0">
                                        <TextBlock Text="?" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                                    </Border>
                                    <TextBlock Text="HƯỚNG DẪN NGHIỆP VỤ" FontSize="13" FontWeight="Bold" Foreground="#1E40AF"/>
                                </StackPanel>

                                <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,12" BorderBrush="#E2E8F0" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Mã Kho Tự Động" FontWeight="Bold" FontSize="12" Foreground="#334155" Margin="0,0,0,5"/>
                                        <TextBlock Text="Được khuyến khích dùng để hệ thống tự quản lý thời gian, tránh trùng lặp." FontSize="11" Foreground="#64748B" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,12" BorderBrush="#E2E8F0" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Công suất kho" FontWeight="Bold" FontSize="12" Foreground="#334155" Margin="0,0,0,5"/>
                                        <TextBlock Text="Công suất tính bằng m², là diện tích tối đa có thể lưu trữ hàng hóa." FontSize="11" Foreground="#64748B" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
