<Window x:Class="ManufacturingERP.Views.Dialogs.AlertDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông báo" Height="220" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Styles/DesignSystem.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="White" CornerRadius="16" BorderThickness="1" BorderBrush="#E5E7EB">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.1" Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="24,20,24,0">
                <StackPanel Orientation="Horizontal">
                    <Border x:Name="IconBorder" Background="#FEF2F2" Width="36" Height="36" CornerRadius="18">
                        <TextBlock x:Name="IconText" Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" 
                                   Foreground="#EF4444" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="TxtTitle" Text="Thông báo" FontSize="16" FontWeight="Bold" Foreground="#111827" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Content -->
            <Border Grid.Row="1" Padding="24,12">
                <TextBlock x:Name="TxtMessage" Text="Nội dung thông báo." 
                           Foreground="#4B5563" FontSize="14" TextWrapping="Wrap" LineHeight="20" VerticalAlignment="Center"/>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F9FAFB" CornerRadius="0,0,16,16" Padding="20,12">
                <Button Content="Đã hiểu" Style="{StaticResource PrimaryButtonStyle}" Click="Ok_Click" Width="100" HorizontalAlignment="Right"/>
            </Border>
        </Grid>
    </Border>
</Window>
