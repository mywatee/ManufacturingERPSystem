<Window x:Class="ManufacturingERP.Views.Dialogs.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Cấu hình Xuất báo cáo" Height="520" Width="650"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    
    <Window.Resources>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="20" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Color="#000000" Opacity="0.1" ShadowDepth="0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: Modern Gradient -->
            <Border Grid.Row="0" CornerRadius="20,20,0,0" Padding="25,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F8FAFC" Offset="0"/>
                        <GradientStop Color="#F1F5F9" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#2563EB" Width="40" Height="40" CornerRadius="10" Margin="0,0,15,0">
                            <TextBlock Text="&#xE10C;" FontFamily="Segoe MDL2 Assets" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Xuất báo cáo sản xuất" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
                            <TextBlock Text="Tùy chỉnh dữ liệu và định dạng tệp tin" FontSize="12" Foreground="#64748B"/>
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Click="Close_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <TextBlock Text="&#xE106;" FontFamily="Segoe MDL2 Assets" Foreground="#94A3B8" FontSize="16"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Body: Two Column Layout -->
            <Grid Grid.Row="1" Margin="25,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/> <!-- Filters -->
                    <ColumnDefinition Width="*"/>   <!-- Options -->
                </Grid.ColumnDefinitions>

                <!-- Left Column: Filters -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="1. BỘ LỌC DỮ LIỆU" Style="{StaticResource SectionHeaderStyle}"/>
                    
                    <Border Background="#F8FAFC" CornerRadius="12" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Khoảng thời gian" FontSize="12" FontWeight="Medium" Foreground="#475569" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="20"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <DatePicker Grid.Column="0" Height="38" SelectedDate="{Binding StartDate}"/>
                                <TextBlock Grid.Column="1" Text="-" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#94A3B8"/>
                                <DatePicker Grid.Column="2" Height="38" SelectedDate="{Binding EndDate}"/>
                            </Grid>

                            <TextBlock Text="Trạng thái lệnh" FontSize="12" FontWeight="Medium" Foreground="#475569" Margin="0,15,0,8"/>
                            <ComboBox Height="38" SelectedValue="{Binding SelectedStatus}">
                                <ComboBoxItem Content="Tất cả trạng thái" IsSelected="True"/>
                                <ComboBoxItem Content="Đang sản xuất"/>
                                <ComboBoxItem Content="Hoàn thành"/>
                                <ComboBoxItem Content="Tạm dừng"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Loại báo cáo" FontSize="12" FontWeight="Medium" Foreground="#475569" Margin="0,0,0,8"/>
                    <UniformGrid Columns="2">
                        <RadioButton Content="Tổng hợp" IsChecked="True" Margin="0,5"/>
                        <RadioButton Content="Chi tiết" Margin="0,5"/>
                    </UniformGrid>
                </StackPanel>

                <!-- Right Column: Export Options -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="2. CẤU HÌNH FILE" Style="{StaticResource SectionHeaderStyle}"/>

                    <TextBlock Text="Chọn các cột hiển thị" FontSize="12" FontWeight="Medium" Foreground="#475569" Margin="0,0,0,8"/>
                    <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="15" Height="150">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <CheckBox Content="Mã lệnh sản xuất" IsChecked="True" Margin="0,4"/>
                                <CheckBox Content="Tên sản phẩm" IsChecked="True" Margin="0,4"/>
                                <CheckBox Content="Số lượng mục tiêu" IsChecked="True" Margin="0,4"/>
                                <CheckBox Content="Tiến độ thực tế" IsChecked="True" Margin="0,4"/>
                                <CheckBox Content="Trạng thái hiện tại" IsChecked="True" Margin="0,4"/>
                                <CheckBox Content="Ngày bắt đầu" IsChecked="True" Margin="0,4"/>
                                <CheckBox Content="Hạn hoàn thành" IsChecked="True" Margin="0,4"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <TextBlock Text="Định dạng tệp tin" FontSize="12" FontWeight="Medium" Foreground="#475569" Margin="0,15,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Margin="0,0,5,0" Background="#F0F9FF" BorderBrush="#BAE6FD" BorderThickness="1" CornerRadius="8" Padding="10">
                            <RadioButton Content="Excel (.xlsx)" IsChecked="{Binding IsExcelSelected}" Foreground="#0369A1" FontWeight="Medium" GroupName="FileFormat"/>
                        </Border>
                        <Border Grid.Column="1" Margin="5,0,0,0" Background="#FFF1F2" BorderBrush="#FECDD3" BorderThickness="1" CornerRadius="8" Padding="10">
                            <RadioButton Content="PDF (.pdf)" IsChecked="{Binding IsPdfSelected}" Foreground="#BE123C" FontWeight="Medium" GroupName="FileFormat"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Footer: Actions -->
            <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0,0,20,20" Padding="25,20">
                <Grid>
                    <TextBlock Text="* Dữ liệu sẽ được xuất dựa trên các bộ lọc đã chọn." VerticalAlignment="Center" Foreground="#94A3B8" FontSize="11" FontStyle="Italic"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Hủy bỏ" Click="Close_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,15,0" Width="110" Height="42"/>
                        <Button Content="Bắt đầu xuất file" Command="{Binding ProcessCommand}" Background="#2563EB" Foreground="White" Width="160" Height="42">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
