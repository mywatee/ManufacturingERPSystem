<Window x:Class="ManufacturingERP.Views.Dialogs.CreateFinancialTransactionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tạo phiếu thu chi" Height="550" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    
    <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="{Binding TitleText}" FontSize="20" FontWeight="Bold" Foreground="#1e293b"/>
                <TextBlock Text="{Binding SubtitleText}" FontSize="13" Foreground="#64748b" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Form -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBooleanConverter}}">
                    <!-- Type and Date -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Loại giao dịch" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding TransactionTypes}" SelectedItem="{Binding Type}" Style="{StaticResource ModernComboBoxStyle}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Ngày thực hiện" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding Date}" Style="{StaticResource ModernDatePickerStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Category and Method -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Hạng mục" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Categories}" Text="{Binding Category}" 
                                      IsEditable="True" Style="{StaticResource ModernComboBoxStyle}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Phương thức" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding Method}" Style="{StaticResource ModernComboBoxStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Overhead Flag -->
                    <CheckBox IsChecked="{Binding IsOverhead}" Margin="0,0,0,16" Content="Đây là chi phí sản xuất chung (Overhead)"
                              Visibility="{Binding Type, Converter={StaticResource StringToBooleanConverter}, ConverterParameter='Chi'}">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Foreground" Value="#1e293b"/>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>

                    <!-- Amount -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Số tiền (VNĐ)" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" Style="{StaticResource ModernTextBoxStyle}"/>
                    </StackPanel>

                    <!-- Reference -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Số chứng từ tham chiếu (Hóa đơn/Mã đơn...)" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding Reference}" Style="{StaticResource ModernTextBoxStyle}"/>
                    </StackPanel>

                    <!-- Description -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Mô tả chi tiết" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding Description}" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Style="{StaticResource ModernTextBoxStyle}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Button Width="100" Margin="0,0,12,0"
                        Command="{Binding CancelCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                            <Setter Property="Content" Value="Hủy bỏ"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                    <Setter Property="Content" Value="Đóng"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                
                <Button Content="Lưu phiếu" 
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Width="130"
                        Command="{Binding SaveCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
            </StackPanel>

        </Grid>
    </Border>
</Window>
