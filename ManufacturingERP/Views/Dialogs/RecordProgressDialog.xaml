<Window x:Class="ManufacturingERP.Views.Dialogs.RecordProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ghi nhận sản lượng" Height="500" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    
    <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.15"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#1E3A5F" CornerRadius="12,12,0,0" Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#2563EB" CornerRadius="8" Width="36" Height="36" Margin="0,0,12,0">
                        <TextBlock Text="&#xE9D5;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="White" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Ghi nhận sản lượng" FontSize="15" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="TxtSubtitle" Text="LSX-..." FontSize="11" Foreground="#94A3B8" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="2" Click="Cancel_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Viewbox Width="16" Height="16">
                            <Path Data="M18 6L6 18 M6 6l12 12" Stroke="#94A3B8" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,16">
                    
                    <!-- Số lượng đạt -->
                    <Border Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Số lượng sản phẩm ĐẠT" FontSize="12" FontWeight="SemiBold" Foreground="#16A34A" Margin="0,0,0,4"/>
                                <TextBlock Text="Sản phẩm hoàn thành, đạt tiêu chuẩn chất lượng" FontSize="11" Foreground="#64748B"/>
                            </StackPanel>
                            <TextBox x:Name="TxtActualQty" Grid.Column="1" Width="90" Height="38" 
                                     TextAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="#16A34A"
                                     BorderBrush="#BBF7D0" BorderThickness="1" VerticalContentAlignment="Center"
                                     PreviewTextInput="NumberValidationTextBox" Text="0"/>
                        </Grid>
                    </Border>

                    <!-- Số lượng lỗi -->
                    <Border Background="#FEF2F2" BorderBrush="#FEE2E2" BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Số lượng sản phẩm LỖI/NG" FontSize="12" FontWeight="SemiBold" Foreground="#DC2626" Margin="0,0,0,4"/>
                                <TextBlock Text="Sản phẩm không đạt, cần xử lý hoặc loại bỏ" FontSize="11" Foreground="#64748B"/>
                            </StackPanel>
                            <TextBox x:Name="TxtFailedQty" Grid.Column="1" Width="90" Height="38" 
                                     TextAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="#DC2626"
                                     BorderBrush="#FEE2E2" BorderThickness="1" VerticalContentAlignment="Center"
                                     PreviewTextInput="NumberValidationTextBox" Text="0"/>
                        </Grid>
                    </Border>

                    <!-- Công đoạn -->
                    <TextBlock Text="Công đoạn thực hiện:" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,6"/>
                    <ComboBox x:Name="CmbStage" Height="38" Padding="10,0" VerticalContentAlignment="Center" 
                              FontSize="13" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,14">
                        <ComboBoxItem Content="Gia công / Cắt gọt" IsSelected="True"/>
                        <ComboBoxItem Content="Lắp ráp / Hàn"/>
                        <ComboBoxItem Content="Sơn phủ / Xử lý bề mặt"/>
                        <ComboBoxItem Content="Kiểm tra chất lượng (QC)"/>
                        <ComboBoxItem Content="Đóng gói / Hoàn thiện"/>
                        <ComboBoxItem Content="Xuất kho"/>
                    </ComboBox>

                    <!-- Người thực hiện (readonly, auto-filled) -->
                    <TextBlock Text="Người ghi nhận:" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtOperator" Height="38" Padding="10,0" VerticalContentAlignment="Center" 
                             FontSize="13" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,14"
                             IsReadOnly="True" Background="#F8FAFC" Foreground="#64748B"/>

                    <!-- Ghi chú -->
                    <TextBlock Text="Ghi chú / Nhận xét:" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtNotes" Height="72" Padding="10,8" TextWrapping="Wrap" AcceptsReturn="True" 
                             FontSize="13" BorderBrush="#E2E8F0" BorderThickness="1"
                             VerticalScrollBarVisibility="Auto"/>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0,0,12,12" Padding="20,14" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtSummary" Text="" FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Hủy" Click="Cancel_Click" Background="Transparent" Foreground="#64748B" 
                                BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,10,0" Width="80" Height="36" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="✓  Ghi nhận" Click="Save_Click" Background="#2563EB" Foreground="White" 
                                Width="120" Height="36" FontWeight="SemiBold" FontSize="13">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
