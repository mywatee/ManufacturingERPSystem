<Window x:Class="ManufacturingERP.Views.Dialogs.PartnerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cấu hình đối tác" Height="500" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Window.Resources>
        <DropShadowEffect x:Key="DialogShadow" BlurRadius="20" ShadowDepth="0" Color="Black" Opacity="0.2"/>
    </Window.Resources>

    <Border CornerRadius="16" Background="White" Margin="15" Effect="{StaticResource DialogShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="16,16,0,0" Padding="20,15">
                <TextBlock x:Name="TitleText" Text="Thêm đối tác mới" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Border Padding="20">
                    <StackPanel>
                        <TextBlock FontSize="12" Margin="0,0,0,4">
                            <Run Text="Mã đối tác" Foreground="#64748B"/>
                            <Run Text=" *" Foreground="#EF4444"/>
                        </TextBlock>
                        <TextBox x:Name="TxtCode" Height="36" VerticalContentAlignment="Center" Padding="8,0" Margin="0,0,0,12"/>

                        <TextBlock FontSize="12" Margin="0,0,0,4">
                            <Run Text="Tên đối tác" Foreground="#64748B"/>
                            <Run Text=" *" Foreground="#EF4444"/>
                        </TextBlock>
                        <TextBox x:Name="TxtName" Height="36" VerticalContentAlignment="Center" Padding="8,0" Margin="0,0,0,12"/>

                        <TextBlock Text="Loại đối tác" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CmbType" Height="36" Margin="0,0,0,12">
                            <ComboBoxItem Content="Nhà cung cấp"/>
                            <ComboBoxItem Content="Khách hàng"/>
                            <ComboBoxItem Content="Cả hai"/>
                        </ComboBox>

                        <TextBlock Text="Số điện thoại" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtPhone" Height="36" VerticalContentAlignment="Center" Padding="8,0" Margin="0,0,0,12"/>

                        <TextBlock Text="Email" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtEmail" Height="36" VerticalContentAlignment="Center" Padding="8,0" Margin="0,0,0,12"/>

                        <TextBlock Text="Địa chỉ" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtAddress" Height="60" VerticalContentAlignment="Top" Padding="8" Margin="0,0,0,12" TextWrapping="Wrap" AcceptsReturn="True"/>

                        <TextBlock Text="Mã số thuế" FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtTaxCode" Height="36" VerticalContentAlignment="Center" Padding="8,0" Margin="0,0,0,12"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0,0,16,16" Padding="20,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Hủy" Width="80" Height="36" Margin="0,0,10,0" Click="Cancel_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                    <Button Content="Lưu" Width="100" Height="36" Click="Save_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
