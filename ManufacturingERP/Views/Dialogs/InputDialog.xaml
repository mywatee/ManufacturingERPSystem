<Window x:Class="ManufacturingERP.Views.Dialogs.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nhập dữ liệu" Height="220" Width="420"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    
    <Border CornerRadius="12" Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.15" Color="Black"/>
        </Border.Effect>
        
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,16">
                <Border Width="40" Height="40" Background="#EFF6FF" CornerRadius="20" Margin="0,0,16,0">
                    <Path Data="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7 M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" 
                          Fill="#2563EB" Width="20" Height="20" Stretch="Uniform"/>
                </Border>
                <TextBlock x:Name="TitleText" Text="Nhập dữ liệu" FontSize="18" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock x:Name="MessageText" Grid.Row="1" TextWrapping="Wrap" FontSize="14" Foreground="#4B5563" Margin="0,0,0,12"/>
            <Border Grid.Row="1" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Margin="0,30,0,0">
                <TextBox x:Name="InputTextBox" FontSize="14" Padding="10,8" BorderThickness="0" Background="Transparent"/>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Hủy bỏ" Click="Cancel_Click" Width="100" Margin="0,0,12,0" Style="{StaticResource GhostButtonStyle}"/>
                <Button Content="Xác nhận" Click="Confirm_Click" Width="120" Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
