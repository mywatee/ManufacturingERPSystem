<Window x:Class="ManufacturingERP.Views.Dialogs.CreateInvoiceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ManufacturingERP.Views.Dialogs"
        mc:Ignorable="d"
        Title="Tạo hóa đơn mới" Height="500" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    
    <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Tạo hóa đơn mới" FontSize="20" FontWeight="Bold" Foreground="#1e293b"/>
                <TextBlock Text="Nhập thông tin chi tiết hóa đơn tài chính" FontSize="13" Foreground="#64748b" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Form -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Type and Code -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Loại hóa đơn" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding InvoiceTypes}" SelectedItem="{Binding InvoiceType}" Style="{StaticResource ModernComboBoxStyle}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Mã hóa đơn" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding InvoiceCode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Partner -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Đối tác (Khách hàng/Nhà cung cấp)" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Partners}" 
                                  SelectedItem="{Binding SelectedPartner}" 
                                  DisplayMemberPath="PartnerName"
                                  Style="{StaticResource ModernComboBoxStyle}"/>
                    </StackPanel>

                    <!-- Dates -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Ngày phát hành" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding IssueDate}" Style="{StaticResource ModernDatePickerStyle}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Hạn thanh toán" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding DueDate}" Style="{StaticResource ModernDatePickerStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Amount -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Tổng số tiền (VNĐ)" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding TotalAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" Style="{StaticResource ModernTextBoxStyle}"/>
                    </StackPanel>

                    <!-- Note -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Ghi chú" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding Note}" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Style="{StaticResource ModernTextBoxStyle}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Button Content="Hủy bỏ" 
                        Style="{StaticResource SecondaryButtonStyle}" 
                        Width="100" Margin="0,0,12,0"
                        Command="{Binding CancelCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                
                <Button Content="Lưu hóa đơn" 
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Width="130"
                        Command="{Binding SaveCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
