<Window x:Class="ManufacturingERP.Views.Dialogs.StockTransactionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Giao dịch kho"
        Width="500" Height="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.20"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0" Padding="24,20" Background="#1E293B">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="&#xE700;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtHeaderTitle" Text="Tạo phiếu kho" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="TxtHeaderSubtitle" Text="Nhập/Xuất vật tư" FontSize="11" Foreground="#94A3B8" Margin="0,2,0,0"/>
                    </StackPanel>
                    
                    <Button Grid.Column="2" Click="Cancel_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="16"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="24">
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Mã vật tư *" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtMaterialId" Padding="10,8" BorderBrush="#CBD5E1" BorderThickness="1" ToolTip="Nhập ID vật tư (VD: 1, 2, 3)"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Số lượng *" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtQuantity" Padding="10,8" BorderBrush="#CBD5E1" BorderThickness="1"/>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Loại giao dịch *" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                    <ComboBox x:Name="CmbType" Padding="10,8" BorderBrush="#CBD5E1" BorderThickness="1">
                        <ComboBoxItem Content="Nhập kho" IsSelected="True"/>
                        <ComboBoxItem Content="Xuất kho"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Chứng từ tham chiếu" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtReference" Padding="10,8" BorderBrush="#CBD5E1" BorderThickness="1" MaxLength="50"/>
                </StackPanel>
                
                <TextBlock x:Name="TxtError" Foreground="#EF4444" FontSize="12" Visibility="Collapsed" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0,0,12,12" Padding="24,16" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Hủy bỏ" Click="Cancel_Click" Margin="0,0,12,0" 
                            Background="White" BorderBrush="#CBD5E1" BorderThickness="1" Foreground="#475569" 
                            Padding="20,8" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="Lưu phiếu" Click="Save_Click" 
                            Background="#2563EB" BorderThickness="0" Foreground="White" FontWeight="Medium"
                            Padding="20,8" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
