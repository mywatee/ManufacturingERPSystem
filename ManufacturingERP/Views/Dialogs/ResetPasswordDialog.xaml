<Window x:Class="ManufacturingERP.Views.Dialogs.ResetPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đặt lại mật khẩu" Height="650" Width="450"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True" WindowStyle="None" Background="Transparent">
    <Border Background="White" CornerRadius="20" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" Opacity="0.12" ShadowDepth="0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20" 
                    Width="32" Height="32" Click="Cancel_Click" Background="Transparent" BorderThickness="0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="16">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" 
                      Fill="#64748B" Stretch="Uniform" Width="14" Height="14"/>
            </Button>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                <Grid Margin="30,10,30,30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,25">
                        <Border Background="#EEF2FF" HorizontalAlignment="Left" CornerRadius="12" Padding="12" Margin="0,0,0,15">
                            <Path Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM9 6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9V6zm9 14H6V10h12v10zm-6-3c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2z" 
                                  Fill="#4F46E5" Width="24" Height="24" Stretch="Uniform"/>
                        </Border>
                        <TextBlock Text="ĐẶT LẠI MẬT KHẨU" FontSize="20" FontWeight="ExtraBold" Foreground="#1E293B"/>
                        <TextBlock Text="Thiết lập mật khẩu mới an toàn cho tài khoản" FontSize="13" Foreground="#64748B" Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Input Section -->
                    <StackPanel Grid.Row="1">
                        <TextBlock Text="Mật khẩu mới" FontWeight="Bold" Margin="0,0,0,10" Foreground="#475569" FontSize="13"/>
                        <PasswordBox x:Name="NewPasswordBox" Height="48" Padding="15,0" VerticalContentAlignment="Center" Background="#F8FAFC" BorderBrush="#E2E8F0">
                            <PasswordBox.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </PasswordBox.Resources>
                        </PasswordBox>
                        
                        <TextBlock Text="Xác nhận lại mật khẩu" FontWeight="Bold" Margin="0,18,0,10" Foreground="#475569" FontSize="13"/>
                        <PasswordBox x:Name="ConfirmPasswordBox" Height="48" Padding="15,0" VerticalContentAlignment="Center" Background="#F8FAFC" BorderBrush="#E2E8F0">
                            <PasswordBox.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </PasswordBox.Resources>
                        </PasswordBox>
                    </StackPanel>

                    <!-- Requirements Checklist -->
                    <Border Grid.Row="2" Background="#F1F5F9" CornerRadius="12" Padding="18" Margin="0,25,0,0">
                        <StackPanel>
                            <TextBlock Text="QUY ĐỊNH BẢO MẬT:" FontWeight="ExtraBold" FontSize="11" Foreground="#475569" Margin="0,0,0,12"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" Fill="#10B981" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="MinLengthText" Text="Độ dài tối thiểu 8 ký tự" FontSize="12" Foreground="#64748B" Margin="10,0,0,0"/>
                            </Grid>
                            <Grid Margin="0,0,0,8" x:Name="UpperRow">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" Fill="#10B981" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Chứa ít nhất một chữ cái viết hoa" FontSize="12" Foreground="#64748B" Margin="10,0,0,0"/>
                            </Grid>
                            <Grid Margin="0,0,0,8" x:Name="LowerRow">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" Fill="#10B981" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Chứa ít nhất một chữ cái viết thường" FontSize="12" Foreground="#64748B" Margin="10,0,0,0"/>
                            </Grid>
                            <Grid Margin="0,0,0,8" x:Name="DigitRow">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" Fill="#10B981" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Chứa ít nhất một chữ số" FontSize="12" Foreground="#64748B" Margin="10,0,0,0"/>
                            </Grid>
                            <Grid x:Name="SpecialRow">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" Fill="#10B981" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Chứa ít nhất một ký tự đặc biệt" FontSize="12" Foreground="#64748B" Margin="10,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Actions -->
                    <Grid Grid.Row="3" Margin="0,30,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Hủy bỏ" Click="Cancel_Click" Height="45" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" Foreground="#64748B" Margin="0,0,7,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button Grid.Column="1" Content="Cập nhật ngay" Click="Update_Click" Height="45" Background="#4F46E5" Foreground="White" FontWeight="Bold" Margin="7,0,0,0">
                            <Button.Effect>
                                <DropShadowEffect BlurRadius="10" Opacity="0.2" ShadowDepth="2" Color="#4F46E5"/>
                            </Button.Effect>
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
