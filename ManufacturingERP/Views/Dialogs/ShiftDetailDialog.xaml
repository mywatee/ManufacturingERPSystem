<Window x:Class="ManufacturingERP.Views.Dialogs.ShiftDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chi tiết Ca làm việc" Height="650" Width="550"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True" WindowStyle="None" Background="Transparent">
    <Border Background="#F8FAFC" CornerRadius="20" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Opacity="0.15" ShadowDepth="0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header với màu sắc động từ Ca làm việc -->
            <Border Grid.Row="0" x:Name="HeaderBar" Height="140" CornerRadius="20,20,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop x:Name="ShiftColorStop1" Color="#2563EB" Offset="0"/>
                        <GradientStop x:Name="ShiftColorStop2" Color="#1E40AF" Offset="1.5"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="30,0">
                    <StackPanel VerticalAlignment="Center">
                        <Border Background="#33FFFFFF" HorizontalAlignment="Left" CornerRadius="8" Padding="12,4" Margin="0,0,0,10">
                            <TextBlock Text="THÔNG TIN CA LÀM VIỆC" FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        <TextBlock x:Name="ShiftNameText" Text="Tên ca làm việc" FontSize="32" FontWeight="Bold" Foreground="White">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                    
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,-10,0" 
                            Style="{StaticResource GhostButtonStyle}" Tag="{StaticResource IconXCircle}" 
                            Foreground="White" Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- Nội dung chi tiết -->
            <ScrollViewer Grid.Row="1" Margin="30,25,30,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="20">
                            <StackPanel>
                                <TextBlock Text="THỜI GIAN TRỰC" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconClock}" Fill="#2563EB" Width="20" Height="20" Margin="0,0,12,0" Stretch="Uniform"/>
                                    <TextBlock x:Name="WorkingTimeText" Text="08:00 - 17:30" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="White" CornerRadius="15" Padding="20">
                            <StackPanel>
                                <TextBlock Text="NGHỈ GIẢI LAO" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconTimezone}" Fill="#F59E0B" Width="20" Height="20" Margin="0,0,12,0" Stretch="Uniform"/>
                                    <TextBlock x:Name="BreakTimeText" Text="12:00 - 13:00" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Background="White" CornerRadius="15" Padding="20" Margin="0,0,0,25">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="TRẠNG THÁI" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="StatusDot" Width="12" Height="12" Fill="#16A34A" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="StatusText" Text="Đang hoạt động" FontSize="16" FontWeight="Medium" Foreground="#334155"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="MÃ MÀU" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8" TextAlignment="Right"/>
                                <Border x:Name="ColorPreview" Width="60" Height="24" CornerRadius="6" Background="#2563EB"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Text="NHÂN VIÊN ĐANG ÁP DỤNG" FontSize="14" FontWeight="Bold" Foreground="#1E293B" Margin="5,0,0,15"/>
                    <ItemsControl x:Name="EmployeeList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="40" Height="40" Background="#F1F5F9" CornerRadius="20">
                                            <Path Data="{StaticResource IconUser}" Fill="#94A3B8" Width="18" Height="18" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="15,0">
                                            <TextBlock Text="{Binding FullName}" FontWeight="Bold" Foreground="#1E293B" FontSize="14"/>
                                            <TextBlock Text="{Binding Department}" FontSize="12" Foreground="#64748B"/>
                                        </StackPanel>
                                        <Border Grid.Column="2" Background="#F0FDF4" CornerRadius="6" Padding="10,4">
                                            <TextBlock Text="Đang trực" FontSize="11" Foreground="#16A34A" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="White" Padding="30,20" CornerRadius="0,0,20,20">
                <Button Content="Đóng cửa sổ" HorizontalAlignment="Right" Click="Close_Click" 
                        Style="{StaticResource PrimaryButtonStyle}" Width="150" Height="45" Background="#1E293B"/>
            </Border>
        </Grid>
    </Border>
</Window>
