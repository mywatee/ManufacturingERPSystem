<Window x:Class="ManufacturingERP.Views.Dialogs.ShiftDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cấu hình Ca làm việc" Height="650" Width="700"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True" WindowStyle="None" Background="Transparent">
    <Border Background="White" CornerRadius="20" BorderBrush="#CBD5E1" BorderThickness="1.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Opacity="0.15" ShadowDepth="0"/>
        </Border.Effect>
        <Grid Margin="35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Form -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header Grid -->
            <Grid Grid.Row="0" Margin="0,0,0,30">
                <StackPanel>
                    <TextBlock x:Name="DialogTitle" Text="THÊM CA LÀM VIỆC MỚI" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="Thiết lập khung giờ và nhận diện cho ca sản xuất" FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
                </StackPanel>
                
                <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,-10,0" 
                        Style="{StaticResource GhostButtonStyle}" Tag="{StaticResource IconXCircle}" 
                        Foreground="#94A3B8" Click="Cancel_Click" Width="32" Height="32" ToolTip="Đóng"/>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Mã và Tên ca -->
                    <!-- Tên ca -->
                    <TextBlock Text="Tên ca làm việc" FontWeight="Bold" Margin="0,0,0,10" Foreground="#334155" FontSize="14"/>
                    <TextBox x:Name="NameTextBox" Height="45" Tag="VD: Ca sáng (C1)" Style="{StaticResource ModernTextBoxStyle}"/>

                    <!-- Thời gian làm việc -->
                    <Grid Margin="0,25,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="25"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel>
                            <TextBlock Text="Giờ bắt đầu" FontWeight="Bold" Margin="0,0,0,10" Foreground="#334155" FontSize="14"/>
                            <TextBox x:Name="StartTimeTextBox" Height="45" Text="08:00" Style="{StaticResource ModernTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Giờ kết thúc" FontWeight="Bold" Margin="0,0,0,10" Foreground="#334155" FontSize="14"/>
                            <TextBox x:Name="EndTimeTextBox" Height="45" Text="17:00" Style="{StaticResource ModernTextBoxStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Giờ nghỉ -->
                    <Grid Margin="0,25,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="25"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel>
                            <TextBlock Text="Bắt đầu nghỉ" FontWeight="Bold" Margin="0,0,0,10" Foreground="#334155" FontSize="14"/>
                            <TextBox x:Name="BreakStartTextBox" Height="45" Text="12:00" Style="{StaticResource ModernTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Kết thúc nghỉ" FontWeight="Bold" Margin="0,0,0,10" Foreground="#334155" FontSize="14"/>
                            <TextBox x:Name="BreakEndTextBox" Height="45" Text="13:00" Style="{StaticResource ModernTextBoxStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Chọn màu sắc -->
                    <TextBlock Text="Màu sắc nhận diện" FontWeight="Bold" Margin="0,25,0,15" Foreground="#334155" FontSize="14"/>
                    <ListBox x:Name="ColorPickerList" BorderThickness="0" Background="Transparent" SelectionMode="Single">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>

                    <Border Background="#F8FAFC" CornerRadius="12" Padding="15" Margin="0,20,0,0">
                        <CheckBox x:Name="IsActiveCheckBox" Content="Kích hoạt ca làm việc này" IsChecked="True" Style="{StaticResource ModernCheckBoxStyle}"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,35,0,0">
                <Button Content="Hủy bỏ" Click="Cancel_Click" Width="110" Height="45" Background="Transparent" BorderThickness="0" Foreground="#64748B" Margin="0,0,15,0" Cursor="Hand"/>
                <Button Content="Lưu dữ liệu" Click="Save_Click" Width="150" Height="45" Style="{StaticResource PrimaryButtonStyle}" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
