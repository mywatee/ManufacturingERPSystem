<Window x:Class="ManufacturingERP.Views.Dialogs.ScheduleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:ManufacturingERP.Core"
        Title="Phân lịch làm việc hàng loạt" Height="750" Width="950"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True" WindowStyle="None" Background="Transparent">
    <Window.Resources>
        <core:FirstLetterConverter x:Key="StringToInitialConverter"/>
    </Window.Resources>
    <Border Background="White" CornerRadius="20" BorderBrush="#CBD5E1" BorderThickness="1.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Opacity="0.15" ShadowDepth="0"/>
        </Border.Effect>
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock x:Name="DialogTitle" Text="PHÂN LỊCH LÀM VIỆC HÀNG LOẠT" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="Chọn nhiều nhân viên và gán ca trực theo khoảng thời gian" FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-5,-5,0" 
                        Style="{StaticResource GhostButtonStyle}" Tag="{StaticResource IconXCircle}" 
                        Foreground="#94A3B8" Click="Cancel_Click" Width="30" Height="30"/>
            </Grid>

            <!-- Content Split View -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/> <!-- Employees List -->
                    <ColumnDefinition Width="Auto"/> <!-- Divider -->
                    <ColumnDefinition Width="*"/>   <!-- Settings -->
                </Grid.ColumnDefinitions>

                <!-- Left: Employee Selection -->
                <Border Grid.Column="0" BorderBrush="#F1F5F9" BorderThickness="0,0,1,0" Padding="0,0,20,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,15">
                            <TextBlock Text="1. Chọn nhân viên" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,10"/>
                            <Grid>
                                <TextBox x:Name="EmployeeSearchTextBox" Height="40" Tag="Nhập tên hoặc mã nhân viên..." 
                                         Padding="12,0"
                                         Style="{StaticResource ModernTextBoxStyle}" KeyUp="EmployeeSearchTextBox_KeyUp"/>
                            </Grid>
                        </StackPanel>

                        <CheckBox Grid.Row="1" Content="Chọn tất cả nhân viên hiển thị" x:Name="SelectAllCheckBox" 
                                  Margin="0,0,0,10" Style="{StaticResource ModernCheckBoxStyle}" 
                                  Checked="SelectAll_Checked" Unchecked="SelectAll_Unchecked"/>

                        <ListView Grid.Row="2" x:Name="EmployeesListView" BorderThickness="1" BorderBrush="#E2E8F0" 
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}" Margin="5,8" 
                                              Style="{StaticResource ModernCheckBoxStyle}"
                                              Click="EmployeeCheckBox_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="32" Height="32" CornerRadius="16" Background="#EFF6FF" Margin="0,0,12,0">
                                                <TextBlock Text="{Binding User.FullName, Converter={StaticResource StringToInitialConverter}}" 
                                                           VerticalAlignment="Center" HorizontalAlignment="Center" 
                                                           Foreground="#2563EB" FontWeight="Bold" FontSize="11"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding User.FullName}" FontWeight="SemiBold" Foreground="#1E293B"/>
                                                <TextBlock Text="{Binding User.Username}" FontSize="10" Foreground="#64748B"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </CheckBox>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Right: Scheduling Settings -->
                <StackPanel Grid.Column="2" Margin="20,0,0,0">
                    <TextBlock Text="2. Thiết lập thời gian &amp; ca" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,15"/>

                    <!-- Date Range -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Từ ngày" FontSize="12" Foreground="#64748B" Margin="0,0,0,5"/>
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Height="45" Background="#F8FAFC">
                                <DatePicker x:Name="StartDatePicker" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Margin="5,0" SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Đến ngày" FontSize="12" Foreground="#64748B" Margin="0,0,0,5"/>
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Height="45" Background="#F8FAFC">
                                <DatePicker x:Name="EndDatePicker" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Margin="5,0" SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Shift -->
                    <StackPanel x:Name="ShiftContainer" Margin="0,0,0,20">
                        <TextBlock Text="Chọn ca làm việc" FontSize="12" Foreground="#64748B" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ShiftComboBox" Height="45" Style="{StaticResource ModernComboBoxStyle}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{Binding ColorHex}" Width="12" Height="12" CornerRadius="6" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding ShiftName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding StartTime, StringFormat=' ({0:HH:mm}'}" Foreground="#64748B" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding EndTime, StringFormat=' - {0:HH:mm})'}" Foreground="#64748B" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Machine/Line -->
                    <StackPanel x:Name="NoteContainer" Margin="0,0,0,20">
                        <TextBlock Text="Chuyền sản xuất" FontSize="12" Foreground="#64748B" Margin="0,0,0,5"/>
                        <TextBox x:Name="NoteTextBox" Height="45" Tag="VD: LINE-01" Style="{StaticResource ModernTextBoxStyle}"/>
                    </StackPanel>

                    <!-- Summary Info -->
                    <Border Background="#F1F5F9" CornerRadius="12" Padding="15" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Tóm tắt phân lịch:" FontWeight="Bold" FontSize="12" Foreground="#475569" Margin="0,0,0,8"/>
                            <TextBlock x:Name="SummaryTextBlock" Text="Chưa chọn nhân viên" FontSize="12" Foreground="#64748B" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Hủy" Click="Cancel_Click" Width="80" Height="40" Background="Transparent" BorderThickness="0" Foreground="#64748B" Margin="0,0,10,0"/>
                <Button x:Name="SaveButton" Content="Xác nhận phân lịch" Click="Save_Click" Width="180" Height="45" Style="{StaticResource PrimaryButtonStyle}" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
