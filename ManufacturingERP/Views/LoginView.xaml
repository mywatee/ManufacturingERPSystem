<UserControl x:Class="ManufacturingERP.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:core="clr-namespace:ManufacturingERP.Core"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280">
    <UserControl.Resources>
        <core:StringHasValueToBooleanConverter x:Key="StringHasValueToBooleanConverter"/>
        
        <!-- Presentation Storyboards -->
        <Storyboard x:Key="ShowToast">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                             To="1" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" 
                             To="0" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="HideToast">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                             To="0" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" 
                             To="-30" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="ShowSuccessToast">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                             To="1" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" 
                             To="0" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="HideSuccessToast">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                             To="0" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" 
                             To="-30" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="450"/>
        </Grid.ColumnDefinitions>

        <!-- Left Side: Visual Branding -->
        <Border Grid.Column="0" Background="{StaticResource LoginBackgroundGradient}">
            <Grid Margin="50">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="600">
                    <Border Width="60" Height="60" Background="White" CornerRadius="12" Margin="0,0,0,25" HorizontalAlignment="Center">
                        <TextBlock Text="⚙️" FontSize="32" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="MANUFACTURING ERP" FontSize="42" FontWeight="Bold" Foreground="White" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <TextBlock Text="Giải pháp quản trị sản xuất thông minh thế hệ mới" 
                               FontSize="18" Foreground="#BFDBFE" TextWrapping="Wrap" Opacity="0.9" HorizontalAlignment="Center" TextAlignment="Center"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,40,0,0" HorizontalAlignment="Center">
                        <Border Width="4" Height="30" Background="#60A5FA" CornerRadius="2" Margin="0,0,15,0"/>
                        <TextBlock Text="Tối ưu hóa quy trình. Nâng cao năng suất. Tự động hóa vận hành." 
                                   FontSize="15" Foreground="White" VerticalAlignment="Center" Opacity="0.8"/>
                    </StackPanel>

                    <!-- Factory Operational Status Widget -->
                    <Border Background="#20FFFFFF" CornerRadius="16" BorderBrush="#30FFFFFF" BorderThickness="1" Margin="0,50,0,0" Padding="25" HorizontalAlignment="Center" MinWidth="450">
                        <StackPanel>
                            <TextBlock Text="Trạng thái vận hành xưởng" Foreground="White" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,20,0" HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8" HorizontalAlignment="Center">
                                        <Ellipse Width="10" Height="10" Fill="#10B981" Margin="0,0,10,0"/>
                                        <TextBlock Text="Đang chạy" Foreground="#BFDBFE" FontSize="13"/>
                                    </StackPanel>
                                    <TextBlock Text="05 Máy" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="20,0,0,0" HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8" HorizontalAlignment="Center">
                                        <Ellipse Width="10" Height="10" Fill="#F59E0B" Margin="0,0,10,0"/>
                                        <TextBlock Text="Bảo trì" Foreground="#BFDBFE" FontSize="13"/>
                                    </StackPanel>
                                    <TextBlock Text="01 Máy" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </UniformGrid>
                            
                            <Border Height="1" Background="#20FFFFFF" Margin="0,15"/>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" 
                                      Fill="#60A5FA" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Hệ thống vận hành ổn định" Foreground="#BFDBFE" FontSize="11" FontStyle="Italic"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- Subtle Decorative Circles -->
                <Ellipse Width="300" Height="300" Fill="White" Opacity="0.05" Margin="-150,0,0,-150" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                <Ellipse Width="150" Height="150" Fill="White" Opacity="0.05" Margin="0,-50,-50,0" HorizontalAlignment="Right" VerticalAlignment="Top"/>
            </Grid>
        </Border>

        <!-- Right Side: Login Form -->
        <Border Grid.Column="1" HorizontalAlignment="Stretch">
            <Grid VerticalAlignment="Center" Margin="50,0">
                <!-- Floating Toast Notification -->
                <Border x:Name="NotificationToast" 
                        VerticalAlignment="Top" 
                        Margin="0,-80,0,0"
                        Padding="16,12"
                        Background="#FFF1F2"
                        BorderBrush="#FECACA"
                        BorderThickness="1"
                        CornerRadius="12"
                        Opacity="0"
                        IsHitTestVisible="False">
                    <Border.RenderTransform>
                        <TranslateTransform Y="-30"/>
                    </Border.RenderTransform>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.1" Color="#E11D48"/>
                    </Border.Effect>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage, Converter={StaticResource StringHasValueToBooleanConverter}}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard Storyboard="{StaticResource ShowToast}"/>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard Storyboard="{StaticResource HideToast}"/>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⚠️" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="16"/>
                        <TextBlock Grid.Column="1" Text="{Binding ErrorMessage}" Foreground="#DC2626" FontSize="13" FontWeight="Medium" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </Grid>
                </Border>
                
                <!-- Floating Success Toast Notification -->
                <Border x:Name="SuccessToast" 
                        VerticalAlignment="Top" 
                        Margin="0,-80,0,0"
                        Padding="16,12"
                        Background="#ECFDF5"
                        BorderBrush="#10B981"
                        BorderThickness="1"
                        CornerRadius="12"
                        Opacity="0"
                        IsHitTestVisible="False">
                    <Border.RenderTransform>
                        <TranslateTransform Y="-30"/>
                    </Border.RenderTransform>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.1" Color="#10B981"/>
                    </Border.Effect>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding InfoMessage, Converter={StaticResource StringHasValueToBooleanConverter}}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard Storyboard="{StaticResource ShowSuccessToast}"/>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard Storyboard="{StaticResource HideSuccessToast}"/>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="24" Height="24" CornerRadius="12" Background="#10B981" Margin="0,0,12,0">
                            <Path Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z" 
                                  Fill="White" Stretch="Uniform" Margin="5" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Thành công" FontWeight="Bold" FontSize="13" Foreground="#065F46"/>
                            <TextBlock Text="{Binding InfoMessage}" Foreground="#047857" FontSize="12" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel>
                    <TextBlock Text="Đăng nhập hệ thống ERP" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Chào mừng quay lại! Vui lòng nhập thông tin tài khoản." 
                               FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,40"/>

                <!-- Username -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Mã nhân viên / Username" Style="{StaticResource LoginLabelStyle}"/>
                    <TextBox Text="{Binding Username}" Style="{StaticResource LoginTextBoxStyle}"/>
                </StackPanel>

                <!-- Password -->
                <StackPanel Margin="0,0,0,30">
                    <TextBlock Text="Mật khẩu" Style="{StaticResource LoginLabelStyle}"/>
                    <Grid>
                        <!-- Hidden Mode (PasswordBox) -->
                        <PasswordBox core:PasswordHelper.Attach="True" 
                                     core:PasswordHelper.Password="{Binding Password, Mode=TwoWay}">
                            <PasswordBox.Style>
                                <Style TargetType="PasswordBox" BasedOn="{StaticResource LoginPasswordBoxStyle}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </PasswordBox.Style>
                        </PasswordBox>

                        <!-- Visible Mode (TextBox) -->
                        <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource LoginTextBoxStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!-- Toggle Visibility Button -->
                        <CheckBox IsChecked="{Binding IsPasswordVisible}"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,15,0"
                                  Cursor="Hand">
                            <CheckBox.Template>
                                <ControlTemplate TargetType="CheckBox">
                                    <Grid Background="Transparent">
                                        <!-- Eye Icon (Open) -->
                                        <Path x:Name="EyeOn" Data="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z M12 17a5 5 0 1 0 0-10 5 5 0 0 0 0 10z M12 14.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z" 
                                              Stroke="{StaticResource SecondaryTextBrush}" StrokeThickness="1.5" Visibility="Collapsed"/>
                                        <!-- Eye Icon (Closed) -->
                                        <Path x:Name="EyeOff" Data="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24 M1 1l22 22" 
                                              Stroke="{StaticResource SecondaryTextBrush}" StrokeThickness="1.5" Visibility="Visible"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="EyeOn" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="EyeOff" Property="Visibility" Value="Collapsed"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </CheckBox.Template>
                        </CheckBox>
                    </Grid>
                </StackPanel>

                <Grid Margin="0,0,0,30">
                    <CheckBox IsChecked="{Binding IsRememberMe}" 
                              Content="Ghi nhớ đăng nhập" VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}"/>
                    <Button Content="Quên mật khẩu?" 
                            Command="{Binding RequestResetCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Cursor="Hand"
                            Foreground="#2563EB" 
                            FontWeight="SemiBold" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Login Button -->
                <Button Command="{Binding LoginCommand}" Style="{StaticResource PrimaryLoginButtonStyle}">
                    <Grid>
                        <TextBlock Text="Đăng nhập hệ thống">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Đang xử lý..." VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Button>

                <TextBlock Text="© 2026 Manufacturing ERP System. Phiên bản 1.0.0" 
                           FontSize="12" Foreground="#9CA3AF" Margin="0,60,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
