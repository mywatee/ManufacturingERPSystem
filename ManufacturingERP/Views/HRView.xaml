<UserControl x:Class="ManufacturingERP.Views.HRView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ManufacturingERP.Views"
             xmlns:viewmodels="clr-namespace:ManufacturingERP.ViewModels"
             xmlns:core="clr-namespace:ManufacturingERP.Core;assembly=ManufacturingERP"
             mc:Ignorable="d" 
             x:Name="root"
             d:DesignHeight="1000" d:DesignWidth="1200"
             Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,4">
                    <Path Data="{StaticResource IconUser}" Fill="#1e3a5f" Width="24" Height="24" Margin="0,0,12,0" Stretch="Uniform"/>
                    <TextBlock Text="Nhân sự &amp; Lương" FontSize="28" FontWeight="Bold" Foreground="#1e3a5f"/>
                </StackPanel>
                <TextBlock Text="Quản lý hồ sơ nhân viên, tính lương và chấm công" FontSize="14" Foreground="#64748b"/>
            </StackPanel>

            <!-- Custom Tab Navigation (Pills) -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,32">
                <RadioButton x:Name="TabProfiles" Content="Hồ sơ nhân viên" IsChecked="{Binding IsProfilesTabActive, Mode=TwoWay}" Style="{StaticResource RoleChipStyle}" Margin="0,0,12,0"/>
                <RadioButton x:Name="TabPayroll" Content="Tính lương sản phẩm" IsChecked="{Binding IsPayrollTabActive, Mode=TwoWay}" Style="{StaticResource RoleChipStyle}" Margin="0,0,12,0"/>
                <RadioButton x:Name="TabAttendance" Content="Quản lý chấm công" IsChecked="{Binding IsAttendanceTabActive, Mode=TwoWay}" Style="{StaticResource RoleChipStyle}" Margin="0,0,12,0"/>
                <RadioButton x:Name="TabSchedules" Content="Ca &amp; Lịch làm việc" IsChecked="{Binding IsSchedulesTabActive, Mode=TwoWay}" Style="{StaticResource RoleChipStyle}" Margin="0,0,12,0"/>
                <RadioButton x:Name="TabReports" Content="Xuất báo cáo" IsChecked="{Binding IsReportsTabActive, Mode=TwoWay}" Style="{StaticResource RoleChipStyle}"/>
            </StackPanel>

            <!-- Main Content Area -->
            <Grid Grid.Row="2">
                <!-- Profile Content -->
                <local:EmployeeProfilesView Visibility="{Binding IsChecked, ElementName=TabProfiles, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- Payroll Content -->
                <local:PayrollManagementView Visibility="{Binding IsChecked, ElementName=TabPayroll, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- Attendance Content -->
                <local:AttendanceManagementView Visibility="{Binding IsChecked, ElementName=TabAttendance, Converter={StaticResource BooleanToVisibilityConverter}}"/>


                <!-- Reports Content -->
                <local:HRReportView Visibility="{Binding IsChecked, ElementName=TabReports, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- Shift & Schedule Content -->
                <Grid Visibility="{Binding IsChecked, ElementName=TabSchedules, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,24">
                        <TextBlock Text="Cấu hình Ca &amp; Phân lịch" FontSize="18" FontWeight="Bold" Foreground="#1e293b"/>
                        <TextBlock Text="Thiết lập thời gian làm việc và gán lịch trực cho nhân sự" FontSize="13" Foreground="#64748b"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Shift List -->
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,24,0" VerticalAlignment="Top">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <TextBlock Text="Danh sách Ca làm việc" FontWeight="Bold" Foreground="#1e293b" FontSize="16"/>
                                    <Button Content="+ Thêm ca" 
                                            Command="{Binding AddShiftCommand}"
                                            Visibility="{Binding CanAddHR, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            HorizontalAlignment="Right" Style="{StaticResource SecondaryButtonStyle}" Padding="12,6" FontSize="11"/>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Shifts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderThickness="1" BorderBrush="#E2E8F0" CornerRadius="12" Padding="16" Margin="0,0,0,16" Background="White">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Dynamic Color Bar from DB -->
                                                    <Border Width="6" Height="40" Background="{Binding ColorHex}" CornerRadius="3" Margin="0,0,16,0" VerticalAlignment="Top"/>
                                                    
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding ShiftName}" FontWeight="Bold" FontSize="15" Foreground="#1e293b" Margin="0,0,0,4"/>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Path Data="{StaticResource IconClock}" Fill="#64748b" Width="12" Height="12" Margin="0,0,6,0" Stretch="Uniform"/>
                                                            <TextBlock Text="{Binding StartTime, StringFormat=HH:mm}" Foreground="#475569" FontSize="13" FontWeight="Medium"/>
                                                            <TextBlock Text=" - " Foreground="#94a3b8" FontSize="13"/>
                                                            <TextBlock Text="{Binding EndTime, StringFormat=HH:mm}" Foreground="#475569" FontSize="13" FontWeight="Medium"/>
                                                        </StackPanel>
                                                        
                                                        <!-- Break Time and Status Badges (WrapPanel to prevent clipping) -->
                                                        <WrapPanel Margin="0,8,0,0">
                                                            <Border Background="#F8FAFC" CornerRadius="6" Padding="8,4" Margin="0,0,8,4">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="Nghỉ: " FontSize="11" Foreground="#94a3b8"/>
                                                                    <TextBlock Text="{Binding BreakStartTime, StringFormat=HH:mm}" FontSize="11" Foreground="#64748b" FontWeight="SemiBold"/>
                                                                    <TextBlock Text=" - " FontSize="11" Foreground="#94a3b8"/>
                                                                    <TextBlock Text="{Binding BreakEndTime, StringFormat=HH:mm}" FontSize="11" Foreground="#64748b" FontWeight="SemiBold"/>
                                                                </StackPanel>
                                                            </Border>
                                                            
                                                            <!-- Status Badge -->
                                                            <Border CornerRadius="6" Padding="8,4" Margin="0,0,0,4">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="#F0FDF4"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                                <Setter Property="Background" Value="#FEF2F2"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="Đang chạy"/>
                                                                            <Setter Property="Foreground" Value="#16A34A"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                                    <Setter Property="Text" Value="Đã dừng"/>
                                                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                        </WrapPanel>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                                        <Button Style="{StaticResource GhostButtonStyle}" Tag="{StaticResource IconEye}" 
                                                                Command="{Binding DataContext.ViewShiftDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Foreground="#6366f1" Width="32" Height="32" ToolTip="Xem chi tiết"/>
                                                        <Button Style="{StaticResource GhostButtonStyle}" Tag="{StaticResource IconEdit}" 
                                                                Command="{Binding DataContext.EditShiftCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Visibility="{Binding DataContext.CanEditHR, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                Width="32" Height="32" Margin="4,0,0,0" ToolTip="Sửa ca"/>
                                                        <Button Style="{StaticResource GhostButtonStyle}" Tag="{StaticResource IconDelete}" 
                                                                Command="{Binding DataContext.DeleteShiftCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Visibility="{Binding DataContext.CanDeleteHR, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                Foreground="#EF4444" Width="32" Height="32" Margin="4,0,0,0" ToolTip="Xóa ca"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Scheduling Grid -->
                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="0">
                            <StackPanel>
                                <Border Background="#F8FAFC" BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Padding="20,16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                                             <Path Data="{StaticResource IconCalendar}" Fill="#2563EB" Width="18" Height="18" Margin="0,0,12,0" Stretch="Uniform"/>
                                             <TextBlock Text="Bảng lịch phân ca tổng thể" FontWeight="Bold" FontSize="15" Foreground="#1e293b" VerticalAlignment="Center"/>
                                         </StackPanel>
                                         
                                         <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
                                             <!-- Month/Year Selectors -->
                                             <TextBlock Text="Tháng:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#64748B" FontSize="12"/>
                                             <ComboBox ItemsSource="{Binding AvailableMonths}" SelectedItem="{Binding ScheduleMonth}" Width="70" Height="32" Margin="0,0,12,0" Style="{StaticResource ModernComboBoxStyle}"/>
                                             
                                             <TextBlock Text="Năm:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#64748B" FontSize="12"/>
                                             <ComboBox ItemsSource="{Binding AvailableYears}" SelectedItem="{Binding ScheduleYear}" Width="85" Height="32" Margin="0,0,15,0" Style="{StaticResource ModernComboBoxStyle}"/>
                                             
                                             <Button Content="+ Phân lịch" 
                                                     Command="{Binding AssignScheduleCommand}"
                                                     Style="{StaticResource PrimaryButtonStyle}" Padding="12,6" Margin="0,0,10,0"/>
                                             <Button Content="Nhập/Xuất Excel" 
                                                     Command="{Binding OpenScheduleImportExportCommand}"
                                                     Style="{StaticResource SecondaryButtonStyle}" Padding="12,6"/>
                                         </StackPanel>

                                        <!-- New Info Bar for Guide (Amber Theme) -->
                                        <Border Grid.Row="1" Background="#FFFBEB" CornerRadius="8" Margin="0,12,0,0" Padding="12,8" BorderThickness="1" BorderBrush="#FEF3C7">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" 
                                                      Fill="#D97706" Width="14" Height="14" Margin="0,0,8,0" Stretch="Uniform"/>
                                                <TextBlock Text="{Binding ScheduleGuide}" FontSize="12" Foreground="#92400E" FontWeight="Medium"/>
                                            </StackPanel>
                                        </Border>
                                     </Grid>
                                 </Border>

                                 <DataGrid ItemsSource="{Binding ScheduleMatrixData}" 
                                           Style="{StaticResource ModernDataGridStyle}"
                                           Height="480"
                                           AutoGenerateColumns="True"
                                           AutoGeneratingColumn="ScheduleGrid_AutoGeneratingColumn"
                                           IsReadOnly="True"
                                           GridLinesVisibility="All"
                                           HorizontalGridLinesBrush="#F1F5F9"
                                           VerticalGridLinesBrush="#F1F5F9">
                                     <DataGrid.Resources>
                                         <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FFF7ED"/>
                                         <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#C2410C"/>
                                         <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FFF7ED"/>
                                         <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#C2410C"/>
                                         
                                         <Style TargetType="DataGridColumnHeader">
                                             <Setter Property="Background" Value="#F8FAFC"/>
                                             <Setter Property="Foreground" Value="#64748b"/>
                                             <Setter Property="FontWeight" Value="SemiBold"/>
                                             <Setter Property="Padding" Value="8"/>
                                             <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                         </Style>
                                         <Style TargetType="DataGridRow">
                                             <Setter Property="Background" Value="White"/>
                                             <Style.Triggers>
                                                 <Trigger Property="IsSelected" Value="True">
                                                     <Setter Property="Background" Value="#FFF7ED"/>
                                                     <Setter Property="BorderBrush" Value="#F97316"/>
                                                 </Trigger>
                                                 <Trigger Property="IsMouseOver" Value="True">
                                                     <Setter Property="Background" Value="#FFFBF0"/>
                                                 </Trigger>
                                             </Style.Triggers>
                                         </Style>
                                         <Style TargetType="DataGridCell">
                                             <Setter Property="VerticalAlignment" Value="Center"/>
                                             <Setter Property="Template">
                                                 <Setter.Value>
                                                     <ControlTemplate TargetType="DataGridCell">
                                                         <Border Background="{TemplateBinding Background}" Padding="4">
                                                             <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                         </Border>
                                                     </ControlTemplate>
                                                 </Setter.Value>
                                             </Setter>
                                             <Setter Property="ContextMenu">
                                                 <Setter.Value>
                                                     <ContextMenu>
                                                         <MenuItem Header="Sửa lượt trực" Command="{Binding DataContext.EditScheduleCellCommand, Source={x:Reference root}}">
                                                             <MenuItem.CommandParameter>
                                                                 <MultiBinding Converter="{StaticResource GlobalMultiBindingConverter}">
                                                                     <Binding Path="PlacementTarget.DataContext" RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType={x:Type ContextMenu}}"/>
                                                                     <Binding Path="PlacementTarget.Column.Header" RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType={x:Type ContextMenu}}"/>
                                                                 </MultiBinding>
                                                             </MenuItem.CommandParameter>
                                                             <MenuItem.Icon>
                                                                 <Path Data="{StaticResource IconEdit}" Fill="#2563EB" Width="12" Height="12" Stretch="Uniform"/>
                                                             </MenuItem.Icon>
                                                         </MenuItem>
                                                         <MenuItem Header="Hủy lượt trực (Xóa)" Command="{Binding DataContext.DeleteScheduleCellCommand, Source={x:Reference root}}">
                                                             <MenuItem.CommandParameter>
                                                                 <MultiBinding Converter="{StaticResource GlobalMultiBindingConverter}">
                                                                     <Binding Path="PlacementTarget.DataContext" RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType={x:Type ContextMenu}}"/>
                                                                     <Binding Path="PlacementTarget.Column.Header" RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType={x:Type ContextMenu}}"/>
                                                                 </MultiBinding>
                                                             </MenuItem.CommandParameter>
                                                             <MenuItem.Icon>
                                                                 <Path Data="{StaticResource IconDelete}" Fill="#EF4444" Width="12" Height="12" Stretch="Uniform"/>
                                                             </MenuItem.Icon>
                                                         </MenuItem>
                                                     </ContextMenu>
                                                 </Setter.Value>
                                             </Setter>
                                             <Style.Triggers>
                                                 <Trigger Property="IsSelected" Value="True">
                                                     <Setter Property="Foreground" Value="#C2410C"/>
                                                     <Setter Property="FontWeight" Value="SemiBold"/>
                                                 </Trigger>
                                             </Style.Triggers>
                                         </Style>
                                     </DataGrid.Resources>
                                 </DataGrid>

                                 <!-- Pagination Footer for Schedule -->
                                 <Border Padding="20,12" Background="#F8FAFC" CornerRadius="0,0,12,12" BorderThickness="0,1,0,0" BorderBrush="#E2E8F0">
                                     <Grid>
                                         <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                             <TextBlock Foreground="#64748b" VerticalAlignment="Center">
                                                 <Run Text="Tổng cộng: "/>
                                                 <Run Text="{Binding ScheduleTotalEmployees}" FontWeight="Bold"/>
                                                 <Run Text=" nhân viên"/>
                                             </TextBlock>
                                             <Border Width="1" Background="#E2E8F0" Margin="16,4" Height="16"/>
                                             <TextBlock Text="10 nhân viên/trang" FontSize="12" Foreground="#94a3b8" VerticalAlignment="Center"/>
                                         </StackPanel>

                                         <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                             <TextBlock VerticalAlignment="Center" Margin="0,0,16,0" Foreground="#64748b">
                                                 <Run Text="Trang "/>
                                                 <Run Text="{Binding ScheduleCurrentPage}" FontWeight="Bold"/>
                                                 <Run Text=" / "/>
                                                 <Run Text="{Binding ScheduleTotalPages}"/>
                                             </TextBlock>

                                             <Button Command="{Binding PrevSchedulePageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="12,6" Margin="0,0,8,0">
                                                 <StackPanel Orientation="Horizontal">
                                                     <Path Data="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z" Fill="#64748b" Width="14" Height="14" Margin="0,0,4,0" Stretch="Uniform"/>
                                                     <TextBlock Text="Trước" FontSize="12" VerticalAlignment="Center"/>
                                                 </StackPanel>
                                             </Button>

                                             <Button Command="{Binding NextSchedulePageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="12,6">
                                                 <StackPanel Orientation="Horizontal">
                                                     <TextBlock Text="Sau" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                     <Path Data="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z" Fill="#64748b" Width="14" Height="14" Stretch="Uniform"/>
                                                 </StackPanel>
                                             </Button>
                                         </StackPanel>
                                     </Grid>
                                 </Border>
                            </StackPanel>
                        </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ScrollViewer>
</UserControl>


