<UserControl x:Class="ManufacturingERP.Views.ActivitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ManufacturingERP.Views"
             xmlns:vm="clr-namespace:ManufacturingERP.ViewModels"
             xmlns:core="clr-namespace:ManufacturingERP.Core"
             mc:Ignorable="d" 
             Language="vi-VN"
             d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ManufacturingERP;component/Styles/DesignSystem.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <core:FirstLetterConverter x:Key="LocalFirstLetterConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="#F9FAFB">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Back Button -->
                <Button Grid.Column="0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding BackCommand}" Padding="10,6">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                            <Path Data="M19 12H5 M12 19l-7-7 7-7" Stroke="{StaticResource PrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Viewbox>
                        <TextBlock Text="Quay lại Dashboard" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Center: Title -->
                <TextBlock Grid.Column="1" Text="Toàn bộ Nhật ký Hoạt động" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                
                <!-- Right: Placeholder to balance the Grid -->
                <Border Grid.Column="2" Width="150" Visibility="Hidden"/>
            </Grid>

            <!-- Filter Bar -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,20" Padding="20,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search -->
                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="Tìm kiếm nhanh" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,5"/>
                        <Border Background="#F9FAFB" CornerRadius="8" BorderThickness="1" BorderBrush="#E5E7EB" Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="16" Height="16" Margin="0,0,10,0">
                                    <Path Data="M21 21l-6-6 m2-5a7 7 0 11-14 0 7 7 0 0114 0z" Stroke="#9CA3AF" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Viewbox>
                                <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" BorderThickness="0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Action Type -->
                    <StackPanel Grid.Column="1" Margin="0,0,20,0" Width="150">
                        <TextBlock Text="Loại hành động" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding ActivityTypes}" SelectedValue="{Binding SelectedType}" Height="40" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- Start Date -->
                    <StackPanel Grid.Column="2" Margin="0,0,20,0" Width="150">
                        <TextBlock Text="Từ ngày" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding StartDate}" Height="40" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- End Date -->
                    <StackPanel Grid.Column="3" Margin="0,0,20,0" Width="150">
                        <TextBlock Text="Đến ngày" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding EndDate}" Height="40" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- Reset -->
                    <Button Grid.Column="4" Style="{StaticResource SecondaryButtonStyle}" VerticalAlignment="Bottom" Height="40" Padding="15,0"
                            Command="{Binding LoadAllActivitiesCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                                <Path Data="M23 4v6h-6 M1 20v-6h6 M3.51 9a9 9 0 0 1 14.85-3.36L23 10 M1 14l4.64 4.36A9 9 0 0 0 20.49 15" Stroke="{StaticResource SecondaryTextBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Viewbox>
                            <TextBlock Text="Làm mới"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <DataGrid Style="{StaticResource ModernDataGridStyle}" ItemsSource="{Binding AllActivities}" IsReadOnly="True">
                        <DataGrid.Columns>
                            <!-- Hành động -->
                            <DataGridTemplateColumn Header="Hành động" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border HorizontalAlignment="Left" MinWidth="90" CornerRadius="8" Padding="8,5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="Thêm">
                                                            <Setter Property="Background" Value="#F0FDF4"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Sửa">
                                                            <Setter Property="Background" Value="#EFF6FF"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Xóa">
                                                            <Setter Property="Background" Value="#FEF2F2"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Hệ thống">
                                                            <Setter Property="Background" Value="#F5F3FF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="24" Height="24" CornerRadius="12" Background="White" Margin="0,0,10,0">
                                                    <Viewbox Width="12" Height="12">
                                                        <Path StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                                            <Path.Style>
                                                                <Style TargetType="Path">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Thêm">
                                                                            <Setter Property="Data" Value="M12 5v14 M5 12h14"/>
                                                                            <Setter Property="Stroke" Value="#16A34A"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Sửa">
                                                                            <Setter Property="Data" Value="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7 M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                                                            <Setter Property="Stroke" Value="#2563EB"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Xóa">
                                                                            <Setter Property="Data" Value="M3 6h18 M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2 M10 11v6 M14 11v6"/>
                                                                            <Setter Property="Stroke" Value="#DC2626"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Hệ thống">
                                                                            <Setter Property="Data" Value="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                                                                            <Setter Property="Stroke" Value="#7C3AED"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                    </Viewbox>
                                                </Border>
                                                <TextBlock Text="{Binding Type}" VerticalAlignment="Center" FontWeight="Medium"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Nội dung -->
                            <DataGridTextColumn Header="Nội dung" Binding="{Binding Content}" Width="*"/>

                            <!-- Người thực hiện -->
                            <DataGridTemplateColumn Header="Người thực hiện" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="28" Height="28" CornerRadius="14" Background="#F3F4F6" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding User, Converter={StaticResource LocalFirstLetterConverter}}" 
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#6B7280"/>
                                            </Border>
                                            <TextBlock Text="{Binding User}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Thời gian -->
                            <DataGridTextColumn Header="Thời gian" Binding="{Binding Time}" Width="180">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Thao tác -->
                            <DataGridTemplateColumn Header="Chi tiết" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" Cursor="Hand">
                                            <Viewbox Width="20" Height="20">
                                                <Path Data="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z M12 17a5 5 0 1 0 0-10 5 5 0 0 0 0 10z M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" 
                                                      Fill="Transparent" Stroke="#3B82F6" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            </Viewbox>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty State -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" 
                                Visibility="{Binding AllActivities.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=invert}">
                        <Viewbox Width="80" Height="80" Opacity="0.2">
                            <Path Data="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z M13 2v7h7" Stroke="#6B7280" StrokeThickness="2"/>
                        </Viewbox>
                        <TextBlock Text="Không tìm thấy hoạt động nào phù hợp" Margin="0,20,0,0" Foreground="{StaticResource SecondaryTextBrush}" FontSize="16"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
