<UserControl x:Class="ManufacturingERP.Views.EmployeeProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ManufacturingERP.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Hồ sơ nhân viên" FontSize="18" FontWeight="Bold" Foreground="#1e293b"/>
            <TextBlock Text="Quản lý thông tin cá nhân và chức danh" FontSize="13" Foreground="#64748b"/>
        </StackPanel>

        <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" 
                Content="+ Thêm nhân viên" Style="{StaticResource PrimaryButtonStyle}" Padding="20,10"
                Command="{Binding AddEmployeeCommand}"/>

        <!-- Profile KPIs -->
        <Grid Grid.Row="1" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,16,0">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#EFF6FF" Width="48" Height="48" CornerRadius="24" Margin="0,0,16,0">
                        <Path Data="{StaticResource IconUser}" Fill="#2563EB" Width="22" Height="22" Stretch="Uniform"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Tổng số nhân viên" FontSize="13" Foreground="#64748b"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding TotalEmployees}" FontSize="24" FontWeight="Bold" Foreground="#1e293b"/>
                        </StackPanel>
                        <TextBlock Text="Tất cả bộ phận" FontSize="11" Foreground="#94a3b8"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,16,0">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#F0FDF4" Width="48" Height="48" CornerRadius="24" Margin="0,0,16,0">
                        <Path Data="{StaticResource IconUser}" Fill="#16A34A" Width="22" Height="22" Stretch="Uniform"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Đang làm việc" FontSize="13" Foreground="#64748b"/>
                        <TextBlock Text="{Binding ActiveEmployees}" FontSize="24" FontWeight="Bold" Foreground="#1e293b" Margin="0,4,0,0"/>
                        <TextBlock Text="Nhân viên chính thức" FontSize="11" Foreground="#94a3b8"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#FFF7ED" Width="48" Height="48" CornerRadius="24" Margin="0,0,16,0">
                        <Path Data="{StaticResource IconUser}" Fill="#EA580C" Width="22" Height="22" Stretch="Uniform"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Đang nghỉ phép" FontSize="13" Foreground="#64748b"/>
                        <TextBlock Text="{Binding OnLeaveEmployees}" FontSize="24" FontWeight="Bold" Foreground="#1e293b" Margin="0,4,0,0"/>
                        <TextBlock Text="Cập nhật hôm nay" FontSize="11" Foreground="#94a3b8"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Search/Filter -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            
            <Border Background="#F8FAFC" CornerRadius="10" Padding="12,0" Height="45" Margin="0,0,16,0">
                <Grid>
                    <Path Data="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" 
                          Fill="#94a3b8" Width="18" Height="18" HorizontalAlignment="Left" Stretch="Uniform"/>
                    <TextBox Style="{StaticResource LoginTextBoxStyle}" BorderThickness="0" Background="Transparent" 
                             VerticalContentAlignment="Center" Margin="30,0,0,0" Tag="Tìm kiếm theo mã hoặc tên nhân viên..."
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Border>
            
            <ComboBox Grid.Column="1" Style="{StaticResource ModernComboBoxStyle}" 
                      ItemsSource="{Binding DepartmentFilters}"
                      SelectedItem="{Binding SelectedDepartmentFilter}"/>
        </Grid>

        <!-- Profile DataGrid -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid x:Name="ProfileGrid" ItemsSource="{Binding EmployeeProfiles}" 
                      Style="{StaticResource ModernDataGridStyle}"
                      VerticalScrollBarVisibility="Disabled"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã NV" Binding="{Binding EmployeeCode}" Width="100"/>
                    <DataGridTemplateColumn Header="Họ và tên" Width="2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#EFF6FF" Width="32" Height="32" CornerRadius="16" Margin="0,0,12,0">
                                        <Path Data="{StaticResource IconUser}" Fill="#3B82F6" Width="14" Height="14" Stretch="Uniform"/>
                                    </Border>
                                    <TextBlock Text="{Binding FullName}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Bộ phận" Binding="{Binding Department}" Width="*"/>
                    <DataGridTextColumn Header="Chức vụ" Binding="{Binding Position}" Width="*"/>
                    <DataGridTextColumn Header="Ngày vào làm" Binding="{Binding JoinDate, StringFormat=yyyy-MM-dd}" Width="*"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*"/>
                    <DataGridTextColumn Header="Điện thoại" Binding="{Binding Phone}" Width="*"/>
                    <DataGridTemplateColumn Header="Trạng thái" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="badge" Style="{StaticResource StatusBadgeStyle}">
                                    <TextBlock x:Name="txt" Text="Đang làm việc"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Đang làm việc">
                                        <Setter TargetName="badge" Property="Style" Value="{StaticResource StatusDoneStyle}"/>
                                        <Setter TargetName="txt" Property="Text" Value="Đang làm việc"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Nghỉ phép">
                                        <Setter TargetName="badge" Property="Style" Value="{StaticResource StatusWaitingStyle}"/>
                                        <Setter TargetName="txt" Property="Text" Value="Nghỉ phép"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Nghỉ việc">
                                        <Setter TargetName="badge" Property="Background" Value="#F3F4F6"/>
                                        <Setter TargetName="txt" Property="Text" Value="Nghỉ việc"/>
                                        <Setter TargetName="txt" Property="Foreground" Value="#6B7280"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Thao tác" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource GhostButtonStyle}" Tag="{StaticResource IconEdit}" Margin="0,0,8,0"
                                            Command="{Binding DataContext.EditEmployeeCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Style="{StaticResource GhostButtonStyle}" Tag="{StaticResource IconDelete}" Foreground="#EF4444"
                                            Command="{Binding DataContext.DeleteEmployeeCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
