<UserControl x:Class="ManufacturingERP.Views.CreateWorkOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ManufacturingERP.Views"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:core="clr-namespace:ManufacturingERP.Core"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="#F8FAFC">
    
    <Control.Resources>
        <core:StringHasValueToBooleanConverter x:Key="StringHasValueToBooleanConverter"/>
        
        <!-- Modern Card Style -->
        <Style x:Key="ModernCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.04" Color="#1E293B"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Form Label Style -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Action Button Style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Custom TextBox with Placeholder Style -->
        <Style x:Key="ModernTextBoxWithPlaceholder" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <Grid>
                                <TextBlock Text="{TemplateBinding Tag}" Margin="{TemplateBinding Padding}" Foreground="#94A3B8" IsHitTestVisible="False" VerticalAlignment="Center" FontSize="{TemplateBinding FontSize}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Control.Resources>

    <Grid Background="Transparent" PreviewMouseDown="OnBackgroundMouseDown">
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Background="Transparent">

        <StackPanel Margin="30,20,30,40" Background="Transparent">
            <!-- Header Section -->
            
            <!-- 1. Refined Balanced Header -->
                <Grid Margin="0,0,0,40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/> <!-- Equal width side columns for absolute center -->
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Command="{Binding CancelCommand}" 
                            Background="Transparent" BorderThickness="0" Padding="0" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32" Height="32" Background="#F1F5F9" CornerRadius="16" Margin="0,0,12,0">
                                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Quay lại danh sách lệnh sản xuất" Foreground="#64748B" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Grid.Column="1" Text="Khởi tạo Lệnh sản xuất" FontSize="32" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center"/>
                    
                    <Button Grid.Column="2" Content="Kích hoạt lệnh ngay" Command="{Binding SaveCommand}" Style="{StaticResource ActionButtonStyle}" 
                            Background="#2563EB" Foreground="White" Width="200" HorizontalAlignment="Right"/>
                </Grid>

                <!-- 2. Two-Column Layout -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/> <!-- Main Content (70%) -->
                        <ColumnDefinition Width="320"/> <!-- Sidebar (30%) -->
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,30,0">
                    <!-- CARD 1: GENERAL INFO -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="30" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.5*"/> <!-- Mã lệnh -->
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/> <!-- Ngày bắt đầu -->
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/> <!-- Hạn hoàn thành -->
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="150"/> <!-- Mức độ ưu tiên -->
                            </Grid.ColumnDefinitions>

                            <!-- Mã lệnh -->
                            <StackPanel Grid.Column="0">
                                <Grid>
                                    <TextBlock Text="Mã lệnh sản xuất" Style="{StaticResource FormLabelStyle}" HorizontalAlignment="Left"/>
                                    <CheckBox IsChecked="{Binding IsAutoCode, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,-4,0,0">
                                        <TextBlock Text="Tự động" Foreground="#3B82F6" FontSize="11" FontWeight="SemiBold"/>
                                    </CheckBox>
                                </Grid>
                                <TextBox Text="{Binding WoCode, Mode=TwoWay}" 
                                         Tag="VD: LSX-001..."
                                         Style="{StaticResource ModernTextBoxWithPlaceholder}"
                                         Height="45" FontSize="14" FontWeight="Bold" IsReadOnly="{Binding IsAutoCode}"/>
                            </StackPanel>

                            <!-- Ngày bắt đầu -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Ngày bắt đầu dự kiến" Style="{StaticResource FormLabelStyle}"/>
                                <DatePicker SelectedDate="{Binding StartDate, Mode=TwoWay}" 
                                            Language="vi-VN" Height="45" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <!-- Hạn hoàn thành -->
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Hạn hoàn thành" Style="{StaticResource FormLabelStyle}"/>
                                <DatePicker SelectedDate="{Binding EndDate, Mode=TwoWay}" 
                                            Language="vi-VN" Height="45" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <!-- Khẩn cấp -->
                            <StackPanel Grid.Column="6">
                                <TextBlock Text="Mức độ ưu tiên" Style="{StaticResource FormLabelStyle}"/>
                                <Border Background="#FEF2F2" BorderBrush="#FEE2E2" BorderThickness="1" CornerRadius="12" Height="45" Padding="15,0">
                                    <CheckBox IsChecked="{Binding IsUrgent, Mode=TwoWay}" VerticalAlignment="Center">
                                        <TextBlock Text="Ưu tiên khẩn cấp" Foreground="#EF4444" FontWeight="Bold" FontSize="12"/>
                                    </CheckBox>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- CARD 2: ADD PRODUCT FORM -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="30" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="THÊM SẢN PHẨM VÀO LỆNH" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,15"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Sản phẩm -->
                                <StackPanel Grid.Column="0">
                                    <ComboBox x:Name="ProductCombo" ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct, Mode=TwoWay}" 
                                              DisplayMemberPath="MaterialName" Height="45" Padding="15,0" VerticalContentAlignment="Center">
                                        <ComboBox.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="10"/>
                                            </Style>
                                        </ComboBox.Resources>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Số lượng -->
                                <TextBox Grid.Column="2" Text="{Binding ItemQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                         Tag="Nhập số lượng..." Height="45"
                                         Style="{StaticResource ModernTextBoxWithPlaceholder}"
                                         PreviewTextInput="NumberValidationTextBox"/>

                                <!-- Button Add -->
                                <Button Grid.Column="4" Command="{Binding AddItemCommand}" Width="160" Height="45" Background="#3B82F6" Foreground="White" Style="{StaticResource ActionButtonStyle}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock x:Name="btnIcon" Text="&#xE710;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock x:Name="btnText" Text="Thêm sản phẩm" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter TargetName="btnText" Property="Text" Value="Lưu thay đổi"/>
                                                    <Setter TargetName="btnIcon" Property="Text" Value="&#xE73E;"/>
                                                    <Setter Property="Background" Value="#16A34A"/>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter Property="Tag" Value="Editing"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- CARD 3: ITEMS LIST GRID -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="0" ClipToBounds="True">
                        <Grid MinHeight="250">
                            <!-- Empty State Placeholder -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OrderItems.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="&#xEA37;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#E2E8F0" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                <TextBlock Text="Chưa có sản phẩm nào" Foreground="#94A3B8" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Hãy thêm sản phẩm bằng form phía trên" Foreground="#CBD5E1" FontSize="11" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#F8FAFC" Padding="20,10" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <TextBlock Text="DANH MỤC SẢN PHẨM TRONG LỆNH" FontSize="11" FontWeight="Bold" Foreground="#64748B" VerticalAlignment="Center"/>
                                        
                                        <Button Command="{Binding ClearAllItemsCommand}" 
                                                HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding OrderItems.Count, Converter={StaticResource StringHasValueToBooleanConverter}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <!-- If Converter above doesn't work for int, I'll use a simpler trigger or just visible -->
                                                        <DataTrigger Binding="{Binding OrderItems.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.7"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="#EF4444" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                <TextBlock Text="Xóa tất cả" Foreground="#EF4444" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>

                                <DataGrid Grid.Row="1" ItemsSource="{Binding OrderItems}" 
                                          SelectedItem="{Binding SelectedOrderItem, Mode=TwoWay}"
                                          MaxHeight="450"
                                          AutoGenerateColumns="False" CanUserAddRows="False" 
                                          Background="Transparent" BorderThickness="0" 
                                          HeadersVisibility="Column" GridLinesVisibility="None"
                                          HorizontalGridLinesBrush="#F1F5F9" RowHeight="60"
                                          SelectionMode="Single" SelectionUnit="FullRow"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="#F1F5F9"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Style.Resources>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#E0EBFF"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#1E40AF"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F1F5F9"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#475569"/>
                                        </Style.Resources>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F8FAFC"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                        <Setter Property="Foreground" Value="#475569"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="20,15"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <!-- Mã SP -->
                                    <DataGridTemplateColumn Header="MÃ SẢN PHẨM" Width="150">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ProductCode}" VerticalAlignment="Center" Margin="20,0,0,0" Foreground="#64748B" FontWeight="SemiBold"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Tên sản phẩm -->
                                    <DataGridTemplateColumn Header="TÊN SẢN PHẨM" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ProductName}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#1E293B" FontWeight="Bold"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Số lượng (Refined Compact Style) -->
                                    <DataGridTemplateColumn Header="SỐ LƯỢNG" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Background="#F0F7FF" BorderBrush="#D1E9FF" BorderThickness="1" 
                                                        CornerRadius="6" Padding="12,6" 
                                                        HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding TargetQty}" Foreground="#0052CC" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Unit}" Foreground="#475569" FontSize="11" Margin="6,2,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Thao tác -->
                                    <DataGridTemplateColumn Header="THAO TÁC" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <!-- Nút Sửa -->
                                                    <Button Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                            CommandParameter="{Binding}" Visibility="Collapsed"/> <!-- Placeholder for alignment -->
                                                            
                                                    <Button Command="{Binding DataContext.SelectedOrderItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Width="32" Height="32" Background="Transparent" BorderThickness="0" Margin="0,0,8,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Command" Value="{Binding DataContext.SetSelectedItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                                            </Style>
                                                        </Button.Style>
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="btnBorder" Background="Transparent" CornerRadius="16">
                                                                    <TextBlock x:Name="btnIcon" Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" 
                                                                               Foreground="#94A3B8" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="btnBorder" Property="Background" Value="#E0EBFF"/>
                                                                        <Setter TargetName="btnIcon" Property="Foreground" Value="#3B82F6"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>

                                                    <!-- Nút Xóa -->
                                                    <Button Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                            CommandParameter="{Binding}"
                                                            Width="32" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="btnBorder" Background="Transparent" CornerRadius="16">
                                                                    <TextBlock x:Name="btnIcon" Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" 
                                                                               Foreground="#94A3B8" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="btnBorder" Property="Background" Value="#FEE2E2"/>
                                                                        <Setter TargetName="btnIcon" Property="Foreground" Value="#EF4444"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>

                    <!-- SIDEBAR: Guidelines & Help -->
                    <StackPanel Grid.Column="1">
                        <Border Style="{StaticResource ModernCardStyle}" Padding="24" Background="#F8FAFC">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <Border Width="24" Height="24" Background="#3B82F6" CornerRadius="12" Margin="0,0,10,0">
                                        <TextBlock Text="?" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                                    </Border>
                                    <TextBlock Text="HƯỚNG DẪN NGHIỆP VỤ" FontSize="13" FontWeight="Bold" Foreground="#1E40AF"/>
                                </StackPanel>

                                <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,12" BorderBrush="#E2E8F0" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Mã Lệnh Tự Động" FontWeight="Bold" FontSize="12" Foreground="#334155" Margin="0,0,0,5"/>
                                        <TextBlock Text="Được khuyến khích dùng để hệ thống tự quản lý thời gian, tránh sai sót." FontSize="11" Foreground="#64748B" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,12" BorderBrush="#E2E8F0" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Cơ Chế Đa Sản Phẩm" FontWeight="Bold" FontSize="12" Foreground="#334155" Margin="0,0,0,5"/>
                                        <TextBlock Text="Bạn có thể thêm nhiều sản phẩm vào cùng một lệnh bằng cách dùng form bên trái." FontSize="11" Foreground="#64748B" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="#FEF2F2" CornerRadius="12" Padding="15" BorderBrush="#FEE2E2" BorderThickness="1" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Hạn Hoàn Thành" FontWeight="Bold" FontSize="12" Foreground="#991B1B" Margin="0,0,0,5"/>
                                        <TextBlock Text="Hãy kiểm tra kỹ hạn hoàn thành trước khi kích hoạt để tránh trễ hạn." FontSize="11" Foreground="#B91C1C" TextWrapping="Wrap" Opacity="0.8"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="#FEF2F2" CornerRadius="12" Padding="15" BorderBrush="#FEE2E2" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Độ Ưu Tiên" FontWeight="Bold" FontSize="12" Foreground="#991B1B" Margin="0,0,0,5"/>
                                        <TextBlock Text="Lệnh khẩn cấp sẽ luôn được đẩy lên đầu bảng tổng sắp sản xuất." FontSize="11" Foreground="#B91C1C" TextWrapping="Wrap" Opacity="0.8"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        
                        <Border Margin="0,20,0,0" Style="{StaticResource ModernCardStyle}" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Mẹo nhanh:" FontWeight="Bold" FontSize="12" Foreground="#64748B" Margin="0,0,0,10"/>
                                <TextBlock Text="• Nhấn vào sản phẩm trong bảng hoặc nút cây bút để sửa thông tin." FontSize="11" Foreground="#94A3B8" Margin="0,0,0,5"/>
                                <TextBlock Text="• Nhấn biểu tượng thùng rác để xóa sản phẩm nhầm." FontSize="11" Foreground="#94A3B8"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>


                <TextBlock Text="© 2026 Manufacturing ERP System - Hỗ trợ vận hành tối ưu" HorizontalAlignment="Center" Margin="0,40,0,0" Foreground="#94A3B8" FontSize="11"/>
        </StackPanel>
    </ScrollViewer>
</Grid>
</UserControl>
