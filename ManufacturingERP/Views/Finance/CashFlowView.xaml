<UserControl x:Class="ManufacturingERP.Views.Finance.CashFlowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="1200" d:DesignWidth="1100">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel>
                <TextBlock Text="Theo dõi dòng tiền" FontSize="18" FontWeight="Bold" Foreground="#1e293b"/>
                <TextBlock Text="Quản lý các giao dịch thu chi thực tế" FontSize="13" Foreground="#64748b"/>
            </StackPanel>

            <Button Grid.Column="1" 
                    Content="+ Tạo phiếu thu/chi" 
                    Style="{StaticResource PrimaryButtonStyle}" 
                    Padding="20,10"
                    Command="{Binding CreateTransactionCommand}"/>
        </Grid>

        <!-- Cash Flow KPIs -->
        <Grid Grid.Row="1" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,16,0" BorderBrush="#D1FAE5" BorderThickness="1.5">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#F0FDF4" Width="48" Height="48" CornerRadius="24" Margin="0,0,16,0">
                        <Path Data="{StaticResource IconTrendingUp}" Fill="#16A34A" Width="22" Height="22" Stretch="Uniform"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Tổng thu tháng này" FontSize="13" Foreground="#64748b"/>
                        <TextBlock Text="{Binding TotalInflow}" FontSize="24" FontWeight="Bold" Foreground="#16A34A" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,16,0" BorderBrush="#FEE2E2" BorderThickness="1.5">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#FEF2F2" Width="48" Height="48" CornerRadius="24" Margin="0,0,16,0">
                        <Path Data="{StaticResource IconTrendingDown}" Fill="#DC2626" Width="22" Height="22" Stretch="Uniform"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Tổng chi tháng này" FontSize="13" Foreground="#64748b"/>
                        <TextBlock Text="{Binding TotalOutflow}" FontSize="24" FontWeight="Bold" Foreground="#DC2626" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" BorderBrush="#FDE68A" BorderThickness="1.5">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#FFFBEB" Width="48" Height="48" CornerRadius="24" Margin="0,0,16,0">
                        <Path Data="{StaticResource IconDollar}" Fill="#D97706" Width="22" Height="22" Stretch="Uniform"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Dòng tiền ròng" FontSize="13" Foreground="#64748b"/>
                        <TextBlock Text="{Binding NetCashFlow}" FontSize="24" FontWeight="Bold" Foreground="#D97706" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Cash Flow Chart -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,32" Height="330">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Biểu đồ dòng tiền" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="Khoảng thời gian:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#64748b" FontSize="12"/>
                        <ComboBox ItemsSource="{Binding ChartPeriods}" SelectedItem="{Binding SelectedChartPeriod}" Width="150" Height="32"/>
                    </StackPanel>
                </Grid>

                <lvc:CartesianChart Grid.Row="1" Series="{Binding CashFlowSeries}" LegendLocation="Bottom">
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Title="Tháng" Labels="{Binding CashFlowLabels}">
                            <lvc:Axis.Separator>
                                <lvc:Separator Step="1" IsEnabled="False"/>
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="Số tiền (triệu đồng)" LabelFormatter="{Binding YAxisFormatter}"/>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </Grid>
        </Border>

        <!-- Filter TX -->
        <Grid Grid.Row="3" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Border Background="#F1F5F9" CornerRadius="8" Width="350" Height="38" HorizontalAlignment="Left">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Tìm kiếm:" Foreground="#64748b" FontSize="12" Margin="12,0,8,0" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchTextTX, UpdateSourceTrigger=PropertyChanged}" 
                             Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" 
                             Tag="Mã giao dịch, danh mục, mô tả..."/>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <DatePicker SelectedDate="{Binding StartDate}" Width="140" Height="38" Margin="0,0,12,0" Style="{StaticResource ModernDatePickerStyle}"/>
                <DatePicker SelectedDate="{Binding EndDate}" Width="140" Height="38" Style="{StaticResource ModernDatePickerStyle}"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding Transactions}" IsReadOnly="True" Style="{StaticResource ModernDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã GD" Binding="{Binding TransactionCode}" Width="120"/>
                    <DataGridTextColumn Header="Ngày" Binding="{Binding Date, StringFormat=dd/MM/yyyy HH:mm}" Width="140"/>
                    
                    <DataGridTemplateColumn Header="Loại" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="8,2" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="Thu">
                                                     <Setter Property="Background" Value="#ECFDF5"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Chi">
                                                     <Setter Property="Background" Value="#FEF2F2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Type}" FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="Thu">
                                                        <Setter Property="Foreground" Value="#059669"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="Chi">
                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Danh mục" Binding="{Binding Category}" Width="150"/>
                    
                    <DataGridTemplateColumn Header="Số tiền" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock FontWeight="SemiBold" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Amount, StringFormat={}{0:N0} đ}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="Thu">
                                                    <Setter Property="Foreground" Value="#059669"/>
                                                    <Setter Property="Text" Value="{Binding Amount, StringFormat={}+{0:N0} đ}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Chi">
                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                    <Setter Property="Text" Value="{Binding Amount, StringFormat={}-{0:N0} đ}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Mô tả" Binding="{Binding Description}" Width="*"/>
                    <DataGridTextColumn Header="Chứng từ" Binding="{Binding Reference}" Width="120"/>
                    <DataGridTextColumn Header="Phương thức" Binding="{Binding Method}" Width="120"/>

                    <DataGridTemplateColumn Header="Thao tác" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource GhostButtonStyle}" ToolTip="Xem"
                                            Command="{Binding DataContext.ViewTransactionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <Path Data="{StaticResource IconEye}" Fill="#64748B" Width="14" Height="14" Stretch="Uniform"/>
                                    </Button>
                                    <Button Style="{StaticResource GhostButtonStyle}" ToolTip="Xóa"
                                            Command="{Binding DataContext.DeleteTransactionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Margin="4,0,0,0">
                                        <Path Data="{StaticResource IconDelete}" Fill="#EF4444" Width="14" Height="14" Stretch="Uniform"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Pagination TX -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <TextBlock VerticalAlignment="Center" Margin="0,0,16,0" Foreground="#64748b">
                <Run Text="Trang"/>
                <Run Text="{Binding CurrentPageTX}" FontWeight="SemiBold" Foreground="#1e293b"/>
                <Run Text="/"/>
                <Run Text="{Binding TotalPagesTX}"/>
            </TextBlock>
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding PreviousPageTXCommand}" IsEnabled="{Binding CanPrevTX}">
                    <Path Data="{StaticResource IconChevronLeft}" Fill="#64748b" Width="14" Height="14" Stretch="Uniform"/>
                </Button>
                <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding NextPageTXCommand}" IsEnabled="{Binding CanNextTX}">
                    <Path Data="{StaticResource IconChevronRight}" Fill="#64748b" Width="14" Height="14" Stretch="Uniform"/>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
