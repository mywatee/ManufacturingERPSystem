<UserControl x:Class="ManufacturingERP.Views.Finance.DebtManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="1200" d:DesignWidth="1100">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="Quản lý công nợ" FontSize="18" FontWeight="Bold" Foreground="#1e293b"/>
            <TextBlock Text="Theo dõi các khoản phải thu và phải trả" FontSize="13" Foreground="#64748b"/>
        </StackPanel>

        <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" 
                Content="+ Tạo hóa đơn" 
                Style="{StaticResource PrimaryButtonStyle}" 
                Padding="20,10"
                Command="{Binding CreateInvoiceCommand}"/>

        <!-- Debt KPIs -->
        <Grid Grid.Row="1" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,16,0" BorderBrush="#FECACA" BorderThickness="1.5">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Background="#FEF2F2" Width="32" Height="32" CornerRadius="16" Margin="0,0,10,0">
                            <Path Data="{StaticResource IconTrendingDown}" Fill="#DC2626" Width="14" Height="14" Stretch="Uniform"/>
                        </Border>
                        <TextBlock Text="Tổng phải trả" VerticalAlignment="Center" FontSize="12" Foreground="#64748b"/>
                    </StackPanel>
                    <TextBlock Text="{Binding TotalPayable}" FontSize="24" FontWeight="Bold" Foreground="#DC2626"/>
                    <TextBlock Text="{Binding APCountText}" FontSize="11" Foreground="#94a3b8"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,16,0" BorderBrush="#FDE68A" BorderThickness="1.5">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Background="#FFFBEB" Width="32" Height="32" CornerRadius="16" Margin="0,0,10,0">
                            <Path Data="{StaticResource IconExclamation}" Fill="#D97706" Width="14" Height="14" Stretch="Uniform"/>
                        </Border>
                        <TextBlock Text="Nợ quá hạn" VerticalAlignment="Center" FontSize="12" Foreground="#64748b"/>
                    </StackPanel>
                    <TextBlock Text="{Binding OverduePayable}" FontSize="24" FontWeight="Bold" Foreground="#D97706"/>
                    <TextBlock Text="Cần thanh toán gấp" FontSize="11" Foreground="#94a3b8"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0,0,16,0" BorderBrush="#A7F3D0" BorderThickness="1.5">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Background="#F0FDF4" Width="32" Height="32" CornerRadius="16" Margin="0,0,10,0">
                            <Path Data="{StaticResource IconTrendingUp}" Fill="#059669" Width="14" Height="14" Stretch="Uniform"/>
                        </Border>
                        <TextBlock Text="Tổng phải thu" VerticalAlignment="Center" FontSize="12" Foreground="#64748b"/>
                    </StackPanel>
                    <TextBlock Text="{Binding TotalReceivable}" FontSize="24" FontWeight="Bold" Foreground="#059669"/>
                    <TextBlock Text="{Binding ARCountText}" FontSize="11" Foreground="#94a3b8"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource CardStyle}" BorderBrush="#FED7AA" BorderThickness="1.5">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Background="#FFF7ED" Width="32" Height="32" CornerRadius="16" Margin="0,0,10,0">
                            <Path Data="{StaticResource IconInfo}" Fill="#EA580C" Width="14" Height="14" Stretch="Uniform"/>
                        </Border>
                        <TextBlock Text="Thu quá hạn" VerticalAlignment="Center" FontSize="12" Foreground="#64748b"/>
                    </StackPanel>
                    <TextBlock Text="{Binding OverdueReceivable}" FontSize="24" FontWeight="Bold" Foreground="#EA580C"/>
                    <TextBlock Text="Cần đôn đốc" FontSize="11" Foreground="#94a3b8"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Accounts Payable Table -->
        <StackPanel Grid.Row="2" Margin="0,0,0,32">
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="{StaticResource IconTrendingDown}" Fill="#DC2626" Width="18" Height="18" Margin="0,0,8,0" Stretch="Uniform"/>
                    <TextBlock Text="Khoản phải trả (Accounts Payable)" FontSize="16" FontWeight="SemiBold" Foreground="#1e293b"/>
                </StackPanel>

                <!-- Filter AP -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Border Background="#F1F5F9" CornerRadius="8" Width="150" Height="36" Margin="0,0,12,0">
                        <ComboBox ItemsSource="{Binding InvoiceStatuses}" SelectedItem="{Binding SelectedStatusAP}" 
                                  Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"/>
                    </Border>
                    <Border Background="#F1F5F9" CornerRadius="8" Width="250" Height="36" Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Tìm kiếm:" Foreground="#64748b" FontSize="12" Margin="12,0,8,0" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding SearchTextAP, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" 
                                     Tag="Nhập mã hóa đơn, tên đối tác..."/>
                        </Grid>
                    </Border>
                    <DatePicker SelectedDate="{Binding StartDate}" Width="130" Height="36" Margin="0,0,8,0" Style="{StaticResource ModernDatePickerStyle}"/>
                    <DatePicker SelectedDate="{Binding EndDate}" Width="130" Height="36" Style="{StaticResource ModernDatePickerStyle}"/>
                </StackPanel>
            </Grid>
            <Border Style="{StaticResource CardStyle}" Padding="0">
                <DataGrid ItemsSource="{Binding AccountsPayable}" IsReadOnly="True" Style="{StaticResource ModernDataGridStyle}" VerticalScrollBarVisibility="Disabled">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Số hóa đơn" Binding="{Binding InvoiceCode}" Width="150"/>
                        <DataGridTemplateColumn Header="Nhà cung cấp" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconShield}" Fill="#94a3b8" Width="14" Height="14" Margin="0,0,8,0" Stretch="Uniform"/>
                                        <TextBlock Text="{Binding Partner.PartnerName}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Mô tả" Binding="{Binding Note}" Width="2*"/>
                        <DataGridTextColumn Header="Số tiền" Binding="{Binding TotalAmount, StringFormat={}{0:N0} đ}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#DC2626"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Ngày phát hành" Binding="{Binding IssueDate, StringFormat=yyyy-MM-dd}" Width="110"/>

                        <DataGridTemplateColumn Header="Hạn thanh toán" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Path x:Name="alertIcon" Data="{StaticResource IconClock}" Fill="#64748b" Width="12" Height="12" Margin="0,0,6,0" Stretch="Uniform" Visibility="Collapsed"/>
                                        <TextBlock x:Name="dateText" Text="{Binding DueDate, StringFormat=yyyy-MM-dd}"/>
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="Quá hạn">
                                            <Setter TargetName="alertIcon" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="alertIcon" Property="Fill" Value="#DC2626"/>
                                            <Setter TargetName="dateText" Property="Foreground" Value="#DC2626"/>
                                            <Setter TargetName="dateText" Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Chứng từ" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconFileLink}" Fill="#3B82F6" Width="12" Height="12" Margin="0,0,6,0" Stretch="Uniform"/>
                                        <TextBlock Text="{Binding Reference}" Foreground="#3B82F6" Cursor="Hand"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Trạng thái" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="badge">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                <Style.Triggers>
                                                     <DataTrigger Binding="{Binding Status}" Value="Quá hạn">
                                                        <Setter Property="Background" Value="#FEF2F2"/>
                                                        <Setter Property="BorderBrush" Value="#FECACA"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Chưa thanh toán">
                                                        <Setter Property="Background" Value="#FFF7ED"/>
                                                        <Setter Property="BorderBrush" Value="#FFEDD5"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Đã thanh toán">
                                                        <Setter Property="Background" Value="#F0FDF4"/>
                                                        <Setter Property="BorderBrush" Value="#DCFCE7"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock x:Name="txt" Text="{Binding Status}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Quá hạn">
                                                            <Setter Property="Foreground" Value="#DC2626"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Thao tác" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{StaticResource GhostButtonStyle}" ToolTip="Xem chi tiết" Foreground="#64748B"
                                                Command="{Binding DataContext.ViewInvoiceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" Margin="0,0,4,0">
                                            <Path Data="{StaticResource IconEye}" Fill="#64748B" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                        <Button Style="{StaticResource GhostButtonStyle}" ToolTip="Thanh toán" Foreground="#3B82F6"
                                                Command="{Binding DataContext.PayInvoiceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding RemainingAmount, Converter={StaticResource GreaterThanZeroToVisibilityConverter}}">
                                            <Path Data="{StaticResource IconDollar}" Fill="#3B82F6" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                        <Button Style="{StaticResource GhostButtonStyle}" ToolTip="Sửa" Foreground="#F59E0B"
                                                Command="{Binding DataContext.EditInvoiceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" Margin="4,0">
                                            <Path Data="{StaticResource IconEdit}" Fill="#F59E0B" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                        <Button Style="{StaticResource GhostButtonStyle}" ToolTip="Xóa" Foreground="#EF4444"
                                                Command="{Binding DataContext.DeleteInvoiceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding Status, Converter={StaticResource StringToBooleanConverter}, ConverterParameter='Chưa thanh toán|Quá hạn'}">
                                            <Path Data="{StaticResource IconDelete}" Fill="#EF4444" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Pagination AP -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding PreviousPageAPCommand}" IsEnabled="{Binding CanPrevAP}">
                    <Path Data="{StaticResource IconChevronLeft}" Fill="#64748b" Width="14" Height="14" Stretch="Uniform"/>
                </Button>
                <Border Background="#F1F5F9" CornerRadius="4" Padding="12,4" Margin="8,0">
                    <TextBlock VerticalAlignment="Center" FontSize="13">
                        <Run Text="Trang " Foreground="#64748b"/>
                        <Run Text="{Binding CurrentPageAP}" FontWeight="SemiBold" Foreground="#1e293b"/>
                        <Run Text=" / " Foreground="#64748b"/>
                        <Run Text="{Binding TotalPagesAP}" Foreground="#64748b"/>
                    </TextBlock>
                </Border>
                <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding NextPageAPCommand}" IsEnabled="{Binding CanNextAP}">
                    <Path Data="{StaticResource IconChevronRight}" Fill="#64748b" Width="14" Height="14" Stretch="Uniform"/>
                </Button>
            </StackPanel>
        </StackPanel>

        <!-- Accounts Receivable Table -->
        <StackPanel Grid.Row="3">
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="{StaticResource IconTrendingUp}" Fill="#059669" Width="18" Height="18" Margin="0,0,8,0" Stretch="Uniform"/>
                    <TextBlock Text="Khoản phải thu (Accounts Receivable)" FontSize="16" FontWeight="SemiBold" Foreground="#1e293b"/>
                </StackPanel>

                <!-- Filter AR -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Border Background="#F1F5F9" CornerRadius="8" Width="150" Height="36" Margin="0,0,12,0">
                        <ComboBox ItemsSource="{Binding InvoiceStatuses}" SelectedItem="{Binding SelectedStatusAR}" 
                                  Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"/>
                    </Border>
                    <Border Background="#F1F5F9" CornerRadius="8" Width="250" Height="36" Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Tìm kiếm:" Foreground="#64748b" FontSize="12" Margin="12,0,8,0" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding SearchTextAR, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" 
                                     Tag="Nhập mã hóa đơn, tên đối tác..."/>
                        </Grid>
                    </Border>
                    <DatePicker SelectedDate="{Binding StartDate}" Width="130" Height="36" Margin="0,0,8,0" Style="{StaticResource ModernDatePickerStyle}"/>
                    <DatePicker SelectedDate="{Binding EndDate}" Width="130" Height="36" Style="{StaticResource ModernDatePickerStyle}"/>
                </StackPanel>
            </Grid>
            <Border Style="{StaticResource CardStyle}" Padding="0">
                <DataGrid ItemsSource="{Binding AccountsReceivable}" IsReadOnly="True" Style="{StaticResource ModernDataGridStyle}" VerticalScrollBarVisibility="Disabled">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Số hóa đơn" Binding="{Binding InvoiceCode}" Width="150"/>
                        <DataGridTemplateColumn Header="Khách hàng" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconUser}" Fill="#94a3b8" Width="14" Height="14" Margin="0,0,8,0" Stretch="Uniform"/>
                                        <TextBlock Text="{Binding Partner.PartnerName}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Mô tả" Binding="{Binding Note}" Width="2*"/>
                        <DataGridTextColumn Header="Số tiền" Binding="{Binding TotalAmount, StringFormat={}{0:N0} đ}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#059669"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Ngày phát hành" Binding="{Binding IssueDate, StringFormat=yyyy-MM-dd}" Width="110"/>
                        <DataGridTextColumn Header="Hạn thanh toán" Binding="{Binding DueDate, StringFormat=yyyy-MM-dd}" Width="110"/>
                        <DataGridTemplateColumn Header="Chứng từ" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconFileLink}" Fill="#3B82F6" Width="12" Height="12" Margin="0,0,6,0" Stretch="Uniform"/>
                                        <TextBlock Text="{Binding Reference}" Foreground="#3B82F6" Cursor="Hand"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Trạng thái" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="badge">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Đã thanh toán">
                                                        <Setter Property="Background" Value="#F0FDF4"/>
                                                        <Setter Property="BorderBrush" Value="#DCFCE7"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Chưa thanh toán">
                                                        <Setter Property="Background" Value="#FFF7ED"/>
                                                        <Setter Property="BorderBrush" Value="#FFEDD5"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Quá hạn">
                                                        <Setter Property="Background" Value="#FEF2F2"/>
                                                        <Setter Property="BorderBrush" Value="#FECACA"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock x:Name="txt" Text="{Binding Status}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Quá hạn">
                                                            <Setter Property="Foreground" Value="#DC2626"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Thao tác" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{StaticResource GhostButtonStyle}" ToolTip="Xem chi tiết" Foreground="#64748B"
                                                Command="{Binding DataContext.ViewInvoiceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" Margin="0,0,4,0">
                                            <Path Data="{StaticResource IconEye}" Fill="#64748B" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                        <Button Style="{StaticResource GhostButtonStyle}" ToolTip="Thu tiền" Foreground="#059669"
                                                Command="{Binding DataContext.PayInvoiceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding RemainingAmount, Converter={StaticResource GreaterThanZeroToVisibilityConverter}}">
                                            <Path Data="{StaticResource IconTrendingUp}" Fill="#059669" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                        <Button Style="{StaticResource GhostButtonStyle}" ToolTip="Sửa" Foreground="#F59E0B"
                                                Command="{Binding DataContext.EditInvoiceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" Margin="4,0">
                                            <Path Data="{StaticResource IconEdit}" Fill="#F59E0B" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                        <Button Style="{StaticResource GhostButtonStyle}" ToolTip="Xóa" Foreground="#EF4444"
                                                Command="{Binding DataContext.DeleteInvoiceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding Status, Converter={StaticResource StringToBooleanConverter}, ConverterParameter='Chưa thanh toán|Quá hạn'}">
                                            <Path Data="{StaticResource IconDelete}" Fill="#EF4444" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Pagination AR -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding PreviousPageARCommand}" IsEnabled="{Binding CanPrevAR}">
                    <Path Data="{StaticResource IconChevronLeft}" Fill="#64748b" Width="14" Height="14" Stretch="Uniform"/>
                </Button>
                <Border Background="#F1F5F9" CornerRadius="4" Padding="12,4" Margin="8,0">
                    <TextBlock VerticalAlignment="Center" FontSize="13">
                        <Run Text="Trang " Foreground="#64748b"/>
                        <Run Text="{Binding CurrentPageAR}" FontWeight="SemiBold" Foreground="#1e293b"/>
                        <Run Text=" / " Foreground="#64748b"/>
                        <Run Text="{Binding TotalPagesAR}" Foreground="#64748b"/>
                    </TextBlock>
                </Border>
                <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding NextPageARCommand}" IsEnabled="{Binding CanNextAR}">
                    <Path Data="{StaticResource IconChevronRight}" Fill="#64748b" Width="14" Height="14" Stretch="Uniform"/>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
