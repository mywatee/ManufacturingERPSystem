<UserControl x:Class="ManufacturingERP.Views.AttendanceManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ManufacturingERP.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">
    <StackPanel>
        <Grid Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="Quản lý chấm công" FontSize="18" FontWeight="Bold" Foreground="#1e293b"/>
                <TextBlock Text="Theo dõi giờ làm việc và năng suất nhân sự" FontSize="13" Foreground="#64748b"/>
            </StackPanel>
            <Button HorizontalAlignment="Right" VerticalAlignment="Center" 
                    Content="Mở bảng điểm danh tập trung" Style="{StaticResource PrimaryButtonStyle}" 
                    Background="#10B981" Padding="16,8"
                    Command="{Binding OpenAttendanceConsoleCommand}"/>
        </Grid>


        <!-- Attendance KPIs -->
        <Grid Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,16,0">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#F0FDF4" Width="48" Height="48" CornerRadius="24" Margin="0,0,16,0">
                        <Path Data="{StaticResource IconCheckCircle}" Fill="#16A34A" Width="22" Height="22" Stretch="Uniform"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Tổng ngày công" FontSize="12" Foreground="#64748b"/>
                        <TextBlock Text="{Binding PresentCount}" FontSize="20" FontWeight="Bold" Foreground="#1e293b"/>
                        <TextBlock Text="Trong khoảng chọn" FontSize="11" Foreground="#94a3b8"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,16,0">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#FEF2F2" Width="48" Height="48" CornerRadius="24" Margin="0,0,16,0">
                        <Path Data="{StaticResource IconXCircle}" Fill="#EF4444" Width="22" Height="22" Stretch="Uniform"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Tổng ngày vắng" FontSize="12" Foreground="#64748b"/>
                        <TextBlock Text="{Binding AbsentCount}" FontSize="20" FontWeight="Bold" Foreground="#EF4444"/>
                        <TextBlock Text="Nghỉ/Vắng mặt" FontSize="11" Foreground="#94a3b8"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0,0,16,0">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#FFFBEB" Width="48" Height="48" CornerRadius="24" Margin="0,0,16,0">
                        <Path Data="{StaticResource IconClock}" Fill="#F59E0B" Width="22" Height="22" Stretch="Uniform"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Số lần đi muộn" FontSize="12" Foreground="#64748b"/>
                        <TextBlock Text="{Binding LateCount}" FontSize="20" FontWeight="Bold" Foreground="#F59E0B"/>
                        <TextBlock Text="Tổng cộng" FontSize="11" Foreground="#94a3b8"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource CardStyle}">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#EFF6FF" Width="48" Height="48" CornerRadius="24" Margin="0,0,16,0">
                        <Path Data="{StaticResource IconClock}" Fill="#2563EB" Width="22" Height="22" Stretch="Uniform"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Tổng tăng ca" FontSize="12" Foreground="#64748b"/>
                        <TextBlock Text="{Binding TotalOvertimeHours, StringFormat={}{0} giờ}" FontSize="20" FontWeight="Bold" Foreground="#2563EB"/>
                        <TextBlock Text="Giờ làm thêm" FontSize="11" Foreground="#94a3b8"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Detailed Attendance Sheet (Matrix View) -->
        <Border Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,32">
            <StackPanel>
                <Border Background="#F8FAFC" BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Padding="20,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconGrid}" Fill="#2563EB" Width="18" Height="18" Margin="0,0,12,0" Stretch="Uniform"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Bảng chấm công chi tiết" FontWeight="Bold" FontSize="16" Foreground="#1e293b"/>
                                <TextBlock Text="Ma trận điểm danh theo khoảng thời gian" FontSize="12" Foreground="#64748b"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <!-- Search -->
                            <Border Background="White" CornerRadius="8" BorderThickness="1" BorderBrush="#CBD5E1" Width="200" Height="32" Margin="0,0,12,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Data="{StaticResource IconSearch}" Fill="#94a3b8" Width="12" Height="12" Margin="8,0,0,0" Stretch="Uniform"/>
                                    <TextBox Grid.Column="1" Style="{StaticResource LoginTextBoxStyle}" 
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                             BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Margin="6,0"
                                             FontSize="12" Tag="Tìm tên/mã..."/>
                                </Grid>
                            </Border>

                            <!-- Dept -->
                            <ComboBox ItemsSource="{Binding DepartmentFilters}" 
                                      SelectedItem="{Binding SelectedDepartmentFilter}"
                                      Style="{StaticResource ModernComboBoxStyle}" 
                                      Width="140" Height="32" Margin="0,0,12,0"/>

                            <!-- Time Modes -->
                            <Border Background="#F1F5F9" CornerRadius="6" Padding="2" Height="32" Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Content="Tuần" IsChecked="{Binding ViewMode, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=Tuần}"
                                                 Command="{Binding SetViewModeCommand}" CommandParameter="Tuần" Style="{StaticResource ToggleTabStyle}" FontSize="11" Padding="8,0"/>
                                    <RadioButton Content="Tháng" IsChecked="{Binding ViewMode, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=Tháng}"
                                                 Command="{Binding SetViewModeCommand}" CommandParameter="Tháng" Style="{StaticResource ToggleTabStyle}" FontSize="11" Padding="8,0"/>
                                    <RadioButton Content="Tùy chọn" IsChecked="{Binding ViewMode, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=Tùy chọn}"
                                                 Command="{Binding SetViewModeCommand}" CommandParameter="Tùy chọn" Style="{StaticResource ToggleTabStyle}" FontSize="11" Padding="8,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Custom Range -->
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ViewMode}" Value="Tùy chọn">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <DatePicker SelectedDate="{Binding StartDate}" Width="100" Height="32" FontSize="11" VerticalContentAlignment="Center"/>
                                <TextBlock Text="→" VerticalAlignment="Center" Margin="4,0" Foreground="#94a3b8"/>
                                <DatePicker SelectedDate="{Binding EndDate}" Width="100" Height="32" FontSize="11" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                                <Button Command="{Binding GenerateAttendanceSheetCommand}" Style="{StaticResource PrimaryButtonStyle}" Height="32" Padding="12,0">
                                    <Path Data="{StaticResource IconFilter}" Fill="White" Width="12" Height="12" Stretch="Uniform"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- The Matrix Grid -->
                <Border Background="White" BorderThickness="0,1" BorderBrush="#E2E8F0">
                    <DataGrid ItemsSource="{Binding AttendanceSheetData, Mode=OneWay}" 
                              AutoGenerateColumns="True"
                              AutoGeneratingColumn="AttendanceGrid_AutoGeneratingColumn"
                              Style="{StaticResource ModernDataGridStyle}"
                              Height="450"
                              MaxHeight="600"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              HorizontalGridLinesBrush="#F1F5F9"
                              VerticalGridLinesBrush="#F1F5F9">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Foreground" Value="#64748b"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="8"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="4"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#EFF6FF"/>
                                        <Setter Property="Foreground" Value="#2563EB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                    </DataGrid>
                </Border>

                <!-- Pagination Footer -->
                <Border Padding="20,12" Background="#F8FAFC" CornerRadius="0,0,12,12">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Foreground="#64748b" VerticalAlignment="Center">
                                <Run Text="Tổng số: "/>
                                <Run Text="{Binding TotalEmployeesCount}" FontWeight="Bold"/>
                                <Run Text=" nhân viên"/>
                            </TextBlock>
                            <Border Width="1" Background="#E2E8F0" Margin="16,4" Height="16"/>
                            <TextBlock Text="Hiển thị 50 bản ghi/trang" FontSize="12" Foreground="#94a3b8" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock VerticalAlignment="Center" Margin="0,0,16,0" Foreground="#64748b">
                                <Run Text="Trang "/>
                                <Run Text="{Binding CurrentPage}" FontWeight="Bold"/>
                                <Run Text=" / "/>
                                <Run Text="{Binding TotalPagesCount}"/>
                            </TextBlock>
                            
                            <Button Command="{Binding PrevPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="12,6" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z" Fill="#64748b" Width="14" Height="14" Margin="0,0,4,0" Stretch="Uniform"/>
                                    <TextBlock Text="Trước" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NextPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="12,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Sau" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <Path Data="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z" Fill="#64748b" Width="14" Height="14" Stretch="Uniform"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- Attendance Summary Table (Separate) -->
        <Border Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,32">
            <StackPanel>
                <Grid Margin="20,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconAnalytics}" Fill="#059669" Width="18" Height="18" Margin="0,0,12,0" Stretch="Uniform"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Bảng thông số chấm công" FontWeight="Bold" FontSize="16" Foreground="#1e293b"/>
                            <TextBlock Text="Tổng hợp các chỉ số quan trọng của nhân viên" FontSize="12" Foreground="#64748b"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Local Filter Bar for Summary Table -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Search -->
                        <Border Background="White" CornerRadius="8" BorderThickness="1" BorderBrush="#CBD5E1" Width="180" Height="32" Margin="0,0,12,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="{StaticResource IconSearch}" Fill="#94a3b8" Width="12" Height="12" Margin="8,0,0,0" Stretch="Uniform"/>
                                <TextBox Grid.Column="1" Style="{StaticResource LoginTextBoxStyle}" 
                                         Text="{Binding SummarySearchText, UpdateSourceTrigger=PropertyChanged}" 
                                         BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Margin="6,0"
                                         FontSize="12" Tag="Tìm tên/mã..."/>
                            </Grid>
                        </Border>

                        <!-- Dept -->
                        <ComboBox ItemsSource="{Binding DepartmentFilters}" 
                                  SelectedItem="{Binding SummarySelectedDepartmentFilter}"
                                  Style="{StaticResource ModernComboBoxStyle}" 
                                  Width="140" Height="32" Margin="0,0,12,0"/>

                        <!-- Summary Time Modes -->
                        <Border Background="#F1F5F9" CornerRadius="6" Padding="2" Height="32" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="Tuần" IsChecked="{Binding SummaryViewMode, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=Tuần}"
                                             Command="{Binding SetSummaryViewModeCommand}" CommandParameter="Tuần" Style="{StaticResource ToggleTabStyle}" FontSize="11" Padding="8,0"/>
                                <RadioButton Content="Tháng" IsChecked="{Binding SummaryViewMode, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=Tháng}"
                                             Command="{Binding SetSummaryViewModeCommand}" CommandParameter="Tháng" Style="{StaticResource ToggleTabStyle}" FontSize="11" Padding="8,0"/>
                                <RadioButton Content="Tùy chọn" IsChecked="{Binding SummaryViewMode, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=Tùy chọn}"
                                             Command="{Binding SetSummaryViewModeCommand}" CommandParameter="Tùy chọn" Style="{StaticResource ToggleTabStyle}" FontSize="11" Padding="8,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Month Navigator (Visible only when SummaryViewMode is Month) -->
                        <Border Background="#F1F5F9" CornerRadius="8" Padding="2" Height="32" Margin="0,0,8,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SummaryViewMode}" Value="Tháng">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding PrevMonthCommand}" Style="{StaticResource IconButtonStyle}" Width="28" Height="28">
                                    <Path Data="{StaticResource IconChevronLeft}" Fill="#64748b" Width="12" Height="12" Stretch="Uniform"/>
                                </Button>
                                <TextBlock Text="{Binding SummaryMonthText}" FontWeight="SemiBold" Foreground="#1e293b" VerticalAlignment="Center" Margin="12,0" MinWidth="100" TextAlignment="Center" FontSize="12"/>
                                <Button Command="{Binding NextMonthCommand}" Style="{StaticResource IconButtonStyle}" Width="28" Height="28">
                                    <Path Data="{StaticResource IconChevronRight}" Fill="#64748b" Width="12" Height="12" Stretch="Uniform"/>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Custom Range for Summary -->
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SummaryViewMode}" Value="Tùy chọn">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <DatePicker SelectedDate="{Binding SummaryStartDate}" Width="100" Height="32" FontSize="11" VerticalContentAlignment="Center"/>
                            <TextBlock Text="→" VerticalAlignment="Center" Margin="4,0" Foreground="#94a3b8"/>
                            <DatePicker SelectedDate="{Binding SummaryEndDate}" Width="100" Height="32" FontSize="11" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                            <Button Command="{Binding LoadSummaryDataCommand}" Style="{StaticResource PrimaryButtonStyle}" Height="32" Padding="12,0">
                                <Path Data="{StaticResource IconFilter}" Fill="White" Width="12" Height="12" Stretch="Uniform"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <DataGrid ItemsSource="{Binding AttendanceSummaries}" 
                          Style="{StaticResource ModernDataGridStyle}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã NV" Binding="{Binding EmployeeCode}" Width="100"/>
                        <DataGridTextColumn Header="Họ và Tên" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Phòng ban" Binding="{Binding Department}" Width="*"/>
                        
                        <DataGridTemplateColumn Header="Ngày Công" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding WorkDays, StringFormat={}{0} ngày}" FontWeight="Bold" Foreground="#16A34A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Đi Muộn" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding LateTimes, StringFormat={}{0} lần}" FontWeight="Bold" Foreground="#EA580C" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Vắng Mặt" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AbsentDays, StringFormat={}{0} ngày}" FontWeight="Bold" Foreground="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Tăng Ca" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding OvertimeHours, StringFormat={}{0:N1} giờ}" FontWeight="Bold" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Pagination Footer for Summary -->
                <Border Padding="20,12" Background="#F8FAFC" CornerRadius="0,0,12,12" BorderThickness="0,1,0,0" BorderBrush="#E2E8F0">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Foreground="#64748b" VerticalAlignment="Center">
                                <Run Text="Tổng cộng: "/>
                                <Run Text="{Binding SummaryTotalCount}" FontWeight="Bold"/>
                                <Run Text=" nhân viên"/>
                            </TextBlock>
                            <Border Width="1" Background="#E2E8F0" Margin="16,4" Height="16"/>
                            <TextBlock Text="20 nhân viên/trang" FontSize="12" Foreground="#94a3b8" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock VerticalAlignment="Center" Margin="0,0,16,0" Foreground="#64748b">
                                <Run Text="Trang "/>
                                <Run Text="{Binding SummaryCurrentPage}" FontWeight="Bold"/>
                                <Run Text=" / "/>
                                <Run Text="{Binding SummaryTotalPages}"/>
                            </TextBlock>

                            <Button Command="{Binding PrevSummaryPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="12,6" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z" Fill="#64748b" Width="14" Height="14" Margin="0,0,4,0" Stretch="Uniform"/>
                                    <TextBlock Text="Trước" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NextSummaryPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="12,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Sau" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <Path Data="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z" Fill="#64748b" Width="14" Height="14" Stretch="Uniform"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
