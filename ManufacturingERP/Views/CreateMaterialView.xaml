<UserControl x:Class="ManufacturingERP.Views.CreateMaterialView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ManufacturingERP.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{StaticResource MainBackgroundBrush}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Loading Progress Bar -->
        <ProgressBar Grid.Row="0" IsIndeterminate="True" Height="3" VerticalAlignment="Top" 
                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Foreground="#2563EB" Background="Transparent" BorderThickness="0"/>

        <!-- Header Area (Fixed at top) -->
        <Grid Grid.Row="0" Margin="30,30,30,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Command="{Binding CancelCommand}" Style="{StaticResource ActionButtonStyle}" Margin="0,0,15,0" Width="40" Height="40">
                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource SecondaryTextBrush}"/>
                </Button>
                <StackPanel>
                    <TextBlock Text="{Binding PageTitle}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                    <TextBlock Text="Thiết lập thông tin kỹ thuật và quản lý cho vật tư trong hệ thống" 
                               FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Hủy bỏ" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButtonStyle}" Width="120" Height="42" Margin="0,0,12,0"/>
                <Button Content="Kích hoạt vật tư ngay" Command="{Binding SaveCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" Style="{StaticResource PrimaryButtonStyle}" Width="200" Height="42"/>
            </StackPanel>
        </Grid>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="30,15,30,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Input Column -->
                <StackPanel Grid.Column="0" Margin="0,0,24,0">
                    <!-- Basic Information Card -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Background="#EFF6FF" Width="32" Height="32" CornerRadius="6" Margin="0,0,12,0">
                                    <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="THÔNG TIN CƠ BẢN" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Foreground="#475569"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,15,20">
                                    <TextBlock Text="Mã vật tư *" FontSize="13" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding MaterialCode, UpdateSourceTrigger=PropertyChanged}" 
                                             IsEnabled="{Binding IsEditMode, Converter={StaticResource InverseBooleanConverter}}"
                                             Style="{StaticResource LoginTextBoxStyle}" Height="42"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,20">
                                    <TextBlock Text="Tên vật tư *" FontSize="13" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding MaterialName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource LoginTextBoxStyle}" Height="42"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,15,0">
                                    <TextBlock Text="Đơn vị tính" FontSize="13" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding Unit, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource LoginTextBoxStyle}" Height="42"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1">
                                    <TextBlock Text="Phân loại hệ thống" FontSize="13" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                                    <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding Category}" Style="{StaticResource ModernComboBoxStyle}" Height="42"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Inventory & Status Card -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Background="#F0FDF4" Width="32" Height="32" CornerRadius="6" Margin="0,0,12,0">
                                    <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#16A34A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="QUẢN LÝ KHO &amp; TRẠNG THÁI" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Foreground="#475569"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                    <TextBlock Text="Trạng thái vận hành" FontSize="13" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                                    <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding Status}" Style="{StaticResource ModernComboBoxStyle}" Height="42"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,15,0">
                                    <TextBlock Text="Tồn thực tế ban đầu" FontSize="13" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding InitialStock, UpdateSourceTrigger=PropertyChanged}" 
                                             IsEnabled="{Binding IsEditMode, Converter={StaticResource InverseBooleanConverter}}"
                                             Style="{StaticResource LoginTextBoxStyle}" Height="42" TextAlignment="Right"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="0,0,15,0">
                                    <TextBlock Text="Mức tồn tối thiểu" FontSize="13" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding MinStock, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource LoginTextBoxStyle}" Height="42" TextAlignment="Right"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="Đơn giá (đ)" FontSize="13" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource LoginTextBoxStyle}" Height="42" TextAlignment="Right" FontWeight="Bold" Foreground="#10B981"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Tabs for Extensions (BOM/Routing) -->
                    <Border Style="{StaticResource CardStyle}" MinHeight="400" 
                            Visibility="{Binding IsTechnicalDataVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <RadioButton Content="Cấu trúc sản phẩm (BOM)" IsChecked="True" Style="{StaticResource AdminTabButtonStyle}" Tag="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/>
                                <RadioButton Content="Quy trình công nghệ" Style="{StaticResource AdminTabButtonStyle}" Tag="M19 3h-4.18C14.4 1.84 13.3 1 12 1s-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1z"/>
                            </StackPanel>
                            <Grid Grid.Row="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- BOM Actions -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">
                                        <Button Command="{Binding AddBomItemCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="12,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE109;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Thêm linh kiện / nguyên liệu" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <!-- BOM List -->
                                    <DataGrid Grid.Row="1" ItemsSource="{Binding BomItems}" Style="{StaticResource ModernDataGridStyle}" 
                                              MaxHeight="400" IsReadOnly="True">
                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Style.Resources>
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                                                </Style.Resources>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#EFF6FF"/>
                                                        <Setter Property="BorderBrush" Value="#2563EB"/>
                                                        <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.CellStyle>
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="Linh kiện" Width="2*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="10,0">
                                                            <Border Background="#F1F5F9" Width="32" Height="32" CornerRadius="4" Margin="0,0,12,0">
                                                                <TextBlock Text="&#xE94B;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding MaterialName}" FontWeight="SemiBold" Foreground="#1E293B"/>
                                                                <TextBlock Text="{Binding MaterialCode}" FontSize="11" Foreground="#94A3B8"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            
                                            <DataGridTextColumn Header="Số lượng định mức" Binding="{Binding Quantity}" Width="*"/>
                                            <DataGridTextColumn Header="Đơn vị" Binding="{Binding Unit}" Width="0.8*"/>
                                            
                                            <DataGridTemplateColumn Header="Thao tác" Width="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <Button Style="{StaticResource ActionButtonStyle}" ToolTip="Xóa">
                                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="#EF4444"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Sidebar Column -->
                <StackPanel Grid.Column="1">
                    <!-- Guidance Card -->
                    <Border Style="{StaticResource CardStyle}" Background="#2563EB" BorderThickness="0" Margin="0,0,0,20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="HƯỚNG DẪN NGHIỆP VỤ" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Mã Vật Tư Tự Động" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Hệ thống tự đề xuất mã dựa trên thời gian khởi tạo để đảm bảo tính duy nhất." 
                                           FontSize="12" Foreground="#BFDBFE" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Phân Loại Vật Tư" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Chọn đúng phân loại để hệ thống áp dụng các quy tắc hạch toán và lưu kho chính xác." 
                                           FontSize="12" Foreground="#BFDBFE" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Hạn Mức Tồn Kho" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Cài đặt mức tồn tối thiểu để nhận cảnh báo mua hàng khi số lượng trong kho giảm xuống." 
                                           FontSize="12" Foreground="#BFDBFE" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Quick Tips Card -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Mẹo nhanh:" FontSize="14" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,12"/>
                            <BulletDecorator Margin="0,0,0,8">
                                <BulletDecorator.Bullet>
                                    <Ellipse Width="4" Height="4" Fill="#94A3B8" Margin="0,6,8,0"/>
                                </BulletDecorator.Bullet>
                                <TextBlock Text="Nhấn vào biểu tượng quay lại để hủy thao tác" FontSize="12" Foreground="#64748B"/>
                            </BulletDecorator>
                            <BulletDecorator>
                                <BulletDecorator.Bullet>
                                    <Ellipse Width="4" Height="4" Fill="#94A3B8" Margin="0,6,8,0"/>
                                </BulletDecorator.Bullet>
                                <TextBlock Text="BOM và Quy trình sẽ được kích hoạt sau khi lưu" FontSize="12" Foreground="#64748B"/>
                            </BulletDecorator>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
