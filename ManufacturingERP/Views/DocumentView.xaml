<UserControl x:Class="ManufacturingERP.Views.DocumentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:core="clr-namespace:ManufacturingERP.Core"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <core:StringHasValueToVisibilityConverter x:Key="StringHasValueToVisibilityConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Quản lý tài liệu" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                    <TextBlock Text="Upload và quản lý tài liệu dùng cho AI Chat (SOP, báo cáo, hợp đồng...)" 
                               FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,5,0,0"/>
                </StackPanel>
                <Button Grid.Column="2" Command="{Binding UploadDocumentCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" Padding="20,10" VerticalAlignment="Top"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📄" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Upload tài liệu" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Command="{Binding SeedSampleDocumentsCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Padding="20,10" Margin="0,0,10,0" VerticalAlignment="Top"
                        IsEnabled="{Binding IsSeeding, Converter={StaticResource InverseBooleanConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📦" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Tạo dữ liệu mẫu" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="..." FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" 
                                   VerticalAlignment="Center" Margin="4,0,0,0"
                                   Visibility="{Binding IsSeeding, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Search & Actions -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#F3F4F6" CornerRadius="8" Height="40" Width="350" HorizontalAlignment="Left">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔍" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#9CA3AF"/>
                            <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"
                                     Foreground="#374151" FontSize="14"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding Documents.Count, StringFormat={}{0} tài liệu}" 
                                   FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Document List -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <!-- Loading indicator -->
                    <Border Background="#80FFFFFF" Panel.ZIndex="10" 
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Đang tải..." FontSize="16" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <DataGrid ItemsSource="{Binding Documents}" 
                              SelectedItem="{Binding SelectedDocument}"
                              IsReadOnly="True" AutoGenerateColumns="False"
                              Style="{StaticResource ModernDataGridStyle}"
                              RowHeaderWidth="0" CanUserAddRows="False" CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Tên tài liệu" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
                                            <TextBlock Text="📄" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <StackPanel>
                                                <TextBlock Text="{Binding OriginalFileName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Description}" FontSize="12" 
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           Visibility="{Binding Description, Converter={StaticResource StringHasValueToVisibilityConverter}}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Định dạng" Binding="{Binding ContentType}" Width="100"/>

                            <DataGridTemplateColumn Header="Kích thước" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FileSize, StringFormat={}{0:N0}}" 
                                                   VerticalAlignment="Center" Margin="5"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Số chunk" Binding="{Binding ChunkCount}" Width="80"/>

                            <DataGridTemplateColumn Header="Ngày upload" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding UploadedAt, StringFormat={}{0:dd/MM/yyyy HH:mm}}" 
                                                   VerticalAlignment="Center" Margin="5"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Thao tác" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Command="{Binding DataContext.ReindexDocumentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Đánh chỉ mục lại"
                                                    Margin="0,0,5,0">
                                                <TextBlock Text="🔄" FontSize="16"/>
                                            </Button>
                                            <Button Command="{Binding DataContext.DeleteDocumentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Xóa">
                                                <TextBlock Text="🗑️" FontSize="16"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
