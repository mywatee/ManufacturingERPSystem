<UserControl x:Class="ManufacturingERP.Views.MasterDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ManufacturingERP.Core"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1400">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:CountToVisibilityConverter x:Key="CountToVis"/>
        <local:EqualityToBooleanConverter x:Key="EqualityToBool"/>
        <local:FirstLetterConverter x:Key="FirstLetterConverter"/>

        <!-- Badge Styles for Categories -->
        <Style x:Key="BadgeBase" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MaterialBadge" TargetType="Border" BasedOn="{StaticResource BadgeBase}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Category}" Value="Nguyên liệu">
                    <Setter Property="Background" Value="#E0F2FE"/>
                    <Setter Property="BorderBrush" Value="#BAE6FD"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Category}" Value="Bán thành phẩm">
                    <Setter Property="Background" Value="#F3E8FF"/>
                    <Setter Property="BorderBrush" Value="#E9D5FF"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Category}" Value="Thành phẩm">
                    <Setter Property="Background" Value="#DCFCE7"/>
                    <Setter Property="BorderBrush" Value="#BBF7D0"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MaterialBadgeText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Category}" Value="Nguyên liệu">
                    <Setter Property="Foreground" Value="#0369A1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Category}" Value="Bán thành phẩm">
                    <Setter Property="Foreground" Value="#7E22CE"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Category}" Value="Thành phẩm">
                    <Setter Property="Foreground" Value="#15803D"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Style.Triggers>
                <Trigger Property="HorizontalContentAlignment" Value="Center">
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                </Trigger>
                <Trigger Property="HorizontalContentAlignment" Value="Right">
                    <Setter Property="HorizontalAlignment" Value="Right"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeight" Value="60"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource DataGridHeaderStyle}"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingStackPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Resources>
                            <!-- Hide default system selection color -->
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>
                        </Style.Resources>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#EFF6FF"/>
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                                <Setter Property="BorderThickness" Value="3,0,0,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Background" Value="#E0F2FE"/>
                            </MultiTrigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="MinWidth" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderThickness="0,0,0,2" BorderBrush="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PagerButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="4,0"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5F9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="24" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="#2563EB"/>
                <TextBlock Text="Dữ liệu gốc" FontSize="28" FontWeight="Bold" Foreground="#1E293B"/>
            </StackPanel>
            <TextBlock Text="Quản lý danh mục vật tư, định mức BOM và quy trình công nghệ" FontSize="14" Foreground="#64748B"/>
        </StackPanel>

        <!-- Main Dashboard Layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/> <!-- Left Column: Materials -->
                <ColumnDefinition Width="*"/> <!-- Right Column: Details (BOM, Routing, Audit Log) -->
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN: MATERIAL DIRECTORY -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,24,0" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title & Add Button -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Danh mục vật tư" FontSize="18" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource SecondaryButtonStyle}" Height="38" Padding="16,0" Margin="0,0,10,0" Command="{Binding NavigateToImportCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8B5; " FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <TextBlock Text="Nhập/Xuất Excel" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PrimaryButtonStyle}" Height="38" Padding="16,0" Command="{Binding AddMaterialCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+ " FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Text="Thêm vật tư mới" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Filters & Search -->
                    <Grid Grid.Row="1" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12,4" Margin="0,0,12,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Tag="Tìm mã hoặc tên vật tư..."/>
                                <TextBlock Grid.Column="1" Text="Tìm mã hoặc tên vật tư..." IsHitTestVisible="False" Foreground="#94A3B8" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <ComboBox Grid.Column="1" Width="140" Margin="0,0,8,0" Height="40" ItemsSource="{Binding CategoryFilters}" SelectedItem="{Binding SelectedCategoryFilter}"/>
                        <ComboBox Grid.Column="2" Width="140" Height="40" ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding SelectedStatusFilter}"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <!-- Material Table -->
                        <DataGrid Style="{StaticResource ModernDataGrid}" 
                                  ItemsSource="{Binding MaterialsView}" 
                                  SelectedItem="{Binding SelectedMaterial}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <!-- Columns ... -->
                                <DataGridTextColumn Header="Mã vật tư" Binding="{Binding Id}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTemplateColumn Header="Tên vật tư" Width="450">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}" VerticalAlignment="Center" Padding="12,0" FontWeight="SemiBold"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Đơn vị" Binding="{Binding Unit}" Width="100">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridHeaderStyle}">
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="Phân loại" Width="160">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridHeaderStyle}">
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource MaterialBadge}" Width="120">
                                                <TextBlock Text="{Binding Category}" Style="{StaticResource MaterialBadgeText}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Tồn kho" Binding="{Binding StockDisplay}" Width="150">
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridHeaderStyle}">
                                            <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="0,0,12,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="Trạng thái" Width="160">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridHeaderStyle}">
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="#EF4444" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Ngừng sử dụng">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="#16A34A" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsLowStock}" Value="False"/>
                                                                        <Condition Binding="{Binding Status}" Value="Đang sử dụng"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="#EF4444" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsOutOfStock}" Value="True"/>
                                                                        <Condition Binding="{Binding Status}" Value="Đang sử dụng"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock FontSize="12" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Đang sử dụng"/>
                                                            <Setter Property="Foreground" Value="#16A34A"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Ngừng sử dụng">
                                                                    <Setter Property="Text" Value="Ngừng SD"/>
                                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                                </DataTrigger>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding Status}" Value="Đang sử dụng"/>
                                                                        <Condition Binding="{Binding IsLowStock}" Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Text" Value="Đang SD (Sắp hết)"/>
                                                                    <Setter Property="Foreground" Value="#EA580C"/>
                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                </MultiDataTrigger>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding Status}" Value="Đang sử dụng"/>
                                                                        <Condition Binding="{Binding IsOutOfStock}" Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Text" Value="Hết hàng"/>
                                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Thao tác" Width="180">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridHeaderStyle}">
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding DataContext.ViewMaterialDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                    <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="14"/>
                                                </Button>
                                                <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding DataContext.EditMaterialCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" Foreground="#2563EB" FontSize="14"/>
                                                </Button>
                                                <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding DataContext.DeleteMaterialCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="#EF4444" FontSize="14"/>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Loading Overlay -->
                        <Border Background="#80FFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                            <StackPanel VerticalAlignment="Center">
                                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="Transparent" Foreground="#2563EB" BorderThickness="0"/>
                                <TextBlock Text="Đang tải dữ liệu..." HorizontalAlignment="Center" Margin="0,10,0,0" Foreground="#2563EB" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Pagination Footer -->
                    <Border Grid.Row="3" Margin="0,16,0,0" Padding="0,16,0,0" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                        <Grid>
                            <TextBlock Text="{Binding PageStatusText}" VerticalAlignment="Center" Foreground="#64748B" FontSize="12"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource PagerButtonStyle}" Command="{Binding PreviousPageCommand}">
                                    <TextBlock Text="&#xE00E;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                                </Button>
                                <Border Background="#2563EB" Width="32" Height="32" CornerRadius="4" Margin="4,0">
                                    <TextBlock Text="{Binding CurrentPage}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                                </Border>
                                <TextBlock Text="của" VerticalAlignment="Center" Margin="8,0" Foreground="#64748B" FontSize="12"/>
                                <TextBlock Text="{Binding TotalPages}" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#1E293B" FontWeight="SemiBold"/>
                                <Button Style="{StaticResource PagerButtonStyle}" Command="{Binding NextPageCommand}">
                                    <TextBlock Text="&#xE00F;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- RIGHT COLUMN: MERGED BOM & ROUTING -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tabs Header -->
                    <Border Grid.Row="0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="24,12,24,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Định mức (BOM)" 
                                        Command="{Binding SwitchDetailTabCommand}" CommandParameter="BOM">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBomVisible}" Value="True">
                                                    <Setter Property="Foreground" Value="#2563EB"/>
                                                    <Setter Property="BorderBrush" Value="#2563EB"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Quy trình" Margin="20,0,0,0"
                                        Command="{Binding SwitchDetailTabCommand}" CommandParameter="Routing">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRoutingVisible}" Value="True">
                                                    <Setter Property="Foreground" Value="#2563EB"/>
                                                    <Setter Property="BorderBrush" Value="#2563EB"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Nhật ký thay đổi" Margin="20,0,0,0"
                                        Command="{Binding SwitchDetailTabCommand}" CommandParameter="Audit">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAuditLogVisible}" Value="True">
                                                    <Setter Property="Foreground" Value="#2563EB"/>
                                                    <Setter Property="BorderBrush" Value="#2563EB"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Đối tác" Margin="20,0,0,0"
                                        Command="{Binding SwitchDetailTabCommand}" CommandParameter="Partners">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPartnersVisible}" Value="True">
                                                    <Setter Property="Foreground" Value="#2563EB"/>
                                                    <Setter Property="BorderBrush" Value="#2563EB"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,0,12">
                                <Button Content="+ Linh kiện" Background="#334155" Height="34" Padding="12,0" 
                                        Command="{Binding AddBomLineCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsBomVisible}" Value="True"/>
                                                        <Condition Binding="{Binding SelectedMaterial.CanHaveStructure}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Thiết lập quy trình" Background="#334155" Height="34" Padding="12,0" 
                                        Command="{Binding ManageRoutingCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsRoutingVisible}" Value="True"/>
                                                        <Condition Binding="{Binding SelectedMaterial.CanHaveStructure}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <!-- Add Partner button moved to Partners tab content to avoid overlap -->
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Tab Content -->
                    <Grid Grid.Row="1" Margin="24">
                        <!-- BOM TAB -->
                        <Grid Visibility="{Binding IsBomVisible, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- BOM DataGrid -->
                            <DataGrid Style="{StaticResource ModernDataGrid}" ItemsSource="{Binding BomLines}" 
                                      RowHeight="54" ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      Visibility="{Binding BomLines.Count, Converter={StaticResource CountToVis}}">
                                <DataGrid.Columns>
                                    <!-- ... existing columns ... -->
                                    <DataGridTemplateColumn Width="30">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Ellipse Width="5" Height="5" Fill="#CBD5E1" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Mã vật tư" Binding="{Binding ComponentCode}" Width="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="12,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="Tên vật tư" Width="300">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ComponentName}" TextTrimming="CharacterEllipsis" ToolTip="{Binding ComponentName}" VerticalAlignment="Center" Padding="12,0"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Định mức" Binding="{Binding QuantityDisplay}" Width="120">
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridHeaderStyle}">
                                                <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="0,0,12,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Width="70">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding DataContext.EditBomLineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Margin="0,0,4,0">
                                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" Foreground="#2563EB" FontSize="12"/>
                                                    </Button>
                                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding DataContext.DeleteBomLineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="#EF4444" FontSize="12"/>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Empty State for BOM -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Visibility="{Binding BomLines.Count, Converter={StaticResource CountToVis}, ConverterParameter=invert}">
                                <Border Background="#F1F5F9" Width="64" Height="64" CornerRadius="32" Margin="0,0,0,16">
                                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="32" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#475569" HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Chưa có định mức vật tư"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedMaterial.CanHaveStructure}" Value="False">
                                                    <Setter Property="Text" Value="Vật tư không yêu cầu định mức"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock FontSize="13" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Nhấn nút '+ Linh kiện' để thiết lập cấu trúc cho sản phẩm này"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedMaterial.CanHaveStructure}" Value="False">
                                                    <Setter Property="Text" Value="Phân loại nguyên liệu/linh kiện không hỗ trợ thiết lập BOM"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <Button Grid.Row="1" Content="Phát hành định mức" Style="{StaticResource PrimaryButtonStyle}" 
                                    HorizontalAlignment="Right" Width="160" Height="38" Margin="0,16,0,0" 
                                    Command="{Binding ReleaseBomCommand}"
                                    ToolTip="Xác nhận và khóa bộ định mức này. Sau khi phát hành, BOM sẽ được dùng để tính toán nguyên vật liệu trong lệnh sản xuất."/>
                        </Grid>

                        <!-- ROUTING TAB -->
                        <Grid Visibility="{Binding IsRoutingVisible, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Routing Content -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                          Visibility="{Binding RoutingSteps.Count, Converter={StaticResource CountToVis}}">
                                <StackPanel MinWidth="400">
                                    <!-- ... existing routing items ... -->
                                    <Border Background="#F8FAFC" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                        <TextBlock HorizontalAlignment="Center">
                                            <Run Text="&#xEB4D; " FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="14"/>
                                            <Run Text="Kéo thả các công đoạn để thay đổi thứ tự" Foreground="#64748B" FontSize="12" FontStyle="Italic"/>
                                        </TextBlock>
                                    </Border>
                                    <ListBox x:Name="RoutingList" ItemsSource="{Binding RoutingSteps}" 
                                             Background="Transparent" BorderThickness="0" 
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             PreviewMouseDown="RoutingList_PreviewMouseDown"
                                             PreviewMouseMove="RoutingList_PreviewMouseMove"
                                             Drop="RoutingList_Drop"
                                             AllowDrop="True">
                                         <ListBox.ItemContainerStyle>
                                             <Style TargetType="ListBoxItem">
                                                 <Setter Property="Background" Value="Transparent"/>
                                                 <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                 <Setter Property="Template">
                                                     <Setter.Value>
                                                         <ControlTemplate TargetType="ListBoxItem">
                                                             <ContentPresenter />
                                                         </ControlTemplate>
                                                     </Setter.Value>
                                                 </Setter>
                                             </Style>
                                         </ListBox.ItemContainerStyle>
                                         <ListBox.ItemTemplate>
                                             <DataTemplate>
                                                 <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,10">
                                                     <Grid>
                                                         <Grid.ColumnDefinitions>
                                                             <ColumnDefinition Width="30"/>
                                                             <ColumnDefinition Width="40"/>
                                                             <ColumnDefinition Width="*"/>
                                                             <ColumnDefinition Width="Auto"/>
                                                             <ColumnDefinition Width="40"/>
                                                         </Grid.ColumnDefinitions>
                                                         
                                                         <!-- Drag Handle -->
                                                         <TextBlock Text="&#xE76F;" FontFamily="Segoe MDL2 Assets" Foreground="#CBD5E1" FontSize="14" VerticalAlignment="Center" Cursor="SizeAll"/>

                                                         <Border Grid.Column="1" Background="#F1F5F9" Width="28" Height="28" CornerRadius="14">
                                                             <TextBlock Text="{Binding StepNo}" FontWeight="Bold" Foreground="#475569" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                         </Border>
                                                         
                                                         <StackPanel Grid.Column="2" Margin="12,0">
                                                             <TextBlock Text="{Binding StepName}" FontWeight="SemiBold" FontSize="14" Foreground="#1E293B" TextTrimming="CharacterEllipsis" ToolTip="{Binding StepName}"/>
                                                             <TextBlock Text="{Binding WorkCenter}" FontSize="12" Foreground="#64748B" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding WorkCenter}"/>
                                                         </StackPanel>
                                                         <TextBlock Grid.Column="3" Text="{Binding StdTimeMinutes, StringFormat={}{0} phút}" FontWeight="SemiBold" Foreground="#2563EB" VerticalAlignment="Center"/>
                                                         <Button Grid.Column="4" Style="{StaticResource ActionButtonStyle}" Command="{Binding DataContext.DeleteRoutingStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" HorizontalAlignment="Right">
                                                             <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="#EF4444" FontSize="12"/>
                                                         </Button>
                                                     </Grid>
                                                 </Border>
                                             </DataTemplate>
                                         </ListBox.ItemTemplate>
                                     </ListBox>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Empty State for Routing -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Visibility="{Binding RoutingSteps.Count, Converter={StaticResource CountToVis}, ConverterParameter=invert}">
                                <Border Background="#F1F5F9" Width="64" Height="64" CornerRadius="32" Margin="0,0,0,16">
                                    <TextBlock Text="&#xEDAC;" FontFamily="Segoe MDL2 Assets" FontSize="32" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#475569" HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Chưa có quy trình công nghệ"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedMaterial.CanHaveStructure}" Value="False">
                                                    <Setter Property="Text" Value="Vật tư không yêu cầu quy trình"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock FontSize="13" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Nhấn nút '+ Công đoạn' để thiết lập các bước sản xuất"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedMaterial.CanHaveStructure}" Value="False">
                                                    <Setter Property="Text" Value="Phân loại nguyên liệu/linh kiện không hỗ trợ thiết lập quy trình"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <Grid Grid.Row="1" Margin="0,16,0,0">
                                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <Run Text="Tổng thời gian: " Foreground="#64748B"/>
                                    <Run Text="{Binding TotalRoutingTime, StringFormat={}{0} phút}" FontWeight="Bold" Foreground="#1E293B" FontSize="16"/>
                                </TextBlock>
                                <Button Content="Lưu thay đổi" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Right" Width="130" Height="38" Command="{Binding SaveRoutingCommand}"/>
                            </Grid>
                        </Grid>
                        
                        <!-- AUDIT LOG TAB -->
                        <Grid Visibility="{Binding IsAuditLogVisible, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Date Filters -->
                                <RowDefinition Height="*"/>    <!-- DataGrid -->
                                <RowDefinition Height="Auto"/> <!-- Pagination -->
                            </Grid.RowDefinitions>

                            <!-- Filters -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="Từ ngày" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <DatePicker SelectedDate="{Binding AuditLogStartDate}" Width="130" Height="32"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="Đến ngày" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <DatePicker SelectedDate="{Binding AuditLogEndDate}" Width="130" Height="32"/>
                                </StackPanel>
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Làm mới" 
                                        Command="{Binding LoadAuditLogsCommand}" CommandParameter="{Binding SelectedMaterial.Id}"
                                        VerticalAlignment="Bottom" Height="32" Padding="12,0"/>
                            </StackPanel>

                            <!-- Audit Log DataGrid -->
                            <DataGrid Grid.Row="1" Style="{StaticResource ModernDataGrid}" ItemsSource="{Binding AuditLogs}"
                                      AutoGenerateColumns="False" IsReadOnly="True" 
                                      MinRowHeight="50" RowHeight="NaN"
                                      BorderThickness="0" Background="Transparent"
                                      HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Thời gian" Width="150">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,8">
                                                    <TextBlock Text="&#xEC92;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding Timestamp, StringFormat='dd/MM/yyyy HH:mm'}" FontSize="12" Foreground="#475569" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    
                                    <DataGridTemplateColumn Header="Người thực hiện" Width="180">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,8">
                                                    <Border Width="28" Height="28" CornerRadius="14" Background="#F1F5F9" Margin="0,0,10,0">
                                                        <TextBlock Text="{Binding User.Employee.FullName, Converter={StaticResource FirstLetterConverter}}" 
                                                                   FontSize="11" FontWeight="Bold" Foreground="#64748B" 
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding User.Employee.FullName}" VerticalAlignment="Center" FontSize="12" Foreground="#1E293B" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Hành động" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Padding="10,6" CornerRadius="14" HorizontalAlignment="Left" Margin="4,8">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#F1F5F9"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Action}" Value="Thêm mới">
                                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Action}" Value="Xóa">
                                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Action}" Value="Cập nhật BOM">
                                                                    <Setter Property="Background" Value="#DBEAFE"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Action}" Value="Cập nhật quy trình">
                                                                    <Setter Property="Background" Value="#F3E8FF"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Action}" Value="Cập nhật">
                                                                    <Setter Property="Background" Value="#FEF3C7"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Action}" FontSize="10" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#475569"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Action}" Value="Thêm mới">
                                                                        <Setter Property="Foreground" Value="#15803D"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Action}" Value="Xóa">
                                                                        <Setter Property="Foreground" Value="#B91C1C"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Action}" Value="Cập nhật BOM">
                                                                        <Setter Property="Foreground" Value="#1E40AF"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Action}" Value="Cập nhật quy trình">
                                                                        <Setter Property="Foreground" Value="#7E22CE"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Action}" Value="Cập nhật">
                                                                        <Setter Property="Foreground" Value="#B45309"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Nội dung chi tiết" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding NewValue}" FontSize="12" Foreground="#475569" 
                                                           TextWrapping="Wrap" VerticalAlignment="Center" Padding="8,10"
                                                           LineHeight="18"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Pagination for Audit Log -->
                            <Border Grid.Row="2" BorderBrush="#F1F5F9" BorderThickness="0,1,0,0" Padding="0,8,0,0" Margin="0,8,0,0">
                                <Grid>
                                    <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#94A3B8">
                                        <Run Text="Hiển thị"/>
                                        <Run Text="{Binding AuditLogs.Count, Mode=OneWay}" FontWeight="SemiBold" Foreground="#64748B"/>
                                        <Run Text="/"/>
                                        <Run Text="{Binding AuditLogTotalItems, Mode=OneWay}" FontWeight="SemiBold" Foreground="#64748B"/>
                                    </TextBlock>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Style="{StaticResource PagerButtonStyle}" Command="{Binding AuditLogPreviousPageCommand}" Width="28" Height="28">
                                            <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="9"/>
                                        </Button>
                                        
                                        <Border Background="#2563EB" Width="28" Height="28" CornerRadius="4" Margin="4,0">
                                            <TextBlock Text="{Binding AuditLogCurrentPage}" Foreground="White" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        
                                        <TextBlock Text="/" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding AuditLogTotalPages}" Foreground="#64748B" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Margin="0,0,4,0"/>

                                        <Button Style="{StaticResource PagerButtonStyle}" Command="{Binding AuditLogNextPageCommand}" Width="28" Height="28">
                                            <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="9"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- PARTNERS TAB -->
                        <Grid Visibility="{Binding IsPartnersVisible, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Partner Search Bar -->
                                <Border Grid.Column="0" Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12,4" Margin="0,0,16,0" MaxWidth="300" HorizontalAlignment="Left">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding PartnerSearchText, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Tìm tên hoặc mã đối tác..." IsHitTestVisible="False" Foreground="#94A3B8" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PartnerSearchText}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <Button Grid.Column="1" HorizontalAlignment="Right"
                                        Background="#2563EB" Height="38" Padding="16,0" 
                                        Command="{Binding AddPartnerCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="+ " FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <TextBlock Text="Thêm đối tác mới" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <DockPanel Grid.Row="1">
                                <!-- Pagination Footer for Partners (Docked to Bottom) -->
                                <Border DockPanel.Dock="Bottom" Margin="0,16,0,0" Padding="0,16,0,0" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                                    <Grid>
                                        <TextBlock VerticalAlignment="Center" Foreground="#64748B" FontSize="12">
                                            <Run Text="Tổng số: "/>
                                            <Run Text="{Binding PartnerTotalItems}" FontWeight="Bold"/>
                                            <Run Text=" đối tác"/>
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Style="{StaticResource PagerButtonStyle}" Command="{Binding PartnerPreviousPageCommand}">
                                                <TextBlock Text="&#xE00E;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                                            </Button>
                                            <Border Background="#2563EB" Width="32" Height="32" CornerRadius="4" Margin="4,0">
                                                <TextBlock Text="{Binding PartnerCurrentPage}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Text="của" VerticalAlignment="Center" Margin="8,0" Foreground="#64748B" FontSize="12"/>
                                            <TextBlock Text="{Binding PartnerTotalPages}" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#1E293B" FontWeight="SemiBold"/>
                                            <Button Style="{StaticResource PagerButtonStyle}" Command="{Binding PartnerNextPageCommand}">
                                                <TextBlock Text="&#xE00F;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- DataGrid (Fills remaining space, scrollbar will be above pagination) -->
                                <DataGrid Style="{StaticResource ModernDataGrid}" ItemsSource="{Binding VisiblePartners}"
                                          AutoGenerateColumns="False" IsReadOnly="True" MinRowHeight="65"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Mã" Binding="{Binding Code}" Width="100">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Padding" Value="12,0"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTemplateColumn Header="Tên đối tác" Width="250">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel VerticalAlignment="Center" Margin="12,8">
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#1E293B" 
                                                                   FontSize="14" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding Type}" FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Điện thoại" Binding="{Binding Phone}" Width="140">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Padding" Value="12,0"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTemplateColumn Header="Email" Width="220">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Email}" VerticalAlignment="Center" Padding="12,8" 
                                                             TextWrapping="Wrap" FontSize="12" Foreground="#475569"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Thao tác" Width="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="4,0">
                                                        <Button Style="{StaticResource ActionButtonStyle}" 
                                                                ToolTip="Chỉnh sửa thông tin"
                                                                Command="{Binding DataContext.EditPartnerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                CommandParameter="{Binding}">
                                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" Foreground="#2563EB" FontSize="14"/>
                                                        </Button>
                                                        <Button Style="{StaticResource ActionButtonStyle}" 
                                                                ToolTip="Xóa đối tác"
                                                                Command="{Binding DataContext.DeletePartnerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                CommandParameter="{Binding}">
                                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="#EF4444" FontSize="14"/>
                                                        </Button>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>

                            <!-- Empty State for Partners -->
                            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Visibility="{Binding Partners.Count, Converter={StaticResource CountToVis}, ConverterParameter=invert}">
                                <Border Background="#F1F5F9" Width="64" Height="64" CornerRadius="32" Margin="0,0,0,16">
                                    <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="32" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Chưa có dữ liệu đối tác" FontSize="16" FontWeight="SemiBold" Foreground="#475569" HorizontalAlignment="Center"/>
                                <TextBlock Text="Nhấn nút '+ Thêm đối tác mới' để thêm mới" FontSize="13" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>