                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="16" Height="16" CornerRadius="8" Margin="0,0,6,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Type}" Value="Nhập kho"><Setter Property="Background" Value="#3B82F6"/></DataTrigger>
                                                                    <DataTrigger Binding="{Binding Type}" Value="Xuất kho"><Setter Property="Background" Value="#F97316"/></DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Path Stretch="Uniform" Width="8" Height="8" Fill="White">
                                                            <Path.Style>
                                                                <Style TargetType="Path">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Nhập kho"><Setter Property="Data" Value="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h4v2z"/></DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Xuất kho"><Setter Property="Data" Value="M19 13H5v-2h14v2z"/></DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                    </Border>
                                                    <TextBlock Text="{Binding Type}" FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Type}" Value="Nhập kho"><Setter Property="Foreground" Value="#2563EB"/></DataTrigger>
                                                                    <DataTrigger Binding="{Binding Type}" Value="Xuất kho"><Setter Property="Foreground" Value="#EA580C"/></DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Mã vật tư" Binding="{Binding MaterialCode}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="Bold"/><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="15,0"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Tên vật tư" Binding="{Binding MaterialName}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="15,0"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="Số lượng" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                                                <TextBlock Text="{Binding Quantity}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Unit}" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Nhà kho" Binding="{Binding Warehouse}" Width="150" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="15,0"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="Người thực hiện" Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                                                <Path Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" 
                                                      Fill="#CBD5E1" Width="14" Height="14" Stretch="Uniform" Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding TransBy}" VerticalAlignment="Center" Foreground="#475569"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Chứng từ" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                                                <Path Data="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z" 
                                                      Fill="#3B82F6" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding ReferenceDoc}" VerticalAlignment="Center" Foreground="#3B82F6" Cursor="Hand">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="TextDecorations" Value="Underline"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Thao tác" Width="150">
                                     <DataGridTemplateColumn.CellTemplate>
                                         <DataTemplate>
                                             <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                 <Button Style="{StaticResource IconButtonStyle}" ToolTip="Xem chi tiết"
                                                         Command="{Binding DataContext.ViewTransactionDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                         CommandParameter="{Binding}">
                                                     <Path Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" 
                                                           Fill="#3B82F6" Width="14" Height="14" Stretch="Uniform"/>
                                                 </Button>
                                                 <Button Style="{StaticResource IconButtonStyle}" ToolTip="Hủy phiếu"
                                                         Command="{Binding DataContext.CancelTransactionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                         CommandParameter="{Binding}">
                                                     <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" 
                                                           Fill="#EF4444" Width="14" Height="14" Stretch="Uniform"/>
                                                 </Button>
                                             </StackPanel>
                                         </DataTemplate>
                                     </DataGridTemplateColumn.CellTemplate>
                                 </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>

                <!-- Tab: Setup -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="setup">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Section Header -->
                    <Grid Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Cấu hình nhà kho" FontSize="18" FontWeight="Bold" Foreground="#1e3a5f"/>
                            <TextBlock Text="Quản lý danh sách kho và theo dõi tỷ lệ lấp đầy" FontSize="14" Foreground="#64748B"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Style="{StaticResource PrimaryButtonStyle}" Background="#1E293B" BorderBrush="#1E293B" Command="{Binding CreateWarehouseCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h4v2z" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"/>
                                <TextBlock Text="Thêm nhà kho mới" VerticalAlignment="Center" Foreground="White" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Header Metrics Section -->
                    <Grid Margin="0,0,0,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Card 1: Total Warehouses -->
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" Background="#EFF6FF" CornerRadius="8">
                                    <Path Data="M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2" 
                                          Fill="#3B82F6" Width="18" Height="18" Stretch="Uniform"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                    <TextBlock Text="Tổng số kho" FontSize="13" Foreground="#64748B" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding TotalWarehousesCount}" FontSize="24" FontWeight="Bold" Foreground="#1e3a5f"/>
                                    <TextBlock Text="{Binding ActiveWarehousesCount, StringFormat={}{0} kho đang hoạt động}" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Card 2: Total Capacity -->
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" Background="#F5F3FF" CornerRadius="8">
                                    <Path Data="M21 16.5c0 .38-.21.71-.53.88l-7.97 4.43c-.31.17-.69.17-1 0l-7.97-4.43c-.32-.17-.53-.5-.53-.88v-9c0-.38.21-.71.53-.88l7.97-4.43c.31-.17.69-.17 1 0l7.97 4.43c.32.17.53.5.53.88v9z" 
                                          Fill="#8B5CF6" Width="18" Height="18" Stretch="Uniform"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                    <TextBlock Text="Tổng công suất" FontSize="13" Foreground="#64748B" Margin="0,0,0,2"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TotalCapacitySum, StringFormat={}{0:N0}}" FontSize="24" FontWeight="Bold" Foreground="#1e3a5f"/>
                                        <TextBlock Text=" m²" FontSize="14" Foreground="#1e3a5f" VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                                    </StackPanel>
                                    <TextBlock Text="Tính theo m²" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Card 3: Utilization Rate -->
                        <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" Background="#ECFDF5" CornerRadius="8">
                                    <Path Data="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" 
                                          Fill="#10B981" Width="18" Height="18" Stretch="Uniform"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                    <TextBlock Text="Tỷ lệ sử dụng" FontSize="13" Foreground="#64748B" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding TotalUsedPercentage, StringFormat={}{0:F1}%}" FontSize="24" FontWeight="Bold" Foreground="#10B981"/>
                                    <TextBlock Text="{Binding TotalUsedSum, StringFormat={}{0:N0} / 2400 m²}" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Warehouse Cards Grid -->
                    <ItemsControl ItemsSource="{Binding WarehouseConfigs}" Margin="0,0,0,32">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,16,16" Padding="24">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Card Header -->
                                        <Grid Margin="0,0,0,20">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="32" Height="32" Background="#EFF6FF" CornerRadius="4">
                                                    <Path Data="M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2" 
                                                          Fill="#3B82F6" Width="16" Height="16" Stretch="Uniform"/>
                                                </Border>
                                                <StackPanel Margin="12,0,0,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold" Foreground="#1e3a5f"/>
                                                        <Border CornerRadius="10" Padding="8,2" Margin="8,0,0,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Hoạt động"><Setter Property="Background" Value="#ECFDF5"/></DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Bảo trì"><Setter Property="Background" Value="#FFFBEB"/></DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Status}" Value="Hoạt động"><Setter Property="Foreground" Value="#059669"/></DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}" Value="Bảo trì"><Setter Property="Foreground" Value="#D97706"/></DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Code}" FontSize="11" Foreground="#94A3B8"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Style="{StaticResource IconButtonStyle}" Margin="0,0,4,0"
                                                        Command="{Binding DataContext.EditWarehouseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Path Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" 
                                                          Fill="#64748B" Width="14" Height="14" Stretch="Uniform"/>
                                                </Button>
                                                <Button Style="{StaticResource IconButtonStyle}"
                                                        Command="{Binding DataContext.DeleteWarehouseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" 
                                                          Fill="#EF4444" Width="14" Height="14" Stretch="Uniform"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Location Info -->
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                                            <Path Data="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" 
                                                  Fill="#94A3B8" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Location}" FontSize="12" Foreground="#64748B"/>
                                        </StackPanel>

                                        <!-- Progress Bar -->
                                        <StackPanel Grid.Row="2" Margin="0,0,0,20">
                                            <Grid Margin="0,0,0,6">
                                                <TextBlock Text="Tỷ lệ lấp đầy" FontSize="12" Foreground="#64748B"/>
                                                <TextBlock Text="{Binding FillPercentage, Mode=OneWay, StringFormat={}{0:F1}%}" HorizontalAlignment="Right" FontSize="12" FontWeight="Bold" Foreground="#10B981"/>
                                            </Grid>
                                            <ProgressBar Value="{Binding FillPercentage, Mode=OneWay}" Height="6" Maximum="100" BorderThickness="0" Background="#F1F5F9">
                                                <ProgressBar.Template>
                                                    <ControlTemplate TargetType="ProgressBar">
                                                        <Grid>
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                                                            <Border HorizontalAlignment="Left" CornerRadius="3" Background="#10B981" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"/>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </ProgressBar.Template>
                                            </ProgressBar>
                                            <Grid Margin="0,6,0,0">
                                                <TextBlock Text="{Binding Used, StringFormat={}Đang dùng: {0:N0} m²}" FontSize="10" Foreground="#94A3B8"/>
