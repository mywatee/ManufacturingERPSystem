                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Hoạt động"><Setter Property="Background" Value="#ECFDF5"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Bảo trì"><Setter Property="Background" Value="#FFFBEB"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Hoạt động"><Setter Property="Foreground" Value="#059669"/></DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Bảo trì"><Setter Property="Foreground" Value="#D97706"/></DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Thao tác" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="Xem chi tiết"
                                                            Command="{Binding DataContext.ViewWarehouseDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Path Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" 
                                                              Fill="#3B82F6" Width="14" Height="14" Stretch="Uniform"/>
                                                    </Button>
                                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="Sửa" Margin="4,0"
                                                            Command="{Binding DataContext.EditWarehouseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Path Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" 
                                                              Fill="#64748B" Width="14" Height="14" Stretch="Uniform"/>
                                                    </Button>
                                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="Xóa"
                                                            Command="{Binding DataContext.DeleteWarehouseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" 
                                                              Fill="#EF4444" Width="14" Height="14" Stretch="Uniform"/>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Tab: Alerts -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="alerts">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Header Section -->
                    <Grid Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Cảnh báo tồn kho" FontSize="18" FontWeight="Bold" Foreground="#1e3a5f"/>
                            <TextBlock Text="Danh sách vật tư có mức tồn kho thấp hơn ngưỡng an toàn" FontSize="14" Foreground="#64748B"/>
                        </StackPanel>
                    </Grid>

                    <!-- Quick Alerts Summary Row -->
                    <Grid Margin="0,0,0,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Card 1: Critical -->
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="20" Background="#FEF2F2" BorderBrush="#FEE2E2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" Background="#FEE2E2" CornerRadius="20">
                                    <Path Data="M12 2L1 21h22L12 2zm1 14h-2v-2h2v2zm0-4h-2V8h2v4z" 
                                          Fill="#DC2626" Width="18" Height="18" Stretch="Uniform"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                    <TextBlock Text="Nguy cấp - Hết hàng" FontSize="13" Foreground="#991B1B" Margin="0,0,0,2" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding CriticalAlertCount}" FontSize="28" FontWeight="Bold" Foreground="#DC2626"/>
                                    <TextBlock Text="Cần nhập ngay lập tức" FontSize="11" Foreground="#EF4444"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Card 2: Warning -->
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="20" Background="#FFF7ED" BorderBrush="#FFEDD5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" Background="#FFEDD5" CornerRadius="20">
                                    <Path Data="M16 18l2.29-2.29-4.88-4.88-4 4L2 7.41 3.41 6l6 6 4-4 6.3 6.29L22 12v6h-6z" 
                                          Fill="#EA580C" Width="18" Height="18" Stretch="Uniform"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                    <TextBlock Text="Cảnh báo - Sắp hết" FontSize="13" Foreground="#9A3412" Margin="0,0,0,2" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding WarningAlertCount}" FontSize="28" FontWeight="Bold" Foreground="#EA580C"/>
                                    <TextBlock Text="Dưới mức tối thiểu" FontSize="11" Foreground="#F97316"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Card 3: Notice -->
                        <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="20" Background="#FEFCE8" BorderBrush="#FEF9C3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" Background="#FEF9C3" CornerRadius="20">
                                    <Path Data="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.89 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z" 
                                          Fill="#CA8A04" Width="18" Height="18" Stretch="Uniform"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                    <TextBlock Text="Lưu ý - Gần ngưỡng" FontSize="13" Foreground="#854D0E" Margin="0,0,0,2" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding NoticeAlertCount}" FontSize="28" FontWeight="Bold" Foreground="#CA8A04"/>
                                    <TextBlock Text="Chuẩn bị nhập hàng" FontSize="11" Foreground="#EAB308"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Detailed Alert Cards Grid -->
                    <ItemsControl ItemsSource="{Binding StockAlerts}" Margin="0,0,0,32">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" VerticalAlignment="Top"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,16,16" Padding="24">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AlertLevel}" Value="Nguy cấp"><Setter Property="Background" Value="#FFF1F2"/></DataTrigger>
                                                <DataTrigger Binding="{Binding AlertLevel}" Value="Cảnh báo"><Setter Property="Background" Value="#FFF7ED"/></DataTrigger>
                                                <DataTrigger Binding="{Binding AlertLevel}" Value="Lưu ý"><Setter Property="Background" Value="#FEFCE8"/></DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Card Header: Level & Icon -->
                                        <Grid Margin="0,0,0,16">
                                            <StackPanel Orientation="Horizontal">
                                                <Border CornerRadius="8" Padding="12,4" Margin="0,0,12,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AlertLevel}" Value="Nguy cấp"><Setter Property="Background" Value="#FECDD3"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding AlertLevel}" Value="Cảnh báo"><Setter Property="Background" Value="#FFEDD5"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding AlertLevel}" Value="Lưu ý"><Setter Property="Background" Value="#FEF9C3"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding AlertLevel}" FontSize="12" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AlertLevel}" Value="Nguy cấp"><Setter Property="Foreground" Value="#BE123C"/></DataTrigger>
                                                                    <DataTrigger Binding="{Binding AlertLevel}" Value="Cảnh báo"><Setter Property="Foreground" Value="#C2410C"/></DataTrigger>
                                                                    <DataTrigger Binding="{Binding AlertLevel}" Value="Lưu ý"><Setter Property="Foreground" Value="#A16207"/></DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Path Width="14" Height="14" Stretch="Uniform" Margin="0,0,4,0">
                                                        <Path.Style>
                                                            <Style TargetType="Path">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AlertLevel}" Value="Nguy cấp">
                                                                        <Setter Property="Data" Value="M12 2L1 21h22L12 2zm1 14h-2v-2h2v2zm0-4h-2V8h2v4z"/>
                                                                        <Setter Property="Fill" Value="#BE123C"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding AlertLevel}" Value="Cảnh báo">
                                                                        <Setter Property="Data" Value="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/>
                                                                        <Setter Property="Fill" Value="#C2410C"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Path.Style>
                                                    </Path>
                                                    <TextBlock Text="{Binding SpecialStatus}" FontSize="12" FontWeight="SemiBold">
                                                       <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AlertLevel}" Value="Nguy cấp"><Setter Property="Foreground" Value="#BE123C"/></DataTrigger>
                                                                    <DataTrigger Binding="{Binding AlertLevel}" Value="Cảnh báo"><Setter Property="Foreground" Value="#C2410C"/></DataTrigger>
                                                                    <DataTrigger Binding="{Binding AlertLevel}" Value="Lưu ý"><Setter Property="Foreground" Value="#A16207"/></DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                            <Path Data="M17,2H7C5.89,2 5,2.89 5,4V20C5,21.1 5.89,22 7,22H17C18.1,22 19,21.1 19,20V4C19,2.89 18.1,2 17,2M17,20H7V4H17V20M12,9L7,14H10V18H14V14H17L12,9Z" 
                                                  Fill="#CBD5E1" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                        </Grid>

                                        <!-- Item Info -->
                                        <StackPanel Grid.Row="1" Margin="0,0,0,20">
                                            <TextBlock Text="{Binding MaterialCode}" FontSize="15" FontWeight="Bold" Foreground="#1e3a5f"/>
                                            <TextBlock Text="{Binding MaterialName}" FontSize="14" Foreground="#334155" Margin="0,2,0,4"/>
                                            <TextBlock Text="{Binding Warehouse}" FontSize="11" Foreground="#94A3B8"/>
                                        </StackPanel>

                                        <!-- Progress & Stats -->
                                        <StackPanel Grid.Row="2" Margin="0,0,0,24">
                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="Tồn kho hiện tại:" FontSize="13" Foreground="#64748B"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding CurrentQty}" FontSize="14" FontWeight="Bold" Foreground="#1e3a5f"/>
                                                    <TextBlock Text="{Binding MinStock, StringFormat={} / {0}}" FontSize="14" FontWeight="Bold" Foreground="#64748B"/>
                                                    <TextBlock Text="{Binding Unit, StringFormat={} {0}}" FontSize="13" Foreground="#64748B" VerticalAlignment="Bottom" Margin="4,0,0,1"/>
                                                </StackPanel>
                                            </Grid>
                                            <ProgressBar Value="{Binding AlertPercentage, Mode=OneWay}" Height="10" Maximum="100" BorderThickness="0" Background="#E2E8F0">
                                                <ProgressBar.Template>
                                                    <ControlTemplate TargetType="ProgressBar">
                                                        <Grid>
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="5"/>
                                                            <Border HorizontalAlignment="Left" CornerRadius="5" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding AlertLevel}" Value="Nguy cấp"><Setter Property="Background" Value="#EF4444"/></DataTrigger>
                                                                            <DataTrigger Binding="{Binding AlertLevel}" Value="Cảnh báo"><Setter Property="Background" Value="#F97316"/></DataTrigger>
                                                                            <DataTrigger Binding="{Binding AlertLevel}" Value="Lưu ý"><Setter Property="Background" Value="#EAB308"/></DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                            </Border>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </ProgressBar.Template>
                                            </ProgressBar>
                                            <Grid Margin="0,8,0,0">
                                                <TextBlock Text="{Binding AlertPercentage, Mode=OneWay, StringFormat={}{0:F0}% mức tối thiểu}" FontSize="11" Foreground="#94A3B8"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <TextBlock Text="Thiếu: " FontSize="11" Foreground="#94A3B8"/>
                                                    <TextBlock Text="{Binding ShortageQuantity}" FontSize="11" FontWeight="Bold" Foreground="#DC2626"/>
                                                    <TextBlock Text="{Binding Unit, StringFormat={} {0}}" FontSize="11" Foreground="#DC2626"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Action -->
                                        <Button Grid.Row="3" Style="{StaticResource PrimaryButtonStyle}" Background="#2563EB" BorderBrush="#2563EB" Height="40"
                                                Command="{Binding DataContext.CreatePurchaseOrderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z" 
                                                      Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"/>
                                                <TextBlock Text="Tạo đơn đặt hàng" Foreground="White" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Bottom Detailed Table -->
                    <StackPanel>
                        <TextBlock Text="Danh sách chi tiết cảnh báo" FontSize="18" FontWeight="Bold" Foreground="#1e3a5f" Margin="0,0,0,16"/>
                        <Border Style="{StaticResource CardStyle}" Padding="0">
                            <DataGrid ItemsSource="{Binding StockAlerts}" AutoGenerateColumns="False" IsReadOnly="True"
                                      Style="{StaticResource ModernDataGridStyle}" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Mức độ" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="12" Padding="8,2" HorizontalAlignment="Left" Margin="15,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AlertLevel}" Value="Nguy cấp"><Setter Property="Background" Value="#FEF2F2"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding AlertLevel}" Value="Cảnh báo"><Setter Property="Background" Value="#FFF7ED"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding AlertLevel}" Value="Lưu ý"><Setter Property="Background" Value="#FEFCE8"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding AlertLevel}" FontSize="11" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AlertLevel}" Value="Nguy cấp"><Setter Property="Foreground" Value="#DC2626"/></DataTrigger>
                                                                    <DataTrigger Binding="{Binding AlertLevel}" Value="Cảnh báo"><Setter Property="Foreground" Value="#EA580C"/></DataTrigger>
                                                                    <DataTrigger Binding="{Binding AlertLevel}" Value="Lưu ý"><Setter Property="Foreground" Value="#CA8A04"/></DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="Mã vật tư" Binding="{Binding MaterialCode}" Width="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="15,0"/></Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Tên vật tư" Binding="{Binding MaterialName}" Width="150">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="15,0"/></Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Nhà kho" Binding="{Binding Warehouse}" Width="150">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="15,0"/></Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTemplateColumn Header="Tồn hiện tại" Width="110">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock VerticalAlignment="Center" Margin="15,0" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding CurrentQty, StringFormat={}{0}}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AlertLevel}" Value="Nguy cấp"><Setter Property="Foreground" Value="#DC2626"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding Unit}" FontWeight="Normal" Foreground="#64748B"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="Mức tối thiểu" Binding="{Binding MinStock, StringFormat={}{0:N0}}" Width="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="15,0"/></Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTemplateColumn Header="Cần nhập thêm" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock VerticalAlignment="Center" Margin="15,0" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding ShortageQuantity, StringFormat={}{0:N0}}"/>
                                                            <Setter Property="Foreground" Value="#DC2626"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ShortageQuantity}" Value="0">
                                                                    <Setter Property="Text" Value="OK"/>
                                                                    <Setter Property="Foreground" Value="#10B981"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding Unit}" FontWeight="Normal" FontSize="11"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Dự kiến hết" Width="110">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4" Padding="8,2" HorizontalAlignment="Left" Margin="15,0">
