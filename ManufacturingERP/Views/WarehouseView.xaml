                                            <Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="15,0"/></Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTemplateColumn Header="Tỷ lệ lấp đầy" Width="150">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel VerticalAlignment="Center" Margin="15,0">
                                                    <TextBlock Text="{Binding FillPercentage, Mode=OneWay, StringFormat={}{0:F1}%}" FontSize="10" FontWeight="SemiBold" Foreground="#10B981" Margin="0,0,0,4"/>
                                                    <ProgressBar Value="{Binding FillPercentage, Mode=OneWay}" Height="6" Maximum="100" BorderThickness="0" Background="#F1F5F9">
