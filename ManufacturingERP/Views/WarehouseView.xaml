                                            </Grid>
                                        </StackPanel>

                                        <!-- Footer -->
                                        <Border Grid.Row="3" BorderBrush="#F1F5F9" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                                            <Grid>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Quản lý: " FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Manager}" FontSize="12" FontWeight="SemiBold" Foreground="#1e3a5f" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Button Content="Chi tiết" HorizontalAlignment="Right" Style="{StaticResource SecondaryButtonStyle}" Padding="16,6" FontSize="11"
                                                        Command="{Binding DataContext.ViewWarehouseDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Bottom List: Detailed Table -->
                    <StackPanel>
                        <TextBlock Text="Danh sách chi tiết" FontSize="18" FontWeight="Bold" Foreground="#1e3a5f" Margin="0,0,0,16"/>
