                                                            <ControlTemplate TargetType="ProgressBar">
                                                                <Grid>
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                                                                    <Border HorizontalAlignment="Left" CornerRadius="3" Background="#10B981" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"/>
                                                                </Grid>
                                                            </ControlTemplate>
                                                        </ProgressBar.Template>
                                                    </ProgressBar>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Trạng thái" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="12" Padding="8,4" HorizontalAlignment="Left" Margin="15,0">
