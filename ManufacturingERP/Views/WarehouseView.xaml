<UserControl x:Class="ManufacturingERP.Views.WarehouseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ManufacturingERP.Views"
             xmlns:viewmodels="clr-namespace:ManufacturingERP.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#F8FAFC">
    
    <UserControl.Resources>
        <Style x:Key="WarehouseStatCard" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,20,0"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title -->
                <RowDefinition Height="Auto"/> <!-- Tabs -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Title Section -->
            <Grid Grid.Row="0" Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Path Data="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z" 
                              Fill="#1e3a5f" Width="24" Height="24" Stretch="Uniform" Margin="0,0,12,0"/>
                        <TextBlock Text="Quản lý kho bãi" FontSize="28" FontWeight="Bold" Foreground="#1e3a5f"/>
                    </StackPanel>
                    <TextBlock Text="Quản lý tồn kho, phiếu nhập xuất và cảnh báo vật tư" 
                               FontSize="14" Foreground="#64748B"/>
                </StackPanel>

                <Button Grid.Column="5" Command="{Binding CreateOutboundCommand}" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Foreground="#475569" Padding="20,10">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style></Button.Resources>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE118;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                        <TextBlock Text="Tạo phiếu Xuất" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="7" Command="{Binding CreateInboundCommand}" Background="#2563EB" Foreground="White" Padding="20,10">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style></Button.Resources>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE109;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                        <TextBlock Text="Nhập kho mới" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>


            <!-- Tabs Section -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,24">

                <RadioButton Content="Tổng quan tồn kho" 
                             Style="{StaticResource AdminTabButtonStyle}"
                             IsChecked="{Binding SelectedTab, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=overview}"
                             Command="{Binding SelectTabCommand}" CommandParameter="overview"/>
                <RadioButton Content="Phiếu nhập/xuất" 
                             Style="{StaticResource AdminTabButtonStyle}"
                             IsChecked="{Binding SelectedTab, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=transactions}"
                             Command="{Binding SelectTabCommand}" CommandParameter="transactions"/>
                <RadioButton Content="Cấu hình nhà kho" 
                             Style="{StaticResource AdminTabButtonStyle}"
                             IsChecked="{Binding SelectedTab, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=setup}"
                             Command="{Binding SelectTabCommand}" CommandParameter="setup"/>
                <RadioButton Content="Cảnh báo tồn kho" 
                             Style="{StaticResource AdminTabButtonStyle}"
                             IsChecked="{Binding SelectedTab, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=alerts}"
                             Command="{Binding SelectTabCommand}" CommandParameter="alerts"/>
            </StackPanel>

            <!-- Content Section -->
            <Grid Grid.Row="2">
                <!-- Tab: Overview -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="overview">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <!-- Stats Cards -->
                    <Grid Margin="0,0,0,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Total Items -->
                        <Border Grid.Column="0" Style="{StaticResource WarehouseStatCard}">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <Border Width="48" Height="48" Background="#EFF6FF" CornerRadius="24" HorizontalAlignment="Left">
                                        <Path Data="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4V8l8 5 8-5v10zm-8-7L4 6h16l-8 5z" 
                                              Fill="#2563EB" Width="24" Height="24" Stretch="Uniform"/>
                                    </Border>
                                    <Path Data="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z" 
                                          Fill="#10B981" Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                </Grid>
                                <TextBlock Text="Tổng số lượng vật tư" FontSize="14" Foreground="#64748B" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding TotalItems}" FontSize="32" FontWeight="Bold" Foreground="#111827"/>
                                <TextBlock Text="{Binding UniqueMaterialsCount, StringFormat={}{0} loại vật tư trong kho}" FontSize="12" Foreground="#94A3B8"/>
                            </StackPanel>
                        </Border>

                        <!-- Total Value -->
                        <Border Grid.Column="1" Style="{StaticResource WarehouseStatCard}">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <Border Width="48" Height="48" Background="#F0FDF4" CornerRadius="24" HorizontalAlignment="Left">
                                        <Path Data="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z" 
                                              Fill="#16A34A" Width="24" Height="24" Stretch="Uniform"/>
                                    </Border>
                                    <Path Data="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z" 
                                          Fill="#10B981" Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                </Grid>
                                <TextBlock Text="Giá trị tồn kho ước tính" FontSize="14" Foreground="#64748B" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding TotalInventoryValue, StringFormat={}{0:N0} đ}" FontSize="32" FontWeight="Bold" Foreground="#16A34A"/>
                                <TextBlock Text="Dựa trên giá nhập gần nhất" FontSize="12" Foreground="#94A3B8"/>
                            </StackPanel>
                        </Border>

                        <!-- Low Stock Alerts -->
                        <Border Grid.Column="2" Style="{StaticResource WarehouseStatCard}" Margin="0">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <Border Width="48" Height="48" Background="#FEF2F2" CornerRadius="24" HorizontalAlignment="Left">
                                        <Path Data="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z" 
                                              Fill="#EF4444" Width="24" Height="24" Stretch="Uniform"/>
                                    </Border>
                                    <Path Data="M16 18l2.29-2.29-4.88-4.88-4 4L2 7.41 3.41 6l6 6 4-4 6.3 6.29L22 12v6z" 
                                          Fill="#EF4444" Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                </Grid>
                                <TextBlock Text="Vật tư cần nhập gấp" FontSize="14" Foreground="#64748B" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding LowStockAlerts}" FontSize="32" FontWeight="Bold" Foreground="#EF4444"/>
                                <TextBlock Text="Mức tồn dưới ngưỡng an toàn" FontSize="12" Foreground="#94A3B8"/>
                            </StackPanel>
                        </Border>

                    </Grid>

                    <!-- Filters and Search -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="15,8" Margin="0,0,16,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center" Foreground="#94A3B8" Margin="0,0,12,0" FontSize="16"/>
                                <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                                         BorderThickness="0" Background="Transparent" VerticalAlignment="Center" 
                                         FontSize="14" d:Text="Tìm kiếm vật tư theo mã hoặc tên..."/>
                            </Grid>
                        </Border>

                        <ComboBox Grid.Column="1" ItemsSource="{Binding WarehouseList}" SelectedItem="{Binding SelectedWarehouse}" 
                                  Style="{StaticResource ModernComboBoxStyle}"/>

                        <Button Grid.Column="3" Command="{Binding NavigateToReportCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="15,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE109;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                                <TextBlock Text="Báo cáo" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="5" Command="{Binding CreateAdjustmentCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="15,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE12F;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                                <TextBlock Text="Kiểm kê" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>



                    <!-- Inventory Table -->
                    <Border Style="{StaticResource CardStyle}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <Border Grid.Row="0" Background="#F8FAFC" Padding="20,15" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                <TextBlock Text="Chi tiết tồn kho" FontSize="16" FontWeight="SemiBold" Foreground="#1e3a5f"/>
                            </Border>

                            <DataGrid Grid.Row="1" ItemsSource="{Binding Inventory}" AutoGenerateColumns="False" IsReadOnly="True"
                                      Style="{StaticResource ModernDataGridStyle}" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Mã vật tư" Binding="{Binding MaterialCode}" Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="15,0"/></Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    
                                    <DataGridTemplateColumn Header="Tên vật tư" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                                                    <Path Data="M20 6h-8l-2-2H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 12H4V8l8 5 8-5v10z" 
                                                          Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                                    <TextBlock Text="{Binding MaterialName}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="Nhà kho" Binding="{Binding Warehouse}" Width="180">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock"><Setter Property="FontSize" Value="13"/><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="15,0"/></Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTemplateColumn Header="Số lượng" Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel VerticalAlignment="Center" Margin="15,0">
                                                    <TextBlock Text="{Binding CurrentQty}" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Hết hàng"><Setter Property="Foreground" Value="#EF4444"/></DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock FontSize="10" Foreground="#94A3B8">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}Min: {0} / Max: {1}">
                                                                <Binding Path="MinStock"/>
                                                                <Binding Path="MaxStock"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Mức tồn kho" Width="160">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel VerticalAlignment="Center" Margin="15,0">
                                                    <ProgressBar Value="{Binding StockPercentage, Mode=OneWay}" Height="6" Maximum="100" BorderThickness="0" Background="#F1F5F9">
                                                        <ProgressBar.Template>
                                                            <ControlTemplate TargetType="ProgressBar">
                                                                <Grid x:Name="TemplateRoot">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                                                                    <Border x:Name="PART_Indicator" CornerRadius="3" HorizontalAlignment="Left">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="#10B981"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Status}" Value="Hết hàng"><Setter Property="Background" Value="#EF4444"/></DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Status}" Value="Cảnh báo tồn thấp"><Setter Property="Background" Value="#F59E0B"/></DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                    </Border>
                                                                </Grid>
                                                            </ControlTemplate>
                                                        </ProgressBar.Template>
                                                    </ProgressBar>
                                                    <TextBlock Text="{Binding StockPercentage, Mode=OneWay, StringFormat={}{0:F0}%}" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="Đơn vị" Binding="{Binding Unit}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="15,0"/></Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Tổng giá trị" Binding="{Binding TotalValue, Mode=OneWay, StringFormat={}{0:N0} đ}" Width="150">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Padding" Value="15,0"/></Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTemplateColumn Header="Trạng thái" Width="180">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="12" Padding="10,2" HorizontalAlignment="Left" Margin="15,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="An toàn">
                                                                    <Setter Property="Background" Value="#F0FDF4"/><Setter Property="BorderBrush" Value="#DCFCE7"/><Setter Property="BorderThickness" Value="1"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Cảnh báo tồn thấp">
                                                                    <Setter Property="Background" Value="#FFF7ED"/><Setter Property="BorderBrush" Value="#FFEDD5"/><Setter Property="BorderThickness" Value="1"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Hết hàng">
                                                                    <Setter Property="Background" Value="#FEF2F2"/><Setter Property="BorderBrush" Value="#FEE2E2"/><Setter Property="BorderThickness" Value="1"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Status}" FontSize="12">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="An toàn"><Setter Property="Foreground" Value="#16A34A"/></DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Cảnh báo tồn thấp"><Setter Property="Foreground" Value="#EA580C"/></DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Hết hàng"><Setter Property="Foreground" Value="#EF4444"/></DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Tab: Transactions -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="transactions">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Header & Buttons -->
                    <Grid Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Quản lý phiếu nhập/xuất kho" FontSize="18" FontWeight="Bold" Foreground="#1e3a5f"/>
                            <TextBlock Text="Theo dõi và quản lý các giao dịch xuất nhập tồn" FontSize="14" Foreground="#64748B"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,12,0" Command="{Binding CreateInboundCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="20" Height="20" Background="#3B82F6" CornerRadius="10" Margin="0,0,8,0">
                                        <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11h-4v4h-2v-4H7v-2h4V7h2v4h4v2z" 
                                              Fill="White" Width="14" Height="14" Stretch="Uniform"/>
                                    </Border>
                                    <TextBlock Text="Tạo phiếu nhập" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PrimaryButtonStyle}" Background="#EA580C" BorderBrush="#EA580C" Command="{Binding CreateOutboundCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="20" Height="20" Background="#F97316" CornerRadius="10" Margin="0,0,8,0">
                                        <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11h-4v4h-2v-4H7v-2h4V7h2v4h4v2z" 
                                              Fill="White" Width="14" Height="14" Stretch="Uniform"/>
                                    </Border>
                                    <TextBlock Text="Tạo phiếu xuất" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Transaction Summary Cards -->
                    <Grid Margin="0,0,0,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Today Inbound -->
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="48" Height="48" Background="#EFF6FF" CornerRadius="24">
                                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 2.06c-3.13.43-5.63 2.93-6.06 6.06H9.3c.09-1.29.62-2.43 1.5-3.3l-.8-.8zM13 4.06v5.24c.88.87 1.41 2.01 1.5 3.3h4.44c-.43-3.13-2.93-5.63-6.06-6.06l.11-2.48zM19.94 13h-4.44c-.09 1.29-.62 2.43-1.5 3.3l.8.8c3.13-.43 5.63-2.93 6.06-6.06zM11 19.94c-3.13-.43-5.63-2.93-6.06-6.06h4.36c.09 1.29.62 2.43 1.5 3.3l-.8.8z" 
                                          Fill="#2563EB" Width="24" Height="24" Stretch="Uniform"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                    <TextBlock Text="Tổng nhập kho hôm nay" FontSize="14" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TodayInboundQty}" FontSize="28" FontWeight="Bold" Foreground="#1e3a5f"/>
                                        <TextBlock Text=" đơn vị" FontSize="14" Foreground="#64748B" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding TodayInboundCount, StringFormat={}{0} phiếu nhập}" FontSize="12" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Today Outbound -->
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="48" Height="48" Background="#FFF7ED" CornerRadius="24">
                                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zM11 19.94c-3.13-.43-5.63-2.93-6.06-6.06h4.36c.09 1.29.62 2.43 1.5 3.3l-.8.8zM11 4.06v5.24c-.88.87-1.41 2.01-1.5 3.3H5.06c.43-3.13 2.93-5.63 6.06-6.06zM13 4.06c3.13.43 5.63 2.93 6.06 6.06h-4.44c-.09-1.29-.62-2.43-1.5-3.3l.8-.8zM19.94 13c-.43 3.13-2.93 5.63-6.06 6.06l.11-2.48v-5.24c.88.87 1.41 2.01 1.5 3.3h4.33z" 
