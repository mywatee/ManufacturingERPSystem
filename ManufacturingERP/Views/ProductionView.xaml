<UserControl x:Class="ManufacturingERP.Views.ProductionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ManufacturingERP.Views"
             xmlns:viewmodels="clr-namespace:ManufacturingERP.ViewModels"
             xmlns:core="clr-namespace:ManufacturingERP.Core"
             xmlns:dd="urn:gong-wpf-dragdrop"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#F8FAFC">
    
    <UserControl.Resources>
        <!-- Kanban Action Button Style -->
        <Style x:Key="KanbanButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Tag}" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="0,0,6,0" 
                                           Visibility="{TemplateBinding Tag, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}"/>
                                <ContentPresenter/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stat Card Style -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,20,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab Button Style -->
        <Style x:Key="ProductionTabButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="text" 
                                       Text="{TemplateBinding Content}"
                                       FontSize="14" 
                                       FontWeight="Medium"
                                       Foreground="#64748B"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#0F172A"/>
                                <Setter TargetName="text" Property="Foreground" Value="#0F172A"/>
                                <Setter TargetName="text" Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Status Pill Styles -->
        <Style x:Key="StatusPillStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Đang chạy">
                    <Setter Property="Background" Value="#EFF6FF"/>
                    <Setter Property="BorderBrush" Value="#DBEAFE"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Đang sản xuất">
                    <Setter Property="Background" Value="#EFF6FF"/>
                    <Setter Property="BorderBrush" Value="#DBEAFE"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Hoàn thành">
                    <Setter Property="Background" Value="#F0FDF4"/>
                    <Setter Property="BorderBrush" Value="#DCFCE7"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Chờ duyệt">
                    <Setter Property="Background" Value="#FFFBEB"/>
                    <Setter Property="BorderBrush" Value="#FEF3C7"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Tạm dừng">
                    <Setter Property="Background" Value="#FEF2F2"/>
                    <Setter Property="BorderBrush" Value="#FEE2E2"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Đã hủy">
                    <Setter Property="Background" Value="#F1F5F9"/>
                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Đang chạy">
                    <Setter Property="Foreground" Value="#2563EB"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Đang sản xuất">
                    <Setter Property="Foreground" Value="#2563EB"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Hoàn thành">
                    <Setter Property="Foreground" Value="#16A34A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Chờ duyệt">
                    <Setter Property="Foreground" Value="#D97706"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Tạm dừng">
                    <Setter Property="Foreground" Value="#DC2626"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Đã hủy">
                    <Setter Property="Foreground" Value="#94A3B8"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Custom ProgressBar Style (Matching Figma) -->
        <Style x:Key="FigmaProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border x:Name="PART_Track" Background="{TemplateBinding Background}" CornerRadius="3"/>
                            <Grid x:Name="PART_Indicator" HorizontalAlignment="Left">
                                <Border Background="{TemplateBinding Foreground}" CornerRadius="3"/>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Kanban Card Template -->
        <DataTemplate x:Key="KanbanCardTemplate" DataType="{x:Type viewmodels:KanbanItem}">
            <Border x:Name="CardBorder" Background="White" CornerRadius="12" Padding="16" Margin="4,4,4,16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect x:Name="CardShadow" BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="Black"/>
                </Border.Effect>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.15" />
                                <DoubleAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.15" />
                                <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="Opacity" To="0.12" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15" />
                                <DoubleAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15" />
                                <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="Opacity" To="0.05" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Border.InputBindings>
                    <MouseBinding Gesture="LeftDoubleClick" Command="{Binding DataContext.ViewOrderDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                </Border.InputBindings>

                <StackPanel>
                    <!-- Grip and Header -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Grip Icon -->
                        <TextBlock Grid.Column="0" Text="&#xE700;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource MutedTextBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" ToolTip="Kéo thả thẻ này"/>
                        
                        <TextBlock Grid.Column="1" Text="{Binding OrderId}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" TextWrapping="Wrap"/>
                        
                        <Border Grid.Column="2" Background="{StaticResource ErrorBackgroundBrush}" CornerRadius="4" Padding="8,4" 
                                Visibility="{Binding IsOverdue, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource ErrorBrush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Trễ hạn" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource ErrorBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Machine Info -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="&#xE7B9;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource MutedTextBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding Title}" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Progress Section -->
                    <StackPanel Margin="0,0,0,12">
                        <Grid Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D5;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource MutedTextBrush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Tiến độ" FontSize="12" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Progress, Mode=OneWay, StringFormat={}{0}%}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                        <ProgressBar Value="{Binding Progress, Mode=OneWay}" Style="{StaticResource FigmaProgressBarStyle}"/>
                    </StackPanel>

                    <!-- Expander for Stats -->
                    <Expander Header="Chi tiết sản lượng" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,12" BorderThickness="0" Background="Transparent">
                        <StackPanel Margin="0,8,0,0">
                            <UniformGrid Columns="3" Margin="0,0,0,8">
                                <!-- Chìm xuống bằng cách bỏ màu nền nổi bật -->
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding PassedQty}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Đạt" FontSize="10" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding TargetQty}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Mục tiêu" FontSize="10" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding FailedQty}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource ErrorBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Lỗi" FontSize="10" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </UniformGrid>
                            <!-- Defect Rate & Dates -->
                            <Grid Margin="0,0,0,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Tỷ lệ lỗi:" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding DefectRate}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ErrorBrush}"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding StartDate}" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                                <TextBlock Text=" - " FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                                <TextBlock Text="{Binding EndDate}" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <!-- Action Buttons -->
                    <Border BorderBrush="{StaticResource MutedBackgroundBrush}" BorderThickness="0,1,0,0" Padding="0,12,0,0"
                            Visibility="{Binding DataContext.CanEditProduction, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <!-- Pending / Chờ duyệt - Bắt đầu button -->
                            <Button Content="Bắt đầu" 
                                    Command="{Binding DataContext.StartOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Background="{StaticResource PrimaryBrush}" Foreground="White" Tag="&#xE768;">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource KanbanButtonStyle}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Chờ duyệt">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- In Production / Đang sản xuất - Tạm dừng + Hoàn thành buttons -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Đang sản xuất">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Tạm dừng" Margin="0,0,4,0" 
                                        Command="{Binding DataContext.PauseOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Background="White" Foreground="{StaticResource SecondaryTextBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Tag="&#xE769;" Style="{StaticResource KanbanButtonStyle}"/>
                                <Button Grid.Column="1" Content="Hoàn thành" Margin="4,0,0,0"
                                        Command="{Binding DataContext.CompleteOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Background="{StaticResource SuccessBrush}" Foreground="White" Style="{StaticResource KanbanButtonStyle}"/>
                            </Grid>

                            <!-- Paused / Tạm dừng - Tiếp tục button -->
                            <Button Content="Tiếp tục" 
                                    Command="{Binding DataContext.StartOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Background="{StaticResource PrimaryBrush}" Foreground="White" Tag="&#xE768;">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource KanbanButtonStyle}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Tạm dừng">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>

                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Tabs -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="22" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="#0F172A"/>
                    <TextBlock Text="Quản lý sản xuất" FontSize="26" FontWeight="Bold" Foreground="#1E1B4B" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Lập kế hoạch, theo dõi tiến độ và kiểm soát chất lượng sản xuất" FontSize="14" Foreground="#64748B"/>
            </StackPanel>

            <!-- Tabs Navigation -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,25" Background="Transparent">
                <RadioButton Content="Bảng điều khiển" IsChecked="{Binding ActiveTabIndex, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=0}" Style="{StaticResource ProductionTabButtonStyle}"/>
                <RadioButton Content="Lệnh sản xuất" IsChecked="{Binding ActiveTabIndex, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=1}" Style="{StaticResource ProductionTabButtonStyle}"/>
                <RadioButton Content="Nhật ký tiến độ" IsChecked="{Binding ActiveTabIndex, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=2}" Style="{StaticResource ProductionTabButtonStyle}"/>
            </StackPanel>

            <!-- Main Content ViewSwitcher -->
            <Grid Grid.Row="2">
                <!-- Tab 0: Dashboard / Kanban -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTabIndex}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Bảng điều khiển xưởng" FontSize="18" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,4"/>
                        <TextBlock Text="Kéo thả thẻ lệnh sản xuất để thay đổi trạng thái" FontSize="13" Foreground="#64748B"/>
                    </StackPanel>
                    <Grid Grid.Row="1" MinHeight="600">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Margin="0,0,12,0">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#F59E0B" CornerRadius="8,8,0,0" Padding="16,12"><TextBlock Text="Chờ duyệt" Foreground="White" FontWeight="SemiBold"/></Border>
                            <Border Grid.Row="1" Background="#F9FAFB" BorderBrush="#E2E8F0" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8">
                                <ItemsControl ItemsSource="{Binding PendingOrders}" ItemTemplate="{StaticResource KanbanCardTemplate}" Padding="12"
                                              Background="Transparent" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                              Tag="Chờ duyệt" dd:DragDrop.IsDragSource="True" dd:DragDrop.IsDropTarget="True" dd:DragDrop.DropHandler="{Binding}"/>
                            </Border>
                        </Grid>
                        <Grid Grid.Column="1" Margin="0,0,12,0">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#2563EB" CornerRadius="8,8,0,0" Padding="16,12"><TextBlock Text="Đang sản xuất" Foreground="White" FontWeight="SemiBold"/></Border>
                            <Border Grid.Row="1" Background="#F9FAFB" BorderBrush="#E2E8F0" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8">
                                <ItemsControl ItemsSource="{Binding InProductionOrders}" ItemTemplate="{StaticResource KanbanCardTemplate}" Padding="12"
                                              Background="Transparent" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                              Tag="Đang sản xuất" dd:DragDrop.IsDragSource="True" dd:DragDrop.IsDropTarget="True" dd:DragDrop.DropHandler="{Binding}"/>
                            </Border>
                        </Grid>
                        <Grid Grid.Column="2" Margin="0,0,12,0">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#EF4444" CornerRadius="8,8,0,0" Padding="16,12"><TextBlock Text="Tạm dừng" Foreground="White" FontWeight="SemiBold"/></Border>
                            <Border Grid.Row="1" Background="#F9FAFB" BorderBrush="#E2E8F0" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8">
                                <ItemsControl ItemsSource="{Binding PausedOrders}" ItemTemplate="{StaticResource KanbanCardTemplate}" Padding="12"
                                              Background="Transparent" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                              Tag="Tạm dừng" dd:DragDrop.IsDragSource="True" dd:DragDrop.IsDropTarget="True" dd:DragDrop.DropHandler="{Binding}"/>
                            </Border>
                        </Grid>
                        <Grid Grid.Column="3" Margin="0,0,12,0">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#16A34A" CornerRadius="8,8,0,0" Padding="16,12"><TextBlock Text="Hoàn thành" Foreground="White" FontWeight="SemiBold"/></Border>
                            <Border Grid.Row="1" Background="#F9FAFB" BorderBrush="#E2E8F0" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8">
                                <ItemsControl ItemsSource="{Binding CompletedOrders}" ItemTemplate="{StaticResource KanbanCardTemplate}" Padding="12"
                                              Background="Transparent" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                               Tag="Hoàn thành" dd:DragDrop.IsDragSource="True" dd:DragDrop.IsDropTarget="True" dd:DragDrop.DropHandler="{Binding}"/>
                            </Border>
                        </Grid>
                        <Grid Grid.Column="4">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#64748B" CornerRadius="8,8,0,0" Padding="16,12"><TextBlock Text="Đã hủy" Foreground="White" FontWeight="SemiBold"/></Border>
                            <Border Grid.Row="1" Background="#F9FAFB" BorderBrush="#E2E8F0" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8">
                                <ItemsControl ItemsSource="{Binding CancelledOrders}" ItemTemplate="{StaticResource KanbanCardTemplate}" Padding="12"
                                              Background="Transparent" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                               Tag="Đã hủy" dd:DragDrop.IsDragSource="True" dd:DragDrop.IsDropTarget="True" dd:DragDrop.DropHandler="{Binding}"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- Tab 1: Work Orders List (High-Fidelity Figma Design) -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTabIndex}" Value="1">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        
                        <!-- Header Actions -->
                        <Grid Grid.Row="0" Margin="0,0,0,25">
                            <StackPanel>
                                <TextBlock Text="Danh sách lệnh sản xuất" FontSize="20" FontWeight="Bold" Foreground="#1E1B4B"/>
                                <TextBlock Text="Quản lý, theo dõi và cập nhật trạng thái các lệnh sản xuất" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0" Padding="15,0"
                                        Command="{Binding ToggleAdvancedSearchCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"/>
                                        <TextBlock Text="Tìm kiếm nâng cao" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Background="#2563EB" Foreground="White" FontSize="13" FontWeight="SemiBold"
                                        Height="42" Padding="20,0" Command="{Binding AddWorkOrderCommand}"
                                        Visibility="{Binding CanAddProduction, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <StackPanel Orientation="Horizontal" Margin="15,0">
                                                    <TextBlock Text="&#xE109;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12" Foreground="White"/>
                                                    <TextBlock Text="Tạo lệnh mới" VerticalAlignment="Center" Foreground="White"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Filter & Search Bar -->
                            <Border Grid.Row="0" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,20" Padding="15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="#F1F5F9" CornerRadius="8" Width="350" Padding="15,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE11A;" FontFamily="Segoe MDL2 Assets" Foreground="#94A3B8" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" FontSize="13" Foreground="#475569" 
                                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                                            </Grid>
                                        </Border>
                                        
                                        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="20,0" Background="#E2E8F0"/>
                                        
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Trạng thái:" VerticalAlignment="Center" Foreground="#64748B" Margin="0,0,12,0" FontSize="13"/>
                                            <ComboBox Width="150" Height="38" VerticalContentAlignment="Center" BorderThickness="1" BorderBrush="#E2E8F0" Padding="10,0"
                                                      SelectedValue="{Binding SelectedStatusFilter}" SelectedValuePath="Content">
                                                <ComboBoxItem Content="Tất cả" IsSelected="True"/>
                                                <ComboBoxItem Content="Chờ duyệt"/>
                                                <ComboBoxItem Content="Đang sản xuất"/>
                                                <ComboBoxItem Content="Tạm dừng"/>
                                                <ComboBoxItem Content="Hoàn thành"/>
                                                <ComboBoxItem Content="Đã hủy"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="Làm mới" Style="{StaticResource SecondaryButtonStyle}" Height="38" Padding="15,0" Margin="0,0,12,0" Command="{Binding RefreshCommand}"/>
                                        <Button Content="Nhập/Xuất báo cáo" Style="{StaticResource SecondaryButtonStyle}" Height="38" Padding="15,0"
                                                Command="{Binding ExportToExcelCommand}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Advanced Filter Panel -->
                            <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,20" Padding="15"
                                    Visibility="{Binding IsAdvancedFilterVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Từ ngày:" VerticalAlignment="Center" Foreground="#64748B" Margin="0,0,8,0" FontSize="13"/>
                                    <DatePicker Grid.Column="1" Width="140" Height="32" SelectedDate="{Binding FilterFromDate}" BorderBrush="#E2E8F0"/>
                                    <TextBlock Grid.Column="2" Text="Đến ngày:" VerticalAlignment="Center" Foreground="#64748B" Margin="15,0,8,0" FontSize="13"/>
                                    <DatePicker Grid.Column="3" Width="140" Height="32" SelectedDate="{Binding FilterToDate}" BorderBrush="#E2E8F0"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
                                <DataGrid ItemsSource="{Binding WorkOrders}" AutoGenerateColumns="False" IsReadOnly="True" 
                                          BorderThickness="0" Background="Transparent" HeadersVisibility="Column" 
                                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                                          RowHeight="72" SelectionUnit="FullRow" SelectionMode="Single">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F8FAFC"/>
                                            <Setter Property="Foreground" Value="#64748B"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Padding" Value="15,12"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                        </Style>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F8FAFC"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#EFF6FF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="#1D4ED8"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <!-- Mã lệnh -->
                                        <DataGridTextColumn Header="MÃ LỆNH" Binding="{Binding Id}" Width="1.5*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Margin" Value="15,0"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#2563EB"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
    
                                        <!-- Sản phẩm -->
                                        <DataGridTemplateColumn Header="SẢN PHẨM" Width="3*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel VerticalAlignment="Center" Margin="15,0">
                                                        <TextBlock Text="{Binding Product}" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
    
                                        <!-- Số lượng -->
                                        <DataGridTemplateColumn Header="SỐ LƯỢNG" Width="1*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding TargetQty}" FontSize="15" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Sản phẩm" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
    
                                        <!-- Tiến độ -->
                                        <DataGridTemplateColumn Header="TIẾN ĐỘ" Width="1.5*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel VerticalAlignment="Center" Margin="15,0">
                                                        <Grid Margin="0,0,0,6">
                                                            <TextBlock Text="{Binding PassedQty, StringFormat={}Đã đạt: {0}}" FontSize="11" Foreground="#16A34A" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding Progress, StringFormat={}{0}%}" FontSize="11" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Right"/>
                                                        </Grid>
                                                        <ProgressBar Value="{Binding Progress, Mode=OneWay}" Style="{StaticResource FigmaProgressBarStyle}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
    
                                        <!-- Trạng thái -->
                                        <DataGridTemplateColumn Header="TRẠNG THÁI" Width="1.2*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource StatusPillStyle}">
                                                        <TextBlock Text="{Binding Status}" Style="{StaticResource StatusTextStyle}"/>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
    
                                        <!-- Cảnh báo -->
                                        <DataGridTemplateColumn Header="CẢNH BÁO" Width="1*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                                                            Visibility="{Binding IsOverdue, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="#F59E0B" FontSize="16" ToolTip="Lệnh đã quá hạn"/>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Thao tác -->
                                        <DataGridTemplateColumn Header="THAO TÁC" Width="1*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Button Style="{StaticResource IconButtonStyle}" Padding="6" ToolTip="Xem chi tiết"
                                                                Command="{Binding DataContext.ViewOrderDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}">
                                                            <TextBlock Text="&#xE890;" FontFamily="Segoe MDL2 Assets" Foreground="#2563EB" FontSize="16" />
                                                        </Button>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- Tab 2: Progress Log (Renumbered) -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTabIndex}" Value="2">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Page Header -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,25">
                            <TextBlock Text="Nhật ký tiến độ sản xuất" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                            <TextBlock Text="Theo dõi lịch sử hoạt động và cập nhật từ xưởng sản xuất" Foreground="#64748B" Margin="0,4,0,0" FontSize="13"/>
                        </StackPanel>

                        <!-- Filter Bar -->
                        <Grid Grid.Row="1" Margin="0,0,0,25">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Background="#F1F5F9" CornerRadius="8" Padding="15,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE11A;" FontFamily="Segoe MDL2 Assets" Foreground="#94A3B8" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" FontSize="13" Foreground="#475569"
                                             Text="{Binding ActivityLogSearchText, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="0" Margin="15,0,0,0" Width="150">
                                <ComboBox Background="Transparent" BorderThickness="0" Height="38" VerticalContentAlignment="Center" Padding="10,0"
                                          SelectedValue="{Binding ActivityLogSelectedStatus}" SelectedValuePath="Content">
                                    <ComboBoxItem Content="Tất cả" IsSelected="True"/>
                                    <ComboBoxItem Content="Sản xuất"/>
                                    <ComboBoxItem Content="Kiểm tra chất lượng (QC)"/>
                                </ComboBox>
                            </Border>
                        </Grid>

                        <!-- Timeline Content -->
                        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding ActivityLogs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,25">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- LEFT: Time -->
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,15,0,0">
                                                <Border Background="#EFF6FF" CornerRadius="20" Width="40" Height="40" Margin="0,0,0,10">
                                                    <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" Foreground="#2563EB" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{Binding Time}" FontSize="12" Foreground="#64748B" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                            </StackPanel>

                                            <!-- RIGHT: Activity Card -->
                                            <Border Grid.Column="1" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="20">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.04" Color="Black"/>
                                                </Border.Effect>
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,15">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border CornerRadius="15" Padding="12,4" Margin="0,0,15,0">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Tiến hành">
                                                                <Setter Property="Background" Value="#E0F2FE"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Tiến độ">
                                                                <Setter Property="Background" Value="#E0F2FE"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Bắt đầu">
                                                                <Setter Property="Background" Value="#E0F2FE"/>
                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}" Value="Hoàn thành">
                                                                                <Setter Property="Background" Value="#DCFCE7"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}" Value="Tạm dừng">
                                                                                <Setter Property="Background" Value="#FEF2F2"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Ellipse Width="6" Height="6" Margin="0,0,8,0" VerticalAlignment="Center">
                                                                        <Ellipse.Style>
                                                                            <Style TargetType="Ellipse">
                                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Tiến hành">
                                                                            <Setter Property="Fill" Value="#0EA5E9"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Tiến độ">
                                                                            <Setter Property="Fill" Value="#0EA5E9"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Bắt đầu">
                                                                            <Setter Property="Fill" Value="#3B82F6"/>
                                                                        </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Status}" Value="Hoàn thành">
                                                                                        <Setter Property="Fill" Value="#22C55E"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Status}" Value="Tạm dừng">
                                                                                        <Setter Property="Fill" Value="#EF4444"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Ellipse.Style>
                                                                    </Ellipse>
                                                                    <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="Bold">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Status}" Value="Tiến hành">
                                                                                        <Setter Property="Foreground" Value="#0369A1"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Status}" Value="Hoàn thành">
                                                                                        <Setter Property="Foreground" Value="#15803D"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </Border>
                                                            <TextBlock Text="{Binding OrderId}" FontSize="15" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                            <TextBlock Text="{Binding Date}" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <TextBlock Text="{Binding Product}" FontSize="14" Foreground="#475569" Margin="0,0,0,20"/>

                                                    <Grid Margin="0,0,0,20">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="1.2*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="Công đoạn" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="&#xE15E;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Stage}" FontSize="13" FontWeight="Bold" Foreground="#334155" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="Người thực hiện" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Operator}" FontSize="13" FontWeight="Bold" Foreground="#334155" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="Sản lượng" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Quantity}" FontSize="13" FontWeight="Bold" Foreground="#16A34A" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Border Background="#FFFBEB" BorderBrush="#FEF3C7" BorderThickness="1" CornerRadius="8" Padding="15,10">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" Foreground="#D97706" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                            <TextBlock Text="{Binding Notes, StringFormat={}Ghi chú: {0}}" FontSize="13" Foreground="#92400E" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
