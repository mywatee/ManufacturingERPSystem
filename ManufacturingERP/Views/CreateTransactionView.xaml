<UserControl x:Class="ManufacturingERP.Views.CreateTransactionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ManufacturingERP.Views"
             xmlns:core="clr-namespace:ManufacturingERP.Core"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="#F8FAFC">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <core:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <core:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>

        
        <Style x:Key="ModernCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.04" Color="#1E293B"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ModernTextBoxWithPlaceholder" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <Grid>
                                <TextBlock Text="{TemplateBinding Tag}" Margin="{TemplateBinding Padding}" Foreground="#94A3B8" IsHitTestVisible="False" VerticalAlignment="Center" FontSize="{TemplateBinding FontSize}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="12"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="ModernDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
            <StackPanel Margin="30,20,30,40" Background="Transparent">
                
                <!-- Header -->
                <Grid Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <!-- Left Column (Back button or Spacer) -->
                        <ColumnDefinition>
                            <ColumnDefinition.Style>
                                <Style TargetType="ColumnDefinition">
                                    <Setter Property="Width" Value="Auto"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                            <Setter Property="Width" Value="*"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ColumnDefinition.Style>
                        </ColumnDefinition>
                        
                        <!-- Center Column (Title) -->
                        <ColumnDefinition Width="4*"/>
                        
                        <!-- Right Column (Action Buttons or Spacer) -->
                        <ColumnDefinition>
                            <ColumnDefinition.Style>
                                <Style TargetType="ColumnDefinition">
                                    <Setter Property="Width" Value="350"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                            <Setter Property="Width" Value="*"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ColumnDefinition.Style>
                        </ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Command="{Binding CancelCommand}" Margin="0,0,20,0"
                            Background="Transparent" BorderThickness="0" Padding="0" HorizontalAlignment="Left" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32" Height="32" Background="#F1F5F9" CornerRadius="16" Margin="0,0,12,0">
                                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Quay lại Quản lý kho" Foreground="#64748B" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Grid.Column="1" Text="{Binding PageTitle}" FontSize="32" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center"/>
                    
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Lưu phiếu kho" Command="{Binding SaveCommand}" Style="{StaticResource ActionButtonStyle}" 
                                Visibility="{Binding IsEditable, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Background="#2563EB" Foreground="White" Width="180"/>
                    </StackPanel>
                </Grid>
                <Grid HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <!-- Left Spacer (ReadOnly only) -->
                        <ColumnDefinition>
                            <ColumnDefinition.Style>
                                <Style TargetType="ColumnDefinition">
                                    <Setter Property="Width" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                            <Setter Property="Width" Value="*"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ColumnDefinition.Style>
                        </ColumnDefinition>

                        <!-- Main Content -->
                        <ColumnDefinition>
                            <ColumnDefinition.Style>
                                <Style TargetType="ColumnDefinition">
                                    <Setter Property="Width" Value="*"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                            <Setter Property="Width" Value="4*"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ColumnDefinition.Style>
                        </ColumnDefinition>
                        
                        <!-- Right Sidebar or Spacer -->
                        <ColumnDefinition>
                            <ColumnDefinition.Style>
                                <Style TargetType="ColumnDefinition">
                                    <Setter Property="Width" Value="350"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                            <Setter Property="Width" Value="*"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ColumnDefinition.Style>
                        </ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1">
                        <!-- CARD 1: GENERAL INFO -->
                        <Border Style="{StaticResource ModernCardStyle}" Padding="30" Margin="0,0,0,20" IsEnabled="{Binding IsEditable}">
                            <StackPanel>
                                <TextBlock Text="THÔNG TIN CHUNG" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,15"/>
                                
                                <!-- Hàng 1: Loại giao dịch, Kho nguồn, Kho đích -->
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Loại giao dịch" Style="{StaticResource FormLabelStyle}"/>
                                        <ComboBox SelectedItem="{Binding TransactionType, Mode=TwoWay}" ItemsSource="{Binding TransactionTypes}" Style="{StaticResource ModernComboBoxStyle}" Height="45" FontSize="14"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="2">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource FormLabelStyle}">
                                                    <Setter Property="Text" Value="Nhà kho"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTransferType}" Value="True">
                                                            <Setter Property="Text" Value="Kho nguồn (Xuất)"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <ComboBox SelectedItem="{Binding SelectedWarehouse, Mode=TwoWay}" ItemsSource="{Binding Warehouses}" DisplayMemberPath="WarehouseName" Style="{StaticResource ModernComboBoxStyle}" Height="45" FontSize="14"/>
                                    </StackPanel>

                                    <!-- Kho đích (Chỉ hiện khi Chuyển kho) hoặc Ngày thực hiện (Khi Nhập/Xuất) -->
                                    <StackPanel Grid.Column="4">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTransferType}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Kho đích (Nhập)" Style="{StaticResource FormLabelStyle}"/>
                                        <ComboBox SelectedItem="{Binding DestinationWarehouse, Mode=TwoWay}" ItemsSource="{Binding Warehouses}" DisplayMemberPath="WarehouseName" Style="{StaticResource ModernComboBoxStyle}" Height="45" FontSize="14"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTransferType}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Ngày thực hiện" Style="{StaticResource FormLabelStyle}"/>
                                        <DatePicker SelectedDate="{Binding TransactionDate, Mode=TwoWay}" Height="45" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Hàng 2: Chứng từ, Đối tác/Ngày chuyển kho -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Chứng từ tham chiếu" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding ReferenceCode, Mode=TwoWay}" Style="{StaticResource ModernTextBoxWithPlaceholder}" Tag="Số hóa đơn, số PO..." Height="45" FontSize="14"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowPartner}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Đối tác / Nhà cung cấp" Style="{StaticResource FormLabelStyle}"/>
                                        <ComboBox ItemsSource="{Binding FilteredPartners}" 
                                                  SelectedItem="{Binding SelectedPartner, Mode=TwoWay}"
                                                  Text="{Binding PartnerSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayMemberPath="PartnerName"
                                                  IsEditable="True"
                                                  IsTextSearchEnabled="False"
                                                  Style="{StaticResource ModernComboBoxStyle}" 
                                                  Height="45" FontSize="14"/>
                                        <CheckBox IsChecked="{Binding AutoCreateInvoice}" Content="Tự động tạo hóa đơn tài chính" 
                                                  Margin="0,10,0,0" Foreground="#2563EB" FontWeight="SemiBold"
                                                  Visibility="{Binding ShowPartner, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTransferType}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Ngày chuyển kho" Style="{StaticResource FormLabelStyle}"/>
                                        <DatePicker SelectedDate="{Binding TransactionDate, Mode=TwoWay}" Height="45" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- CARD 2: ITEM LIST -->
                        <Border Style="{StaticResource ModernCardStyle}" Padding="30" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="DANH SÁCH VẬT TƯ" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,15"/>
                                
                                <!-- Add Item Row -->
                                <Border Background="#F8FAFC" CornerRadius="12" Padding="20" Margin="0,0,0,20" BorderBrush="#E2E8F0" BorderThickness="1"
                                        Visibility="{Binding IsEditable, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Chọn vật tư *" Style="{StaticResource FormLabelStyle}"/>
                                            <ComboBox ItemsSource="{Binding FilteredMaterials}" 
                                                      SelectedItem="{Binding NewItemMaterial, Mode=TwoWay}"
                                                      Text="{Binding MaterialSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      DisplayMemberPath="MaterialName"
                                                      IsEditable="True"
                                                      IsTextSearchEnabled="False"
                                                      Style="{StaticResource ModernComboBoxStyle}" 
                                                      Height="45" FontSize="14"/>

                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Số lượng *" Style="{StaticResource FormLabelStyle}"/>
                                            <Grid>
                                                <TextBox Text="{Binding NewItemQuantity, Mode=TwoWay}" Style="{StaticResource ModernTextBoxWithPlaceholder}" Tag="0" Height="45" FontSize="14"/>
                                                <TextBlock Text="{Binding NewItemUnit}" Foreground="#64748B" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,45,0" IsHitTestVisible="False"/>
                                            </Grid>
                                        </StackPanel>

                                        <Button Grid.Column="4" Content="Thêm" Command="{Binding AddItemCommand}" Style="{StaticResource ActionButtonStyle}" 
                                                Background="#10B981" Foreground="White" VerticalAlignment="Bottom"/>
                                    </Grid>
                                </Border>

                                <!-- Items List Header -->
                                <Border Background="#F1F5F9" CornerRadius="8" Padding="15,10" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/> <!-- Mã vật tư -->
                                            <ColumnDefinition Width="2*"/>   <!-- Tên vật tư -->
                                            <ColumnDefinition Width="120"/>  <!-- Số lượng -->
                                            <ColumnDefinition Width="80">   <!-- Action -->
                                                <ColumnDefinition.Style>
                                                    <Style TargetType="ColumnDefinition">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                                                <Setter Property="Width" Value="0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ColumnDefinition.Style>
                                            </ColumnDefinition>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Mã vật tư" FontWeight="SemiBold" Foreground="#475569" Grid.Column="0"/>
                                        <TextBlock Text="Tên vật tư" FontWeight="SemiBold" Foreground="#475569" Grid.Column="1"/>
                                        <TextBlock Text="Số lượng" FontWeight="SemiBold" Foreground="#475569" Grid.Column="2" TextAlignment="Right" Margin="0,0,15,0"/>
                                        <TextBlock Text="Thao tác" FontWeight="SemiBold" Foreground="#475569" Grid.Column="3" TextAlignment="Center" 
                                                   Visibility="{Binding IsEditable, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </Grid>
                                </Border>

                                <ItemsControl ItemsSource="{Binding TransactionItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="15,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="80">
                                                            <ColumnDefinition.Style>
                                                                <Style TargetType="ColumnDefinition">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                                            <Setter Property="Width" Value="0"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ColumnDefinition.Style>
                                                        </ColumnDefinition>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <TextBlock Text="{Binding MaterialCode}" VerticalAlignment="Center" Foreground="#1E293B"/>
                                                    <TextBlock Text="{Binding MaterialName}" Grid.Column="1" VerticalAlignment="Center" Foreground="#1E293B" FontWeight="Medium"/>
                                                    
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0">
                                                        <TextBlock Text="{Binding Quantity}" FontWeight="Bold" Foreground="#2563EB"/>
                                                        <TextBlock Text="{Binding Unit}" Foreground="#64748B" Margin="5,0,0,0" FontSize="11"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center"
                                                                Visibility="{Binding DataContext.IsEditable, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Button Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="5" Margin="0,0,5,0">
                                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" Foreground="#3B82F6" FontSize="14"/>
                                                        </Button>
                                                        <Button Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="5">
                                                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" Foreground="#EF4444" FontSize="14"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- CARD 3: NOTES -->
                        <Border Style="{StaticResource ModernCardStyle}" Padding="30" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="GHI CHÚ &amp; DIỄN GIẢI" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,15"/>
                                <TextBox Text="{Binding Notes, Mode=TwoWay}" Style="{StaticResource ModernTextBoxWithPlaceholder}" 
                                         IsEnabled="{Binding IsEditable}"
                                         Tag="Lý do nhập/xuất, tình trạng hàng hóa..." 
                                         Height="80" FontSize="14" AcceptsReturn="True" TextWrapping="Wrap" Padding="16,12"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- SIDEBAR: Current Status -->
                    <StackPanel Grid.Column="2" Visibility="{Binding IsEditable, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border Style="{StaticResource ModernCardStyle}" Padding="24" Background="#F8FAFC">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <Border Width="24" Height="24" Background="#3B82F6" CornerRadius="12" Margin="0,0,10,0">
                                        <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                                    </Border>
                                    <TextBlock Text="THÔNG TIN HỖ TRỢ" FontSize="13" FontWeight="Bold" Foreground="#1E40AF"/>
                                </StackPanel>

                                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20" BorderBrush="#E2E8F0" BorderThickness="1">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock FontSize="11" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,5">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Tồn kho hiện tại"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTransferType}" Value="True">
                                                            <Setter Property="Text" Value="Tồn kho tại KHO NGUỒN"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding NewItemCurrentStock}" FontSize="32" FontWeight="Bold" Foreground="#1E293B"/>
                                            <TextBlock Text="{Binding NewItemUnit}" FontSize="14" Foreground="#64748B" VerticalAlignment="Bottom" Margin="8,0,0,6"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20" BorderBrush="#E2E8F0" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTransferType}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Tồn kho tại KHO ĐÍCH" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding NewItemDestStock}" FontSize="32" FontWeight="Bold" Foreground="#1E293B"/>
                                            <TextBlock Text="{Binding NewItemUnit}" FontSize="14" Foreground="#64748B" VerticalAlignment="Bottom" Margin="8,0,0,6"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="HƯỚNG DẪN" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,10"/>
                                <TextBlock Text="• Nhập kho: Thêm vật tư và số lượng vào danh sách, sau đó nhấn 'Lưu phiếu kho'." FontSize="11" Foreground="#64748B" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <TextBlock Text="• Xuất kho: Hệ thống sẽ kiểm tra tồn kho tại nhà kho đã chọn cho từng mặt hàng." FontSize="11" Foreground="#64748B" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <TextBlock Text="• Lưu ý: Một phiếu có thể chứa nhiều mặt hàng để tối ưu quy trình." FontSize="11" Foreground="#64748B" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
