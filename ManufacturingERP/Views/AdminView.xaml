<UserControl x:Class="ManufacturingERP.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ManufacturingERP.Views"
             xmlns:vm="clr-namespace:ManufacturingERP.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=vm:AdminViewModel, IsDesignTimeCreatable=False}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Background="{StaticResource MainBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <!-- Page Info Section -->
        <StackPanel Margin="30,25,30,15">
            <TextBlock Text="Quản trị Hệ thống" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
            <TextBlock Text="Quản lý người dùng, phân quyền và cấu hình hệ thống" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Tab Header Section -->
        <Border Grid.Row="1" Background="White" Margin="30,5,30,20" CornerRadius="12">
            <StackPanel Orientation="Horizontal" Margin="5,0">
                <RadioButton Content="Quản lý Người dùng" 
                             Tag="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"
                             Style="{StaticResource AdminTabButtonStyle}"
                             IsChecked="{Binding ActiveTab, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=users}"
                             Command="{Binding ChangeTabCommand}" CommandParameter="users"/>
                <RadioButton Content="Phân quyền" 
                             Tag="M12 2L4 5v6.09c0 5.05 3.41 9.76 8 10.91 4.59-1.15 8-5.86 8-10.91V5l-8-3z"
                             Style="{StaticResource AdminTabButtonStyle}"
                             IsChecked="{Binding ActiveTab, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=roles}"
                             Command="{Binding ChangeTabCommand}" CommandParameter="roles"/>
                <RadioButton Content="Nhật ký Hệ thống" 
                             Tag="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"
                             Style="{StaticResource AdminTabButtonStyle}"
                             IsChecked="{Binding ActiveTab, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=logs}"
                             Command="{Binding ChangeTabCommand}" CommandParameter="logs"/>
                <RadioButton Content="Thiết lập" 
                             Tag="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"
                             Style="{StaticResource AdminTabButtonStyle}"
                             IsChecked="{Binding ActiveTab, Converter={StaticResource StringToBooleanConverter}, ConverterParameter=settings}"
                             Command="{Binding ChangeTabCommand}" CommandParameter="settings"/>
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="2" Margin="30,0,30,30">
            <!-- User Management Tab Content -->
            <Grid x:Name="UserTabContent">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveTab}" Value="users">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Toolbar -->
                <Grid Margin="0,0,0,25">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Quản lý Tài khoản Người dùng" FontSize="19" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Quản lý danh sách người dùng và phân quyền truy cập hệ thống" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    
                    <Button Content="+ Thêm người dùng mới" 
                            Style="{StaticResource PrimaryButtonStyle}" 
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Padding="24,12"
                            FontSize="13" FontWeight="SemiBold"/>
                </Grid>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                    <DataGrid ItemsSource="{Binding Users}" Style="{StaticResource ModernDataGridStyle}" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã NV" Binding="{Binding UserId, StringFormat=NV-{0:D3}}" Width="100"/>
                            <DataGridTextColumn Header="Tên đăng nhập" Binding="{Binding Username}" Width="150"/>
                            <DataGridTextColumn Header="Họ tên" Binding="{Binding FullName}" Width="180"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                            <DataGridTextColumn Header="Số điện thoại" Binding="{Binding Phone}" Width="150"/>
                            
                            <DataGridTemplateColumn Header="Vai trò" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border x:Name="badge" Style="{StaticResource RoleOperatorBadgeStyle}" Padding="10,4" CornerRadius="6" HorizontalAlignment="Left">
                                            <TextBlock x:Name="roleText" Text="Nhân viên vận hành"/>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding UserId}" Value="1">
                                                <Setter TargetName="badge" Property="Style" Value="{StaticResource RoleAdminBadgeStyle}"/>
                                                <Setter TargetName="roleText" Property="Text" Value="Admin"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding UserId}" Value="45">
                                                <Setter TargetName="badge" Property="Style" Value="{StaticResource RoleQCBadgeStyle}"/>
                                                <Setter TargetName="roleText" Property="Text" Value="QC"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding UserId}" Value="89">
                                                <Setter TargetName="badge" Property="Style" Value="{StaticResource RoleAccountingBadgeStyle}"/>
                                                <Setter TargetName="roleText" Property="Text" Value="Kế toán"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Trạng thái" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border x:Name="statusBadge" Style="{StaticResource SuccessBadgeStyle}" Padding="10,4" CornerRadius="12" HorizontalAlignment="Left" Margin="0,0,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <Path x:Name="statusIcon" Data="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2z" Fill="{Binding Foreground, ElementName=statusText}" Width="10" Height="10" Stretch="Uniform" Margin="0,0,6,0"/>
                                                <TextBlock x:Name="statusText" Text="Hoạt động" FontSize="11" FontWeight="Medium"/>
                                            </StackPanel>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                <Setter TargetName="statusBadge" Property="Style" Value="{StaticResource UrgentBadgeStyle}"/>
                                                <Setter TargetName="statusText" Property="Text" Value="Khóa"/>
                                                <Setter TargetName="statusIcon" Property="Data" Value="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Thao tác" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,0,0,0">
                                            <Button Style="{StaticResource GhostButtonStyle}" Tag="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" Foreground="{StaticResource PrimaryBrush}" ToolTip="Sửa nhân viên" Margin="0,0,5,0"/>
                                            <Button Style="{StaticResource GhostButtonStyle}" Tag="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM9 6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9V6zm9 14H6V10h12v10zm-6-3c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2z" Foreground="#F59E0B" ToolTip="Khóa tài khoản" Margin="0,0,5,0"/>
                                            <Button Style="{StaticResource GhostButtonStyle}" Tag="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" Foreground="{StaticResource ErrorBrush}" ToolTip="Xóa nhân viên"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- Roles & Permissions Tab Content -->
            <Grid x:Name="RolesTabContent">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveTab}" Value="roles">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Phân quyền dựa trên Vai trò (RBAC)" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                    <TextBlock Text="Cấu hình quyền truy cập cho từng vai trò trong hệ thống" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,2,0,15"/>
                    
                    <ItemsControl ItemsSource="{Binding AvailableRoles}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton Content="{Binding}" 
                                             Style="{StaticResource RoleChipStyle}"
                                             Command="{Binding DataContext.SelectRoleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             CommandParameter="{Binding}">
                                    <RadioButton.IsChecked>
                                        <MultiBinding Converter="{StaticResource EqualityToBooleanConverter}" Mode="OneWay">
                                            <Binding Path="DataContext.SelectedRole" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            <Binding Path="."/>
                                        </MultiBinding>
                                    </RadioButton.IsChecked>
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Permission Matrix Header -->
                <Border Grid.Row="1" Style="{StaticResource PermissionInfoBarStyle}" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M12 2L4 5v6.09c0 5.05 3.41 9.76 8 10.91 4.59-1.15 8-5.86 8-10.91V5l-8-3z" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                        <TextBlock VerticalAlignment="Center">
                            <Run Text="Ma trận quyền hạn cho: "/>
                            <Run Text="{Binding SelectedRole}" FontWeight="Bold"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                    <DataGrid ItemsSource="{Binding Permissions}" Style="{StaticResource ModernDataGridStyle}" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Phân hệ" Binding="{Binding ModuleName}" Width="*" FontWeight="SemiBold"/>
                            
                            <DataGridTemplateColumn Header="Xem" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding CanView, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernCheckBoxStyle}" HorizontalAlignment="Left"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Thêm" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding CanAdd, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernCheckBoxStyle}" HorizontalAlignment="Left"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Sửa" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding CanEdit, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernEditCheckBoxStyle}" HorizontalAlignment="Left"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Xóa" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding CanDelete, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernCheckBoxStyle}" HorizontalAlignment="Left"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Ghi đè" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding CanOverride, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernCheckBoxStyle}" HorizontalAlignment="Left"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Actions Footer -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="Đặt lại" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0"/>
                    <Button Content="Lưu cấu hình" Style="{StaticResource PrimaryButtonStyle}" Padding="24,12" FontSize="13" FontWeight="Bold"/>
                </StackPanel>

                <!-- Policy Warning Footer -->
                <Border Grid.Row="4" Style="{StaticResource PermissionInfoBarStyle}" Margin="0,20,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M12 2L4 5v6.09c0 5.05 3.41 9.76 8 10.91 4.59-1.15 8-5.86 8-10.91V5l-8-3z" Width="14" Height="14" Stretch="Uniform" Margin="0,0,10,0"/>
                        <TextBlock VerticalAlignment="Center">
                            <Run Text="Lưu ý: " FontWeight="Bold"/>
                            <Run Text="Các thay đổi về phân quyền sẽ có hiệu lực ngay lập tức đối với tất cả người dùng thuộc vai trò này. Vui lòng kiểm tra kỹ trước khi lưu."/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Logs Tab Content -->
            <Grid x:Name="LogsTabContent">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveTab}" Value="logs">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Nhật ký Hệ thống (Audit Logs)" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                    <TextBlock Text="Theo dõi và truy xuất mọi thay đổi dữ liệu trong hệ thống" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,20"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Search Bar -->
                        <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Height="42">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" 
                                      Fill="#9CA3AF" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="Tìm kiếm theo người dùng hoặc bảng..." Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Foreground="#9CA3AF" FontSize="13"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="15,0,0,0">
                            <Button Content="Bộ lọc" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0">
                                <Button.Tag>
                                    <Path Data="{StaticResource IconFilter}" Width="14" Height="14" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,8,0"/>
                                </Button.Tag>
                            </Button>
                            <Button Content="Chọn ngày" Style="{StaticResource SecondaryButtonStyle}">
                                <Button.Tag>
                                    <Path Data="{StaticResource IconCalendar}" Width="14" Height="14" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,8,0"/>
                                </Button.Tag>
                            </Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,15">
                    <DataGrid ItemsSource="{Binding AuditLogs}" Style="{StaticResource ModernDataGridStyle}" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Thời gian" Binding="{Binding Timestamp, StringFormat=dd/MM/yyyy HH:mm:ss}" Width="180"/>
                            <DataGridTextColumn Header="Người thực hiện" Binding="{Binding UserFullName}" Width="150" FontWeight="SemiBold"/>
                            
                            <DataGridTemplateColumn Header="Hành động" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border x:Name="actionBadge" HorizontalAlignment="Left" CornerRadius="6">
                                            <StackPanel Orientation="Horizontal" Margin="6,2">
                                                <Path x:Name="actionIcon" Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Action}"/>
                                            </StackPanel>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Action}" Value="Thêm">
                                                <Setter TargetName="actionBadge" Property="Style" Value="{StaticResource ActivityAddStyle}"/>
                                                <Setter TargetName="actionIcon" Property="Data" Value="{StaticResource IconAdd}"/>
                                                <Setter TargetName="actionIcon" Property="Fill" Value="#16A34A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Action}" Value="Sửa">
                                                <Setter TargetName="actionBadge" Property="Style" Value="{StaticResource ActivityEditStyle}"/>
                                                <Setter TargetName="actionIcon" Property="Data" Value="{StaticResource IconEdit}"/>
                                                <Setter TargetName="actionIcon" Property="Fill" Value="#EA580C"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Action}" Value="Xóa">
                                                <Setter TargetName="actionBadge" Property="Style" Value="{StaticResource ActivityDeleteStyle}"/>
                                                <Setter TargetName="actionIcon" Property="Data" Value="{StaticResource IconDelete}"/>
                                                <Setter TargetName="actionIcon" Property="Fill" Value="#DC2626"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Bảng dữ liệu" Width="230">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource TableBadgeStyle}" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding TableName}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Giá trị cũ" Binding="{Binding OldValue}" Width="*" Foreground="{StaticResource SecondaryTextBrush}"/>
                            <DataGridTextColumn Header="Giá trị mới" Binding="{Binding NewValue}" Width="*" FontWeight="Medium"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Pagination Footer -->
                <Grid Grid.Row="2" Margin="0,5,0,0">
                    <TextBlock Text="Hiển thị 8 / 8 bản ghi" VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Trước" Style="{StaticResource SecondaryButtonStyle}" Padding="12,6" FontSize="12" Margin="0,0,5,0"/>
                        <Button Content="1" Style="{StaticResource PrimaryButtonStyle}" Padding="12,6" FontSize="12" Margin="0,0,5,0"/>
                        <Button Content="2" Style="{StaticResource SecondaryButtonStyle}" Padding="12,6" FontSize="12" Margin="0,0,5,0"/>
                        <Button Content="Sau" Style="{StaticResource SecondaryButtonStyle}" Padding="12,6" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Settings Tab Content -->
            <Grid x:Name="SettingsTabContent">
                 <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveTab}" Value="settings">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Thiết lập Hệ thống" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Cấu hình các tham số chung của hệ thống ERP" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,2,0,15"/>

                    <StackPanel Margin="0,20,0,0">
                        <!-- Business Profile Section -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Style="{StaticResource SectionHeaderStyle}">
                                    <Path Data="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/>
                                    <TextBlock Text="Thông tin Doanh nghiệp"/>
                                </StackPanel>

                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 1: Name and Tax Code -->
                                    <StackPanel Margin="0,0,0,15">
                                        <TextBlock Text="Tên doanh nghiệp" Style="{StaticResource LoginLabelStyle}"/>
                                        <TextBox Style="{StaticResource LoginTextBoxStyle}" Text="{Binding CompanyName}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="0,0,0,15">
                                        <TextBlock Text="Mã số thuế" Style="{StaticResource LoginLabelStyle}"/>
                                        <TextBox Style="{StaticResource LoginTextBoxStyle}" Text="{Binding TaxCode}"/>
                                    </StackPanel>

                                    <!-- Row 2: Address -->
                                    <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,0,0,15">
                                        <TextBlock Text="Địa chỉ" Style="{StaticResource LoginLabelStyle}"/>
                                        <TextBox Style="{StaticResource LoginTextBoxStyle}" Text="{Binding Address}"/>
                                    </StackPanel>

                                    <!-- Row 3: Phone and Email -->
                                    <StackPanel Grid.Row="2">
                                        <TextBlock Text="Số điện thoại" Style="{StaticResource LoginLabelStyle}"/>
                                        <TextBox Style="{StaticResource LoginTextBoxStyle}" Text="{Binding Phone}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="2">
                                        <TextBlock Text="Email" Style="{StaticResource LoginLabelStyle}"/>
                                        <TextBox Style="{StaticResource LoginTextBoxStyle}" Text="{Binding Email}"/>
                                    </StackPanel>
                                </Grid>

                                <Separator Background="{StaticResource BorderBrush}" Margin="0,5,0,20"/>

                                <TextBlock Text="Logo doanh nghiệp" Style="{StaticResource LoginLabelStyle}" Margin="0,0,0,15"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <ContentControl Style="{StaticResource DashedBorderStyle}">
                                        <Path Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-5.04-6.71l-2.75 3.54-1.96-2.36L6.5 17h11l-3.54-4.71z" 
                                              Fill="#9CA3AF" Width="40" Height="40" Stretch="Uniform"/>
                                    </ContentControl>
                                    <StackPanel Margin="24,0,0,0" VerticalAlignment="Center">
                                        <Button Content="Tải lên Logo" Style="{StaticResource SecondaryButtonStyle}" Width="120" HorizontalAlignment="Left"/>
                                        <TextBlock Text="Định dạng: PNG, JPG (Tối đa 2MB)" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Format Configuration Card -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Style="{StaticResource SectionHeaderStyle}">
                                    <Path Data="{StaticResource IconCalendar}"/>
                                    <TextBlock Text="Cấu hình Định dạng"/>
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Date & Time Format -->
                                    <StackPanel Margin="0,0,0,20">
                                        <TextBlock Text="Định dạng ngày tháng" Style="{StaticResource LoginLabelStyle}"/>
                                        <ComboBox Style="{StaticResource ModernComboBoxStyle}" ItemsSource="{Binding AvailableDateFormats}" SelectedItem="{Binding SelectedDateFormat}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="0,0,0,20">
                                        <TextBlock Text="Định dạng giờ" Style="{StaticResource LoginLabelStyle}"/>
                                        <ComboBox Style="{StaticResource ModernComboBoxStyle}" ItemsSource="{Binding AvailableTimeFormats}" SelectedItem="{Binding SelectedTimeFormat}"/>
                                    </StackPanel>

                                    <!-- Currency & Timezone -->
                                    <StackPanel Grid.Row="1">
                                        <TextBlock Text="Đơn vị tiền tệ" Style="{StaticResource LoginLabelStyle}"/>
                                        <ComboBox Style="{StaticResource ModernComboBoxStyle}" ItemsSource="{Binding AvailableCurrencies}" SelectedItem="{Binding SelectedCurrency}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="2">
                                        <TextBlock Text="Múi giờ" Style="{StaticResource LoginLabelStyle}"/>
                                        <ComboBox Style="{StaticResource ModernComboBoxStyle}" ItemsSource="{Binding AvailableTimeZones}" SelectedItem="{Binding SelectedTimeZone}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Security & Authentication Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <StackPanel Style="{StaticResource SectionHeaderStyle}">
                                    <Path Data="{StaticResource IconShield}"/>
                                    <TextBlock Text="Bảo mật &amp; Xác thực"/>
                                </StackPanel>

                                <Grid ShowGridLines="False">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Password Length & Algorithm -->
                                    <StackPanel Margin="0,0,0,20" HorizontalAlignment="Left" Width="200">
                                        <TextBlock Text="Độ dài mật khẩu tối thiểu" Style="{StaticResource LoginLabelStyle}" Margin="0,0,0,10"/>
                                        <TextBox Style="{StaticResource ModernNumericTextBoxStyle}" Width="120" HorizontalAlignment="Left" Text="{Binding MinPasswordLength}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="0,0,0,20" HorizontalAlignment="Left">
                                        <TextBlock Text="Thuật toán băm mật khẩu" Style="{StaticResource LoginLabelStyle}" Margin="0,0,0,10"/>
                                        <ComboBox Style="{StaticResource ModernComboBoxStyle}" Width="350" HorizontalAlignment="Left" ItemsSource="{Binding AvailableHashAlgorithms}" SelectedItem="{Binding SelectedHashAlgorithm}"/>
                                    </StackPanel>

                                    <!-- Session & Login Attempts -->
                                    <StackPanel Grid.Row="1" Margin="0,0,0,20" HorizontalAlignment="Left" Width="200">
                                        <TextBlock Text="Thời gian hết phiên (phút)" Style="{StaticResource LoginLabelStyle}" Margin="0,0,0,10"/>
                                        <TextBox Style="{StaticResource ModernNumericTextBoxStyle}" Width="120" HorizontalAlignment="Left" Text="{Binding SessionTimeout}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,20" HorizontalAlignment="Left">
                                        <TextBlock Text="Số lần đăng nhập sai tối đa" Style="{StaticResource LoginLabelStyle}" Margin="0,0,0,10"/>
                                        <TextBox Style="{StaticResource ModernNumericTextBoxStyle}" Width="120" HorizontalAlignment="Left" Text="{Binding MaxLoginAttempts}"/>
                                    </StackPanel>

                                    <!-- Policy Checkboxes -->
                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="3">
                                        <CheckBox Content="Yêu cầu mật khẩu phức tạp (chữ hoa, chữ thường, số, ký tự đặc biệt)" 
                                                  Style="{StaticResource ModernCheckBoxStyle}" IsChecked="{Binding IsComplexityRequired}" Margin="0,0,0,15"/>
                                        <CheckBox Content="Bắt buộc đổi mật khẩu mỗi 90 ngày" 
                                                  Style="{StaticResource ModernCheckBoxStyle}" IsChecked="{Binding IsRotationRequired}" Margin="0,0,0,15"/>
                                        <CheckBox Content="Bật xác thực hai yếu tố (2FA)" 
                                                  Style="{StaticResource ModernCheckBoxStyle}" IsChecked="{Binding Is2FARequired}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Bottom Action Bar -->
                        <Border Margin="0,30,0,0" Padding="0,20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Đặt lại" Style="{StaticResource SecondaryButtonStyle}" Width="100" Margin="0,0,12,0"/>
                                <Button Content="Lưu cấu hình" Style="{StaticResource PrimaryButtonStyle}" Width="150">
                                    <Button.Background>
                                        <SolidColorBrush Color="#2563EB"/>
                                    </Button.Background>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Grid>
</ScrollViewer>
</UserControl>
