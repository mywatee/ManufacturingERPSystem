<UserControl x:Class="ManufacturingERP.Views.WorkOrderDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ManufacturingERP.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="Transparent">

    <Grid>
        <!-- Loading Overlay -->
        <Border Background="#80FFFFFF" Panel.ZIndex="10" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Đang tải dữ liệu..." FontSize="16" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Background="White" CornerRadius="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="24">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.05"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" CornerRadius="16,16,0,0" Padding="24" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Back Button -->
                        <Button Grid.Column="0" Command="{Binding GoBackCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,16,0" VerticalAlignment="Center" ToolTip="Quay lại">
                            <Border Width="40" Height="40" CornerRadius="20" Background="#F1F5F9">
                                <Viewbox Width="20" Height="20">
                                    <Path Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" Fill="#475569"/>
                                </Viewbox>
                            </Border>
                        </Button>

                        <Viewbox Width="32" Height="32" Grid.Column="1" Margin="0,0,16,0">
                            <Path Data="M12 2L2 7l10 5 10-5-10-5z M2 17l10 5 10-5 M2 12l10 5 10-5" Fill="#2563EB"/>
                        </Viewbox>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Chi tiết Lệnh: " FontSize="20" Foreground="#64748B"/>
                                <TextBlock Text="{Binding Order.Wocode}" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                                <Border Background="#DBEAFE" CornerRadius="6" Padding="8,4" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StatusVi}" Foreground="#1D4ED8" FontWeight="SemiBold" FontSize="12"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{Binding CreatorName, StringFormat=Người tạo: {0}}" FontSize="13" Foreground="#94A3B8" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Actions -->
                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Cập nhật tiến độ" Command="{Binding RecordProgressCommand}" Visibility="{Binding CanRecord, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#F8FAFC" Foreground="#334155" BorderBrush="#CBD5E1" BorderThickness="1" Padding="16,8" Margin="0,0,12,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="Chỉnh sửa" Command="{Binding EditOrderCommand}" Visibility="{Binding CanEdit, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#F8FAFC" Foreground="#334155" BorderBrush="#CBD5E1" BorderThickness="1" Padding="16,8" Margin="0,0,12,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="Hủy lệnh" Command="{Binding CancelOrderCommand}" Visibility="{Binding CanCancel, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#FEE2E2" Foreground="#DC2626" BorderBrush="#FCA5A5" BorderThickness="1" Padding="16,8" Margin="0,0,12,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="Tạm dừng" Command="{Binding PauseOrderCommand}" Visibility="{Binding CanPause, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#F59E0B" Foreground="White" BorderThickness="0" Padding="16,8" Margin="0,0,12,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="Bắt đầu sản xuất" Command="{Binding StartOrderCommand}" Visibility="{Binding CanStart, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#2563EB" Foreground="White" BorderThickness="0" Padding="16,8" Margin="0,0,12,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="Hoàn thành" Command="{Binding CompleteOrderCommand}" Visibility="{Binding CanComplete, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#10B981" Foreground="White" BorderThickness="0" Padding="16,8">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- TabControl -->
                <TabControl Grid.Row="1" Margin="24" Background="Transparent" BorderThickness="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border Name="Border" Padding="16,8" Margin="0,0,8,0" BorderBrush="Transparent" BorderThickness="0,0,0,3" Background="Transparent">
                                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="10,2"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#2563EB" />
                                                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="#0F172A" />
                                                <Setter TargetName="ContentSite" Property="TextElement.FontWeight" Value="Bold" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="False">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="Transparent" />
                                                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="#64748B" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#F8FAFC" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <!-- Tab 1: Tổng quan -->
                    <TabItem Header="Tổng quan">
                        <Grid Margin="0,16,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Info Cards -->
                            <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,24">
                                <Border Background="#F8FAFC" CornerRadius="8" Padding="16" Margin="0,0,12,0" BorderBrush="#E2E8F0" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Thời gian thực hiện" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#0F172A" Text="{Binding DateRangeText}"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F8FAFC" CornerRadius="8" Padding="16" Margin="0,0,12,0" BorderBrush="#E2E8F0" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Đã sản xuất (Xưởng)" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding TotalReportedQty}" FontSize="14" FontWeight="Bold" Foreground="#2563EB"/>
                                            <TextBlock Text="/" FontSize="14" Foreground="#94A3B8" Margin="4,0"/>
                                            <TextBlock Text="{Binding TotalTargetQty}" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F8FAFC" CornerRadius="8" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Thực tế (Đạt QC)" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding TotalActualQty}" FontSize="14" FontWeight="Bold" Foreground="#16A34A"/>
                                            <TextBlock Text="/" FontSize="14" Foreground="#94A3B8" Margin="4,0"/>
                                            <TextBlock Text="{Binding TotalTargetQty}" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- Items List -->
                            <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
                                <DataGrid ItemsSource="{Binding Order.WorkOrderItems}" AutoGenerateColumns="False" IsReadOnly="True"
                                          BorderThickness="0" Background="Transparent" HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                                          RowHeight="60" SelectionMode="Single">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F8FAFC"/>
                                            <Setter Property="Foreground" Value="#64748B"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Padding" Value="15,16"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                        </Style>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F8FAFC"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#EFF6FF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="#1D4ED8"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="MÃ SP" Binding="{Binding Product.MaterialCode}" Width="1.2*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Margin" Value="15,0"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="TÊN SẢN PHẨM" Binding="{Binding Product.MaterialName}" Width="2*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Margin" Value="15,0"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="MỤC TIÊU" Binding="{Binding TargetQty}" Width="0.8*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Margin" Value="15,0"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="ĐÃ SẢN XUẤT" Binding="{Binding ReportedQty}" Width="1*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Margin" Value="15,0"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#2563EB"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="THỰC TẾ (QC)" Binding="{Binding ActualQty}" Width="1*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Margin" Value="15,0"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#16A34A"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="LỖI XƯỞNG" Binding="{Binding InternalFailedQty}" Width="0.9*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Margin" Value="15,0"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#F59E0B"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="LỖI QC" Binding="{Binding QCFailedQty}" Width="0.8*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Margin" Value="15,0"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="TRẠNG THÁI" Binding="{Binding Status}" Width="1.5*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Margin" Value="15,0"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- Tab 2: Tiến độ công đoạn -->
                    <TabItem Header="Tiến độ công đoạn">
                        <Grid Margin="0,16,0,0">
                            <Border Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
                                <DataGrid ItemsSource="{Binding Order.WorkOrderProgresses}" AutoGenerateColumns="False" IsReadOnly="True"
                                          BorderThickness="0" Background="Transparent" HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                                          RowHeight="60" SelectionMode="Single">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F8FAFC"/>
                                            <Setter Property="Foreground" Value="#64748B"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Padding" Value="15,16"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                        </Style>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F8FAFC"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#EFF6FF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="#1D4ED8"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="CÔNG ĐOẠN" Binding="{Binding StageName}" Width="2*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Margin" Value="15,0"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="SỐ LƯỢNG ĐẠT" Binding="{Binding ProducedQty}" Width="1.2*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Margin" Value="15,0"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#16A34A"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="SỐ LƯỢNG LỖI" Binding="{Binding DefectQty}" Width="1.2*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Margin" Value="15,0"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="NGƯỜI GHI NHẬN" Binding="{Binding RecordedBy}" Width="2*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Margin" Value="15,0"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="GHI CHÚ" Binding="{Binding Notes}" Width="3*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Margin" Value="15,0"/>
                                                    <Setter Property="Foreground" Value="#64748B"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>
                    </TabItem>

                </TabControl>
            </Grid>
        </Border>

        <!-- ===== INLINE EDIT PANEL OVERLAY ===== -->
        <Border Background="#40000000" Panel.ZIndex="20" 
                Visibility="{Binding IsEditPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="White" CornerRadius="12" MaxWidth="560" MaxHeight="520" 
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Border Grid.Row="0" Background="{StaticResource SidebarBackgroundBrush}" CornerRadius="12,12,0,0" Padding="20,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#2563EB" CornerRadius="8" Width="32" Height="32" Margin="0,0,12,0">
                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Chỉnh sửa Lệnh sản xuất" FontSize="15" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="{Binding Order.Wocode}" FontSize="11" Foreground="#94A3B8"/>
                            </StackPanel>
                            <Button Grid.Column="2" Command="{Binding CancelEditCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#94A3B8"/>
                            </Button>
                        </Grid>
                    </Border>
                    
                    <!-- Content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
                        <StackPanel>
                            <TextBlock Text="Mã lệnh" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Order.Wocode}" IsReadOnly="True" Background="#F8FAFC" Padding="10,8" Height="36" 
                                     BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,14"/>
                            
                            <TextBlock Text="Sản phẩm mục tiêu" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding ProductList}" SelectedItem="{Binding EditSelectedProduct}" 
                                      DisplayMemberPath="MaterialName" Height="36" Padding="10,0" VerticalContentAlignment="Center"
                                      BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,14"/>
                            
                            <TextBlock Text="Số lượng kế hoạch" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditQuantity, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" Height="36" 
                                     BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,14"/>
                            
                            <TextBlock Text="Hạn hoàn thành" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding EditEndDate}" Height="36" Padding="10,0" 
                                        VerticalContentAlignment="Center" Margin="0,0,0,14"/>
                            
                            <Border Background="#FEF2F2" BorderBrush="#FEE2E2" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Ưu tiên sản xuất khẩn cấp" FontWeight="SemiBold" Foreground="#DC2626" FontSize="13"/>
                                        <TextBlock Text="Đẩy lên đầu danh sách điều độ" FontSize="11" Foreground="#EF4444" Opacity="0.8"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" IsChecked="{Binding EditIsUrgent}" Style="{StaticResource ModernCheckBoxStyle}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                    
                    <!-- Footer -->
                    <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0,0,12,12" Padding="20,14" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Hủy bỏ" Command="{Binding CancelEditCommand}" Style="{StaticResource SecondaryButtonStyle}" Width="90" Margin="0,0,10,0"/>
                            <Button Content="Lưu thay đổi" Command="{Binding SaveEditCommand}" Style="{StaticResource PrimaryButtonStyle}" Width="120" Height="36"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Border>

        <!-- ===== FULL SCREEN RECORD PROGRESS PANEL ===== -->
        <Border Background="#F8FAFC" Panel.ZIndex="20" 
                Visibility="{Binding IsRecordPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Background="Transparent">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                    <StackPanel Margin="30,20,30,40" Background="Transparent">
                        
                        <!-- Header Section -->
                        <Grid Margin="0,0,0,40">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Back Button -->
                            <Button Grid.Column="0" Command="{Binding CancelRecordCommand}" 
                                    Background="Transparent" BorderThickness="0" Padding="0" HorizontalAlignment="Left" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="32" Height="32" Background="#F1F5F9" CornerRadius="16" Margin="0,0,12,0">
                                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Quay lại Chi tiết lệnh" Foreground="#64748B" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Title -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="Cập nhật Tiến độ" FontSize="32" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Order.Wocode, StringFormat=Lệnh sản xuất: {0}}" FontSize="14" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                            
                            <!-- Action Button -->
                            <Button Grid.Column="2" Content="Lưu tiến độ" Command="{Binding SaveRecordCommand}" 
                                    Background="#2563EB" Foreground="White" Width="200" HorizontalAlignment="Right" Height="48" FontWeight="Bold" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- Two-Column Layout -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="320"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Form Content -->
                            <StackPanel Grid.Column="0" Margin="0,0,30,0">
                                <Border Background="White" CornerRadius="20" BorderBrush="#E2E8F0" BorderThickness="1" Padding="30">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.04" Color="#1E293B"/>
                                    </Border.Effect>
                                    
                                    <StackPanel>
                                        <!-- Chọn sản phẩm -->
                                        <TextBlock Text="SẢN PHẨM GHI NHẬN" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,10"/>
                                        <ComboBox ItemsSource="{Binding Order.WorkOrderItems}" SelectedItem="{Binding RecordSelectedProduct}" 
                                                  DisplayMemberPath="Product.MaterialName" Height="48" Padding="15,0" VerticalContentAlignment="Center" 
                                                  BorderBrush="#E2E8F0" BorderThickness="1.5" Margin="0,0,0,24" FontSize="14" FontWeight="SemiBold">
                                            <ComboBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="10"/>
                                                </Style>
                                            </ComboBox.Resources>
                                        </ComboBox>

                                        <!-- Số lượng đạt/lỗi -->
                                        <Grid Margin="0,0,0,24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Số lượng đạt -->
                                            <Border Grid.Column="0" Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1.5" CornerRadius="16" Padding="20">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="#15803D" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="SẢN PHẨM HOÀN THÀNH" FontSize="13" FontWeight="Bold" Foreground="#15803D" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Text="Đã gia công xong" FontSize="11" Foreground="#16A34A" Margin="0,0,0,16"/>
                                                    <TextBox Text="{Binding RecordActualQty, UpdateSourceTrigger=PropertyChanged}" 
                                                             Height="48" TextAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="#16A34A"
                                                             BorderBrush="#BBF7D0" BorderThickness="1.5" VerticalContentAlignment="Center">
                                                        <TextBox.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="10"/>
                                                            </Style>
                                                        </TextBox.Resources>
                                                    </TextBox>
                                                </StackPanel>
                                            </Border>

                                            <!-- Số lượng lỗi -->
                                            <Border Grid.Column="2" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1.5" CornerRadius="16" Padding="20">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" Foreground="#B91C1C" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="LỖI NỘI BỘ XƯỞNG" FontSize="13" FontWeight="Bold" Foreground="#B91C1C" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Text="Phế phẩm tại xưởng" FontSize="11" Foreground="#DC2626" Margin="0,0,0,16"/>
                                                    <TextBox Text="{Binding RecordFailedQty, UpdateSourceTrigger=PropertyChanged}" 
                                                             Height="48" TextAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="#DC2626"
                                                             BorderBrush="#FECACA" BorderThickness="1.5" VerticalContentAlignment="Center">
                                                        <TextBox.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="10"/>
                                                            </Style>
                                                        </TextBox.Resources>
                                                    </TextBox>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- Nhân viên thực hiện (Dạng Nhóm) -->
                                        <TextBlock Text="NHÂN VIÊN THỰC HIỆN (NHÓM)" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,10"/>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox ItemsSource="{Binding WorkerList}" SelectedItem="{Binding SelectedWorkerToAdd}" 
                                                      Height="40" Padding="15,0" VerticalContentAlignment="Center" 
                                                      BorderBrush="#E2E8F0" BorderThickness="1.5" FontSize="13">
                                                 <ComboBox.ItemTemplate>
                                                     <DataTemplate>
                                                         <TextBlock Text="{Binding Employee.FullName, FallbackValue='(Chưa có tên)'}"/>
                                                     </DataTemplate>
                                                 </ComboBox.ItemTemplate>
                                                 <ComboBox.Resources>
                                                     <Style TargetType="Border">
                                                         <Setter Property="CornerRadius" Value="8"/>
                                                     </Style>
                                                 </ComboBox.Resources>
                                            </ComboBox>
                                            <Button Grid.Column="1" Command="{Binding AddWorkerToRecordCommand}" 
                                                    Content="Thêm vào nhóm" Background="#2563EB" Foreground="White" 
                                                    Padding="16,0" Margin="10,0,0,0" Height="40" FontWeight="SemiBold">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </Grid>

                                        <!-- Bảng danh sách nhân viên -->
                                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Margin="0,0,0,24" Background="#F8FAFC" Padding="2">
                                            <DataGrid ItemsSource="{Binding RecordWorkerList}" AutoGenerateColumns="False" 
                                                      Background="Transparent" BorderThickness="0" CanUserAddRows="False"
                                                      HeadersVisibility="Column" RowHeight="45">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="HỌ TÊN" Binding="{Binding User.Employee.FullName}" Width="*" IsReadOnly="True"/>
                                                    <DataGridTemplateColumn Header="BẮT ĐẦU" Width="120">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <DatePicker SelectedDate="{Binding StartTime, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="KẾT THÚC" Width="120">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <DatePicker SelectedDate="{Binding EndTime, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Width="50">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Button Command="{Binding DataContext.RemoveWorkerFromRecordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="#DC2626"/>
                                                                </Button>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Border>

                                        <!-- Công đoạn -->
                                        <TextBlock Text="CÔNG ĐOẠN THỰC HIỆN" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,10"/>
                                        <ComboBox ItemsSource="{Binding StageOptions}" SelectedItem="{Binding RecordSelectedStage}" 
                                                  Height="48" Padding="15,0" VerticalContentAlignment="Center" BorderBrush="#E2E8F0" BorderThickness="1.5" Margin="0,0,0,24" FontSize="14">
                                            <ComboBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="10"/>
                                                </Style>
                                            </ComboBox.Resources>
                                        </ComboBox>

                                        <!-- Ghi chú -->
                                        <TextBlock Text="GHI CHÚ / NHẬN XÉT" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,10"/>
                                        <TextBox Text="{Binding RecordNotes, UpdateSourceTrigger=PropertyChanged}" Height="80" Padding="15,12" TextWrapping="Wrap" AcceptsReturn="True" 
                                                 BorderBrush="#E2E8F0" BorderThickness="1.5" VerticalScrollBarVisibility="Auto" FontSize="14">
                                            <TextBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="10"/>
                                                </Style>
                                            </TextBox.Resources>
                                        </TextBox>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            
                            <!-- Sidebar -->
                            <StackPanel Grid.Column="1">
                                <Border Background="White" CornerRadius="20" BorderBrush="#E2E8F0" BorderThickness="1" Padding="24">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.04" Color="#1E293B"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                            <Border Width="28" Height="28" Background="#EFF6FF" CornerRadius="14" Margin="0,0,12,0">
                                                <TextBlock Text="?" FontWeight="Bold" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="HƯỚNG DẪN NGHIỆP VỤ" FontSize="14" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Border Background="#F8FAFC" CornerRadius="8" Padding="15" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="Cộng dồn tiến độ" FontWeight="Bold" Foreground="#334155" Margin="0,0,0,4"/>
                                                <TextBlock Text="Nhập số lượng bạn vừa làm xong. Hệ thống sẽ dùng số liệu này để tính % tiến độ sản xuất thực tế trên bảng điều khiển." Foreground="#64748B" FontSize="12" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Background="#FEF2F2" CornerRadius="8" Padding="15" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="Sản phẩm lỗi" FontWeight="Bold" Foreground="#B91C1C" Margin="0,0,0,4"/>
                                                <TextBlock Text="Phế phẩm phát sinh trong quá trình gia công. Số lượng này không được cộng vào thực tế đạt." Foreground="#DC2626" FontSize="12" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                        
                                        <TextBlock Text="Mẹo nhanh:" FontWeight="Bold" Foreground="#64748B" FontSize="12" Margin="0,15,0,8"/>
                                        <TextBlock Text="• Sử dụng phím Tab để nhảy nhanh giữa các ô nhập liệu." Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                        <TextBlock Text="• Nên điền Ghi chú nếu số lượng Lỗi &gt; 0 để quản lý theo dõi." Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
