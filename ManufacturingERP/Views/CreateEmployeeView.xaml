<UserControl x:Class="ManufacturingERP.Views.CreateEmployeeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ManufacturingERP.Views"
             xmlns:core="clr-namespace:ManufacturingERP.Core"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1100"
             Background="#F8FAFC">

    <UserControl.Resources>
        <!-- Modern Card Style -->
        <Style x:Key="ModernCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.03" Color="#1E293B"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Form Label Style -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,30,40,40">
                <!-- Header Section -->
                <Grid Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Command="{Binding GoBackCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" Background="#F1F5F9" CornerRadius="18" Margin="0,0,12,0">
                                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Quay lại danh sách" VerticalAlignment="Center" Foreground="#64748B" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Grid.Column="1" Text="Thêm nhân viên mới" FontSize="28" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center"/>

                    <Button Grid.Column="2" Content="Lưu thông tin nhân sự" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" Width="220"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="350"/>
                    </Grid.ColumnDefinitions>

                    <!-- Main Form Area -->
                    <StackPanel Grid.Column="0" Margin="0,0,30,0">
                        <!-- Personal Info Card -->
                        <Border Style="{StaticResource ModernCardStyle}" Padding="30" Margin="0,0,0,25">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <Border Width="4" Height="20" Background="#3B82F6" CornerRadius="2" Margin="0,0,12,0"/>
                                    <TextBlock Text="THÔNG TIN CÁ NHÂN" FontSize="15" FontWeight="Bold" Foreground="#1E293B"/>
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                     <!-- Employee Code -->
                                     <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,20">
                                         <TextBlock Text="Mã nhân viên" Style="{StaticResource FormLabelStyle}"/>
                                         <Grid>
                                             <Grid.ColumnDefinitions>
                                                 <ColumnDefinition Width="*"/>
                                                 <ColumnDefinition Width="Auto"/>
                                             </Grid.ColumnDefinitions>
                                             <TextBox Text="{Binding EmployeeCode, UpdateSourceTrigger=PropertyChanged}" 
                                                      Style="{StaticResource ModernTextBox}" 
                                                      Tag="EMPxxx"
                                                      IsReadOnly="False"/>
                                             <Button Grid.Column="1" 
                                                     Content="Tự tạo mã" 
                                                     Command="{Binding GenerateCodeCommand}" 
                                                     Height="45" 
                                                     Width="100" 
                                                     Margin="10,0,0,0"
                                                     Style="{StaticResource PrimaryButtonStyle}"
                                                     FontSize="12"/>
                                         </Grid>
                                     </StackPanel>

                                    <!-- Full Name -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,20">
                                        <TextBlock Text="Họ và tên" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Tag="Nhập họ tên đầy đủ..."/>
                                    </StackPanel>

                                    <!-- Email -->
                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,20">
                                        <TextBlock Text="Email liên hệ" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Tag="example@company.com"/>
                                    </StackPanel>

                                    <!-- Phone -->
                                    <StackPanel Grid.Row="2" Grid.Column="0">
                                        <TextBlock Text="Số điện thoại" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Tag="09xx xxx xxx"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Employment Info Card -->
                        <Border Style="{StaticResource ModernCardStyle}" Padding="30">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <Border Width="4" Height="20" Background="#10B981" CornerRadius="2" Margin="0,0,12,0"/>
                                    <TextBlock Text="THÔNG TIN CÔNG VIỆC &amp; LƯƠNG" FontSize="15" FontWeight="Bold" Foreground="#1E293B"/>
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Department -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,20">
                                        <TextBlock Text="Bộ phận" Style="{StaticResource FormLabelStyle}"/>
                                        <ComboBox ItemsSource="{Binding Departments}" SelectedItem="{Binding SelectedDepartment}" Height="45" Padding="12,0" VerticalContentAlignment="Center">
                                            <ComboBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="10"/>
                                                </Style>
                                            </ComboBox.Resources>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Position -->
                                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,20">
                                        <TextBlock Text="Chức danh / Vị trí" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding Position, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                                    </StackPanel>

                                    <!-- Basic Salary -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,20">
                                        <TextBlock Text="Lương cơ bản (VNĐ)" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding BasicSalary, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N0}}" Style="{StaticResource ModernTextBox}"/>
                                    </StackPanel>

                                    <!-- Join Date -->
                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,20">
                                        <TextBlock Text="Ngày vào làm" Style="{StaticResource FormLabelStyle}"/>
                                        <DatePicker SelectedDate="{Binding JoinDate}" Height="45" VerticalContentAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Pieces Rate -->
                                    <StackPanel Grid.Row="2" Grid.Column="0">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedDepartment}" Value="Sản xuất">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedDepartment}" Value="Kỹ thuật">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Đơn giá sản phẩm (VNĐ/SP)" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding PiecesRate, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N0}}" Style="{StaticResource ModernTextBox}"/>
                                    </StackPanel>

                                    <!-- Productivity Threshold -->
                                    <StackPanel Grid.Row="2" Grid.Column="2">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedDepartment}" Value="Sản xuất">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedDepartment}" Value="Kỹ thuật">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Định mức năng suất (SP)" Style="{StaticResource FormLabelStyle}"/>
                                        <TextBox Text="{Binding ProductivityThreshold, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Sidebar Info -->
                    <StackPanel Grid.Column="1">
                        <Border Style="{StaticResource ModernCardStyle}" Padding="25" Background="#F1F5F9" BorderThickness="0">
                            <StackPanel>
                                <TextBlock Text="Lưu ý hệ thống" FontSize="13" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,15"/>
                                
                                <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Tài khoản người dùng" FontWeight="Bold" FontSize="12" Foreground="#334155" Margin="0,0,0,5"/>
                                        <TextBlock Text="Hệ thống sẽ tự động tạo tài khoản đăng nhập dựa trên tên nhân viên." FontSize="11" Foreground="#64748B" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Mã nhân viên" FontWeight="Bold" FontSize="12" Foreground="#334155" Margin="0,0,0,5"/>
                                        <TextBlock Text="Mã số nhân viên (EMP...) sẽ được cấp phát tự động theo thời gian thực." FontSize="11" Foreground="#64748B" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="#DBEAFE" CornerRadius="12" Padding="15">
                                    <StackPanel>
                                        <TextBlock Text="Mật khẩu mặc định" FontWeight="Bold" FontSize="12" Foreground="#1E40AF" Margin="0,0,0,5"/>
                                        <TextBlock Text="Mật khẩu khởi tạo là 'Staff@123'. Nhân viên nên đổi mật khẩu ngay sau khi nhận tài khoản." FontSize="11" Foreground="#1E40AF" TextWrapping="Wrap" Opacity="0.8"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Background="#80FFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#E2E8F0" Foreground="#3B82F6" BorderThickness="0"/>
                <TextBlock Text="Đang xử lý..." Margin="0,10,0,0" Foreground="#3B82F6" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
