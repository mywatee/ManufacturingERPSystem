<UserControl x:Class="ManufacturingERP.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:local="clr-namespace:ManufacturingERP.Views"
             xmlns:dialogs="clr-namespace:ManufacturingERP.Views.Dialogs"
             mc:Ignorable="d" 
             d:DesignHeight="1000" d:DesignWidth="1200">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Page Title & Header -->
                <Grid Grid.Row="0" Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="Bảng điều khiển" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Tổng quan hệ thống sản xuất - Cập nhật thời gian thực" 
                                   FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
                
                <!-- Rest of the content stays the same -->

            <!-- Stat Cards (Row 1) -->
            <Grid Grid.Row="1" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Border Width="45" Height="45" CornerRadius="8" Background="{StaticResource BlueIconBg}" HorizontalAlignment="Left">
                                <TextBlock Text="🏭" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding RunningOrders}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Lệnh sản xuất chạy" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,10,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Border Width="45" Height="45" CornerRadius="8" Background="{StaticResource OrangeIconBg}" HorizontalAlignment="Left">
                                <TextBlock Text="⚠️" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding MaterialAlerts}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Cảnh báo vật tư" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="10,0,10,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Border Width="45" Height="45" CornerRadius="8" Background="{StaticResource GreenIconBg}" HorizontalAlignment="Left">
                                <TextBlock Text="📈" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding TodayProductivity}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Năng suất hôm nay" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource CardStyle}" Margin="10,0,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Border Width="45" Height="45" CornerRadius="8" Background="{StaticResource PurpleIconBg}" HorizontalAlignment="Left">
                                <TextBlock Text="💰" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding MonthlyRevenue}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Doanh thu tháng này" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Charts (Row 2) -->
            <Grid Grid.Row="2" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Line Chart Card -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0" Height="450">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Tiến độ sản xuất so với Kế hoạch" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                        
                        <lvc:CartesianChart Grid.Row="1" Series="{Binding ProductionSeries}" LegendLocation="None">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="{Binding ProductionLabels}">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator Step="1" IsEnabled="False"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis MinValue="180" MaxValue="280">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator StrokeThickness="1" Stroke="#F1F5F9" />
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>

                        <!-- Manual Legend for Line Chart with proper spacing -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,5">
                            <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                <Ellipse Width="12" Height="12" Stroke="DodgerBlue" StrokeThickness="2" Margin="0,0,6,0"/>
                                <TextBlock Text="Thực tế" FontSize="13" Foreground="{StaticResource PrimaryTextBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="12" Height="12" Stroke="Tomato" StrokeThickness="2" Margin="0,0,6,0"/>
                                <TextBlock Text="Kế hoạch" FontSize="13" Foreground="{StaticResource PrimaryTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Pie Chart Card -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,0,0" Height="450">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Phân tích lý do hàng lỗi" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <!-- Modern Donut Chart -->
                        <Grid Grid.Row="1">
                            <lvc:PieChart x:Name="PieChartDefect" 
                                          Series="{Binding DefectSeries}" 
                                          LegendLocation="None" 
                                          Hoverable="True"
                                          DataClick="PieChart_DataClick"
                                          DataHover="PieChart_DataHover"
                                          MouseLeave="PieChart_MouseLeave"
                                          InnerRadius="90"
                                          Margin="20">
                                <lvc:PieChart.ChartLegend>
                                    <lvc:DefaultLegend Visibility="Collapsed"/>
                                </lvc:PieChart.ChartLegend>
                            </lvc:PieChart>
                            
                            <!-- Center Text (Interactive) -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding SelectedDefectValue}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding SelectedDefectTitle}" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Pie Chart Legend (Empty) -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                            <TextBlock Text="Không có dữ liệu lỗi" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" FontStyle="Italic"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Urgent Orders (Row 3) -->
            <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,0,0,30">
                <StackPanel>
                    <Grid Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Lệnh sản xuất gần đây" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>

                    <DataGrid Style="{StaticResource ModernDataGridStyle}" ItemsSource="{Binding UrgentOrders}">
                        <DataGrid.Columns>
                            <!-- Mã lệnh -->
                            <DataGridTemplateColumn Header="Mã lệnh" Width="250">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Code}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <Border Style="{StaticResource UrgentBadgeStyle}" Margin="8,0,0,0" 
                                                    Visibility="{Binding IsUrgent, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Khẩn cấp"/>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <!-- Sản phẩm -->
                            <DataGridTextColumn Header="Sản phẩm" Binding="{Binding Product}" Width="*"/>
                            
                            <!-- Số lượng -->
                            <DataGridTextColumn Header="Số lượng" Binding="{Binding Quantity}" Width="100"/>

                            <!-- Tiến độ -->
                            <DataGridTemplateColumn Header="Tiến độ" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <ProgressBar Value="{Binding Progress}" Width="80" Style="{StaticResource ModernProgressBarStyle}" Foreground="#2563EB"/>
                                            <TextBlock Text="{Binding Progress, StringFormat={}{0}%}" FontSize="12" Margin="8,0,0,0" Foreground="{StaticResource SecondaryTextBrush}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Trạng thái -->
                            <DataGridTemplateColumn Header="Trạng thái" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border HorizontalAlignment="Left" MinWidth="90">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Đang sản xuất">
                                                            <Setter Property="Background" Value="#EFF6FF"/>
                                                            <Setter Property="BorderBrush" Value="#DBEAFE"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Chờ">
                                                            <Setter Property="Background" Value="#FFF7ED"/>
                                                            <Setter Property="BorderBrush" Value="#FFEDD5"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Hoàn thành">
                                                            <Setter Property="Background" Value="#F0FDF4"/>
                                                            <Setter Property="BorderBrush" Value="#DCFCE7"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Tạm dừng">
                                                            <Setter Property="Background" Value="#FEF2F2"/>
                                                            <Setter Property="BorderBrush" Value="#FEE2E2"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Hủy">
                                                            <Setter Property="Background" Value="#F3F4F6"/>
                                                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}" FontSize="12" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Đang sản xuất">
                                                                <Setter Property="Foreground" Value="#2563EB"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Chờ">
                                                                <Setter Property="Foreground" Value="#EA580C"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Hoàn thành">
                                                                <Setter Property="Foreground" Value="#16A34A"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Tạm dừng">
                                                                <Setter Property="Foreground" Value="#DC2626"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Hủy">
                                                                <Setter Property="Foreground" Value="#4B5563"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Hạn hoàn thành -->
                            <DataGridTextColumn Header="Hạn hoàn thành" Binding="{Binding Deadline}" Width="150"/>

                            <!-- Thao tác -->
                            <DataGridTemplateColumn Header="Thao tác" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.ViewOrderDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" Cursor="Hand" ToolTip="Xem chi tiết">
                                            <Viewbox Width="20" Height="20">
                                                <Path Data="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z M12 17a5 5 0 1 0 0-10 5 5 0 0 0 0 10z M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" 
                                                      Fill="Transparent" Stroke="#3B82F6" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            </Viewbox>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Footer for See All -->
                    <Border BorderBrush="#F3F4F6" BorderThickness="0,1,0,0" Margin="0,10,0,0" Padding="0,12,0,0">
                        <Button Cursor="Hand" Background="Transparent" BorderThickness="0" HorizontalAlignment="Center"
                                Command="{Binding ViewAllOrdersCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Xem tất cả lệnh sản xuất" Foreground="#2563EB" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <Viewbox Width="12" Height="12" Margin="6,0,0,0" VerticalAlignment="Center">
                                            <Path Data="M9 5l7 7-7 7" Stroke="#2563EB" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Viewbox>
                                    </StackPanel>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Recent Activity (Row 4) -->
            <Border Grid.Row="4" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Grid Margin="0,0,0,20">
                        <TextBlock Text="Hoạt động gần đây" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Right" Padding="15,6"
                                Command="{Binding ExportActivitiesCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                    <Path Data="M7 11V7h10v4 m-5 8V11 m-3 3l3 3 3-3" Stroke="#4B5563" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Viewbox>
                                <TextBlock Text="Xuất báo cáo" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                    
                    <DataGrid Style="{StaticResource ModernDataGridStyle}" ItemsSource="{Binding Activities}" IsReadOnly="True"
                              MaxHeight="420" 
                              EnableRowVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <DataGrid.Columns>
                            <!-- Hành động -->
                            <DataGridTemplateColumn Header="Hành động" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border HorizontalAlignment="Left" MinWidth="85" CornerRadius="8" Padding="8,4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="Bắt đầu">
                                                            <Setter Property="Background" Value="#F0FDF4"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Đang sản xuất">
                                                            <Setter Property="Background" Value="#F0FDF4"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Hoàn thành">
                                                            <Setter Property="Background" Value="#F0FDF4"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Tạm dừng">
                                                            <Setter Property="Background" Value="#FFF7ED"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Hủy">
                                                            <Setter Property="Background" Value="#FEF2F2"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Chờ duyệt">
                                                            <Setter Property="Background" Value="#FFF7ED"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Thêm">
                                                            <Setter Property="Background" Value="#F0FDF4"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Sửa">
                                                            <Setter Property="Background" Value="#EFF6FF"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Cập nhật">
                                                            <Setter Property="Background" Value="#EFF6FF"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Xóa">
                                                            <Setter Property="Background" Value="#FEF2F2"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Phê duyệt">
                                                            <Setter Property="Background" Value="#F0FDF4"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="24" Height="24" CornerRadius="12" Background="White" Margin="0,0,10,0">
                                                    <Viewbox Width="12" Height="12">
                                                        <Path StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                                            <Path.Style>
                                                                <Style TargetType="Path">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Bắt đầu">
                                                                            <Setter Property="Data" Value="M5 3l14 9-14 9V3z"/>
                                                                            <Setter Property="Stroke" Value="#16A34A"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Đang sản xuất">
                                                                            <Setter Property="Data" Value="M5 3l14 9-14 9V3z"/>
                                                                            <Setter Property="Stroke" Value="#16A34A"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Hoàn thành">
                                                                            <Setter Property="Data" Value="M20 6L9 17l-5-5"/>
                                                                            <Setter Property="Stroke" Value="#16A34A"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Tạm dừng">
                                                                            <Setter Property="Data" Value="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/>
                                                                            <Setter Property="Stroke" Value="#EA580C"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Hủy">
                                                                            <Setter Property="Data" Value="M18 6L6 18M6 6l12 12"/>
                                                                            <Setter Property="Stroke" Value="#DC2626"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Chờ duyệt">
                                                                            <Setter Property="Data" Value="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                                                            <Setter Property="Stroke" Value="#EA580C"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Thêm">
                                                                            <Setter Property="Data" Value="M12 5v14 M5 12h14"/>
                                                                            <Setter Property="Stroke" Value="#16A34A"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Sửa">
                                                                            <Setter Property="Data" Value="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7 M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                                                            <Setter Property="Stroke" Value="#2563EB"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Cập nhật">
                                                                            <Setter Property="Data" Value="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7 M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                                                            <Setter Property="Stroke" Value="#2563EB"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Xóa">
                                                                            <Setter Property="Data" Value="M3 6h18 M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2 M10 11v6 M14 11v6"/>
                                                                            <Setter Property="Stroke" Value="#DC2626"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Phê duyệt">
                                                                            <Setter Property="Data" Value="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                                                            <Setter Property="Stroke" Value="#16A34A"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                    </Viewbox>
                                                </Border>
                                                <TextBlock Text="{Binding Type}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Nội dung -->
                            <DataGridTemplateColumn Header="Nội dung" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="5"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Người thực hiện -->
                            <DataGridTextColumn Header="Người thực hiện" Binding="{Binding User}" Width="200"/>

                            <!-- Thời gian -->
                            <DataGridTextColumn Header="Thời gian" Binding="{Binding Time}" Width="150"/>

                            <!-- Thao tác -->
                            <DataGridTemplateColumn Header="Thao tác" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.OpenActivityDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" Cursor="Hand" ToolTip="Xem chi tiết hoạt động">
                                            <Viewbox Width="20" Height="20">
                                                <Path Data="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z M12 17a5 5 0 1 0 0-10 5 5 0 0 0 0 10z M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" 
                                                      Fill="Transparent" Stroke="#3B82F6" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            </Viewbox>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <!-- Footer for See All -->
                    <Border BorderBrush="#F3F4F6" BorderThickness="0,1,0,0" Margin="0,10,0,0" Padding="0,12,0,0">
                        <Button Command="{Binding ViewAllActivitiesCommand}" Cursor="Hand" Background="Transparent" BorderThickness="0" HorizontalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Xem tất cả hoạt động" Foreground="#2563EB" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                        <Viewbox Width="12" Height="12" Margin="6,0,0,0" VerticalAlignment="Center">
                                            <Path Data="M9 5l7 7-7 7" Stroke="#2563EB" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Viewbox>
                                    </StackPanel>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
