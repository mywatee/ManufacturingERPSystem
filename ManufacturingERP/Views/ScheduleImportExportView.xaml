<UserControl x:Class="ManufacturingERP.Views.ScheduleImportExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#F8FAFC"
             Language="vi-VN">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Back Button -->
            <Button Grid.Column="0" Command="{Binding BackCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE112;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Foreground="#64748B" Margin="0,0,8,0"/>
                    <TextBlock Text="Quay lại danh sách phân ca" Foreground="#64748B" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Center: Title -->
            <TextBlock Grid.Column="1" Text="{Binding PageTitle}" FontSize="28" FontWeight="Bold" Foreground="#0F172A" 
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- Right: Action Button -->
            <Button Grid.Column="2" Command="{Binding ProcessCommand}" Background="#2563EB" Foreground="White" Padding="25,12" FontSize="14" FontWeight="SemiBold">
                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style></Button.Resources>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE105;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ActionButtonText}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Main Content Layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Configuration Form -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,30,0">
                <StackPanel>
                    <!-- Mode Selection -->
                    <Border Background="White" CornerRadius="16" Padding="25" Margin="0,0,0,25">
                        <Border.Effect><DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="0"/></Border.Effect>
                        <StackPanel>
                            <TextBlock Text="LOẠI THAO TÁC" FontSize="12" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,15"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <RadioButton Grid.Column="0" Content="Xuất báo cáo dữ liệu" IsChecked="{Binding IsExportMode}" FontSize="14" FontWeight="Medium"/>
                                <RadioButton Grid.Column="1" Content="Nhập dữ liệu từ Excel" IsChecked="{Binding IsImportMode}" FontSize="14" FontWeight="Medium"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Export Configurations -->
                    <Border Background="White" CornerRadius="16" Padding="25" Margin="0,0,0,25" Visibility="{Binding IsExportMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.Effect><DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="0"/></Border.Effect>
                        <StackPanel>
                            <TextBlock Text="CẤU HÌNH XUẤT DỮ LIỆU" FontSize="12" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,20"/>
                            
                            <TextBlock Text="CHỌN NHÂN VIÊN CỤ THỂ (Tùy chọn)" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,25" Background="#F8FAFC">
                                <StackPanel>
                                    <!-- Search and Department for the selection list -->
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Tìm nhanh trong danh sách" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,5"/>
                                            <TextBox Height="38" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Padding="10,0">
                                                <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                                            </TextBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Lọc theo Phòng ban" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,5"/>
                                            <ComboBox Height="38" ItemsSource="{Binding Departments}" SelectedItem="{Binding SelectedDepartment}">
                                                <ComboBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></ComboBox.Resources>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Employee List with Checkboxes -->
                                    <Border Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Height="200">
                                        <DataGrid ItemsSource="{Binding EmployeeSelectionList}" AutoGenerateColumns="False" 
                                                  CanUserAddRows="False" BorderThickness="0" Background="Transparent" 
                                                  HeadersVisibility="Column" GridLinesVisibility="None">
                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Width="50">
                                                    <DataGridTemplateColumn.Header>
                                                        <CheckBox HorizontalAlignment="Center"/>
                                                    </DataGridTemplateColumn.Header>
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Mã NV" Binding="{Binding Employee.EmployeeCode}" Width="100" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="Họ và Tên" Binding="{Binding Employee.FullName}" Width="*" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="Phòng ban" Binding="{Binding Employee.Department}" Width="150" IsReadOnly="True"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>
                                    
                                    <TextBlock Text="{Binding SelectedEmployeesCount, StringFormat='Đã chọn {0} nhân viên'}" 
                                               FontSize="11" FontWeight="SemiBold" Foreground="#2563EB" Margin="0,10,0,5"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="CHỌN THỜI GIAN XUẤT" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,25">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="20"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Tháng" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,5"/>
                                    <ComboBox Height="40" ItemsSource="{Binding AvailableMonths}" SelectedItem="{Binding Month}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Năm" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,5"/>
                                    <ComboBox Height="40" ItemsSource="{Binding AvailableYears}" SelectedItem="{Binding Year}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Định dạng tệp tin" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                <RadioButton Content="Excel (.xlsx)" IsChecked="{Binding IsExcelSelected}" Margin="0,0,30,0"/>
                                <RadioButton Content="PDF (.pdf)" IsChecked="{Binding IsPdfSelected}"/>
                            </StackPanel>

                            <TextBlock Text="Chọn các cột hiển thị" FontWeight="SemiBold" Margin="0,0,0,15"/>
                            <ItemsControl ItemsSource="{Binding ExportColumns}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="0,0,25,15" FontSize="13" Foreground="#475569"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Import Configurations -->
                    <Border Background="White" CornerRadius="16" Padding="25" Visibility="{Binding IsImportMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.Effect><DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="0"/></Border.Effect>
                        <StackPanel>
                            <TextBlock Text="CẤU HÌNH NHẬP DỮ LIỆU" FontSize="12" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,20"/>
                            
                            <TextBlock Text="Chọn tệp tin Excel nguồn" FontWeight="SemiBold" Margin="0,0,0,10"/>
                             <Grid Margin="0,0,0,25">
                                 <Grid.ColumnDefinitions>
                                     <ColumnDefinition Width="*"/>
                                     <ColumnDefinition Width="Auto"/>
                                     <ColumnDefinition Width="Auto"/>
                                 </Grid.ColumnDefinitions>
                                 <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="15,10">
                                     <TextBlock Text="{Binding SelectedFilePath}" VerticalAlignment="Center" Foreground="#94A3B8" FontStyle="Italic"/>
                                 </Border>
                                 <Button Grid.Column="1" Content="Chọn file..." Command="{Binding SelectFileCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Padding="20,0"/>
                                 <Button Grid.Column="2" Content="Tải file mẫu" Command="{Binding DownloadTemplateCommand}" Style="{StaticResource OutlineButtonStyle}" Margin="10,0,0,0" Padding="20,0"/>
                             </Grid>

                             <TextBlock Text="Chế độ nhập" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <StackPanel Margin="0,0,0,10">
                                <RadioButton Content="Thêm mới (Giữ nguyên dữ liệu khác)" IsChecked="{Binding IsUpdateMode, Converter={StaticResource InverseBooleanConverter}}" Margin="0,0,0,10"/>
                                <RadioButton Content="Ghi đè nếu trùng Mã NV và Ngày" IsChecked="{Binding IsUpdateMode}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Right Panel: Instructions -->
            <StackPanel Grid.Column="1">
                <Border Background="White" CornerRadius="16" Padding="25">
                    <Border.Effect><DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="0"/></Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="#DBEAFE" Width="30" Height="30" CornerRadius="15" Margin="0,0,12,0">
                                <TextBlock Text="?" Foreground="#2563EB" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="HƯỚNG DẪN NGHIỆP VỤ" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Instructions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8FAFC" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,5"/>
                                            <TextBlock Text="{Binding Content}" FontSize="12" Foreground="#64748B" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Background="#FFF7ED" CornerRadius="12" Padding="15" Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" Foreground="#D97706" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Mẹo: Bạn có thể xuất lịch để làm mẫu nhập dữ liệu." FontSize="11" Foreground="#92400E" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
