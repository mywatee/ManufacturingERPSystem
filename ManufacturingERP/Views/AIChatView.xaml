<UserControl x:Class="ManufacturingERP.Views.AIChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:ManufacturingERP.Models"
             mc:Ignorable="d"
             d:DesignWidth="380" d:DesignHeight="600"
             Width="380">
    <Border Background="White" CornerRadius="16,0,0,0" BorderBrush="#E2E8F0" BorderThickness="1,0,0,0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.15" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#1E293B" Padding="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#3B82F6" Width="32" Height="32" CornerRadius="8" VerticalAlignment="Center">
                        <TextBlock Text="AI" FontWeight="Bold" Foreground="White" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Trợ lý ERP" FontWeight="SemiBold" Foreground="White" FontSize="14"/>
                        <TextBlock Text="Hỗ trợ sử dụng hệ thống" Foreground="#94A3B8" FontSize="11"/>
                    </StackPanel>
                    <Button Grid.Column="2" Command="{Binding CloseCommand}"
                            Background="Transparent" BorderThickness="0" Width="28" Height="28"
                            Foreground="#94A3B8" FontSize="16" FontWeight="Bold"
                            Content="✕" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Suggested Questions -->
            <Border Grid.Row="1" Background="#F8FAFC" Padding="12,8,12,4"
                    Visibility="{Binding ShowSuggestions, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding SuggestedQuestions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}"
                                    Command="{Binding DataContext.SendSuggestionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Background="#E8F4FD" Foreground="#1565C0" BorderThickness="0"
                                    FontSize="11" Padding="8,4" Margin="0,0,6,4" Cursor="Hand"
                                    Height="28">
                                <Button.Resources>
                                    <Style TargetType="Border"/>
                                </Button.Resources>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- Messages -->
            <ScrollViewer Grid.Row="2" x:Name="MessageScrollViewer"
                          Background="#F8FAFC" Padding="12,4"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,6">
                                        <Border MaxWidth="340" Padding="0" CornerRadius="12" BorderThickness="0.5" BorderBrush="#E2E8F0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                            <Setter Property="Background" Value="#3B82F6"/>
                                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Margin="12,8">
                                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                                           FontSize="13" LineHeight="20"
                                                           Foreground="#1E293B"/>
                                                <Grid Margin="0,4,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Timestamp}" FontSize="10" 
                                                               Foreground="#94A3B8" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" 
                                                            Command="{Binding DataContext.CopyMessageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding Content}"
                                                            Background="Transparent" BorderThickness="0"
                                                            Width="20" Height="20" Padding="0" Cursor="Hand"
                                                            ToolTip="Sao chép" VerticalAlignment="Center"
                                                            Foreground="#94A3B8" FontSize="12"
                                                            Content="📋"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Loading indicator -->
            <Border Grid.Row="2" Background="#80F8FAFC"
                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                    VerticalAlignment="Bottom" Padding="12,8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Đang trả lời" FontSize="12" Foreground="#64748B" FontStyle="Italic" VerticalAlignment="Center"/>
                    <TextBlock x:Name="Dot1" Text="." FontSize="16" FontWeight="Bold" Foreground="#3B82F6" VerticalAlignment="Center"
                               Margin="1,-2,0,0">
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="TextBlock.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="False">
                                        <DoubleAnimation From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.0"
                                                         Storyboard.TargetProperty="Opacity" FillBehavior="Stop"/>
                                        <DoubleAnimation From="1" To="0" Duration="0:0:0.4" BeginTime="0:0:1.2"
                                                         Storyboard.TargetProperty="Opacity" FillBehavior="Stop"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                    <TextBlock x:Name="Dot2" Text="." FontSize="16" FontWeight="Bold" Foreground="#3B82F6" VerticalAlignment="Center"
                               Margin="0,-2,0,0">
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="TextBlock.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="False">
                                        <DoubleAnimation From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.3"
                                                         Storyboard.TargetProperty="Opacity" FillBehavior="Stop"/>
                                        <DoubleAnimation From="1" To="0" Duration="0:0:0.4" BeginTime="0:0:1.5"
                                                         Storyboard.TargetProperty="Opacity" FillBehavior="Stop"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                    <TextBlock x:Name="Dot3" Text="." FontSize="16" FontWeight="Bold" Foreground="#3B82F6" VerticalAlignment="Center"
                               Margin="0,-2,0,0">
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="TextBlock.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="False">
                                        <DoubleAnimation From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.6"
                                                         Storyboard.TargetProperty="Opacity" FillBehavior="Stop"/>
                                        <DoubleAnimation From="1" To="0" Duration="0:0:0.4" BeginTime="0:0:1.8"
                                                         Storyboard.TargetProperty="Opacity" FillBehavior="Stop"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Input -->
            <Border Grid.Row="3" Padding="12,8,12,12" Background="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Nhập câu hỏi..."
                             Style="{StaticResource ModernTextBoxStyle}"
                             Height="40" FontSize="13"
                             IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
                    <Button Grid.Column="1" Command="{Binding SendMessageCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="40" Width="40" Margin="8,0,0,0" Padding="0"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"
                            FontSize="18" Content="➤"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
