<UserControl x:Class="ManufacturingERP.Views.AttendanceConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ManufacturingERP.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#F1F5F9">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Header Bar -->
        <Border Grid.Row="0" Background="#1E293B" Padding="32,24">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding BackCommand}" 
                            Style="{StaticResource GhostButtonStyle}" 
                            Tag="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" 
                            Foreground="White" Width="40" Height="40" Margin="0,0,16,0"/>
                    <StackPanel>
                        <TextBlock Text="Bảng Điểm Danh Tập Trung" FontSize="24" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Cập nhật trạng thái nhân sự thời gian thực" FontSize="13" Foreground="#94A3B8"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="#334155" CornerRadius="12" Padding="20,10" Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconClock}" Fill="#38BDF8" Width="18" Height="18" Margin="0,0,12,0" Stretch="Uniform"/>
                            <TextBlock Text="{Binding CurrentTime}" FontSize="20" FontWeight="Bold" Foreground="White" FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>
                    
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#14532D" CornerRadius="12" Padding="16,8" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="CÓ MẶT:" FontSize="11" FontWeight="Bold" Foreground="#4ADE80" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding PresentCount}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#78350F" CornerRadius="12" Padding="16,8" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="MUỘN:" FontSize="11" FontWeight="Bold" Foreground="#FBBF24" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding LateCount}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#7F1D1D" CornerRadius="12" Padding="16,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="VẮNG:" FontSize="11" FontWeight="Bold" Foreground="#F87171" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding AbsentCount}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filter & Actions Area -->
        <Border Grid.Row="1" Background="White" BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Padding="32,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Background="#F8FAFC" CornerRadius="12" Padding="16,0" Height="50" Width="400">
                        <Grid>
                            <Path Data="{StaticResource IconSearch}" Fill="#94A3B8" Width="18" Height="18" HorizontalAlignment="Left" Stretch="Uniform"/>
                            <TextBox Style="{StaticResource LoginTextBoxStyle}" BorderThickness="0" Background="Transparent" 
                                     VerticalContentAlignment="Center" Margin="32,0,0,0" Tag="Tìm kiếm nhanh tên hoặc mã nhân viên..."
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" FontSize="16"/>
                        </Grid>
                    </Border>

                    
                    <!-- Batch Actions (Only visible if something is selected) -->
                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsAnySelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border Width="1" Background="#E2E8F0" Margin="8,8,16,8"/>
                        <TextBlock Text="Thao tác hàng loạt:" VerticalAlignment="Center" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,12,0"/>
                        <Button Content="ĐIỂM DANH" Command="{Binding BatchMarkAttendanceCommand}" CommandParameter="Auto"
                                Style="{StaticResource PrimaryButtonStyle}" Background="#10B981" Height="36" Margin="0,0,8,0" Padding="12,0"/>
                        <Button Content="ĐI MUỘN" Command="{Binding BatchMarkAttendanceCommand}" CommandParameter="Đi muộn"
                                Style="{StaticResource PrimaryButtonStyle}" Background="#F59E0B" Height="36" Margin="0,0,8,0" Padding="12,0"/>
                        <Button Content="VẮNG MẶT" Command="{Binding BatchMarkAttendanceCommand}" CommandParameter="Vắng"
                                Style="{StaticResource PrimaryButtonStyle}" Background="#EF4444" Height="36" Padding="12,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Bộ phận:" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="#64748B" FontWeight="SemiBold"/>
                    <ListBox ItemsSource="{Binding Departments}" SelectedItem="{Binding SelectedDepartment}"
                             BorderThickness="0" Background="Transparent">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="border" CornerRadius="20" Padding="16,8" Margin="0,0,8,0" Background="#F1F5F9" Cursor="Hand">
                                                <ContentPresenter x:Name="content" TextBlock.Foreground="#64748B" TextBlock.FontWeight="SemiBold"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#3B82F6"/>
                                                    <Setter TargetName="content" Property="TextBlock.Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Employee Cards Grid -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Table View (DataGrid) -->
            <Border
                    Style="{StaticResource CardStyle}" Margin="32" Padding="0">
                <DataGrid ItemsSource="{Binding Employees}" AutoGenerateColumns="False" 
                          CanUserAddRows="False" GridLinesVisibility="None"
                          HeadersVisibility="Column" Background="Transparent" BorderThickness="0">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#F1F5F9"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Background" Value="#F0F9FF"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="50">
                            <DataGridTemplateColumn.Header>
                                <CheckBox x:Name="HeaderCheck" HorizontalAlignment="Center" 
                                          Command="{Binding DataContext.SelectAllCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:AttendanceConsoleView}}}"
                                          CommandParameter="{Binding IsChecked, ElementName=HeaderCheck}"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                                              HorizontalAlignment="Center"
                                              Command="{Binding DataContext.UpdateSelectionCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:AttendanceConsoleView}}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Mã NV" Binding="{Binding Employee.EmployeeCode}" Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Họ và Tên" Binding="{Binding Employee.FullName}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Bộ phận" Binding="{Binding Employee.Department}" Width="150" IsReadOnly="True"/>
                        
                        <DataGridTemplateColumn Header="Lịch làm việc" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ShiftDisplay}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Giờ vào" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding CheckInDisplay}" FontWeight="Bold" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Trạng thái" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="statusBadge" Style="{StaticResource StatusBadgeStyle}">
                                        <TextBlock Text="{Binding TimingStatus}" HorizontalAlignment="Center"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding TimingStatus}" Value="CHƯA ĐẾN GIỜ">
                                            <Setter TargetName="statusBadge" Property="Style" Value="{StaticResource StatusDoingStyle}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TimingStatus}" Value="CHƯA VÀO CA">
                                            <Setter TargetName="statusBadge" Property="Style" Value="{StaticResource StatusDoingStyle}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TimingStatus}" Value="ĐÚNG GIỜ">
                                            <Setter TargetName="statusBadge" Property="Style" Value="{StaticResource StatusDoneStyle}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TimingStatus}" Value="ĐI MUỘN">
                                            <Setter TargetName="statusBadge" Property="Style" Value="{StaticResource StatusWaitingStyle}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TimingStatus}" Value="VẮNG MẶT">
                                            <Setter TargetName="statusBadge" Property="Style" Value="{StaticResource UrgentBadgeStyle}"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Thao tác" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Case: No Record -->
                                        <StackPanel x:Name="checkInActions" Orientation="Horizontal">
                                            <Button Command="{Binding DataContext.MarkAttendanceCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:AttendanceConsoleView}}}" 
                                                    CommandParameter="{Binding}" ToolTip="Vào ca (Đúng giờ)" Margin="0,0,4,0" Width="32" Height="32" Style="{StaticResource PrimaryButtonStyle}" Background="#10B981" Padding="6">
                                                <Path Data="{StaticResource IconCheckCircle}" Fill="White" Stretch="Uniform"/>
                                            </Button>
                                            <Button Command="{Binding DataContext.MarkLateCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:AttendanceConsoleView}}}" 
                                                    CommandParameter="{Binding}" ToolTip="Đi muộn" Margin="0,0,4,0" Width="32" Height="32" Style="{StaticResource PrimaryButtonStyle}" Background="#F59E0B" Padding="6">
                                                <Path Data="{StaticResource IconClock}" Fill="White" Stretch="Uniform"/>
                                            </Button>
                                            <Button Command="{Binding DataContext.MarkAbsentCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:AttendanceConsoleView}}}" 
                                                    CommandParameter="{Binding}" ToolTip="Vắng mặt" Width="32" Height="32" Style="{StaticResource PrimaryButtonStyle}" Background="#EF4444" Padding="6">
                                                <Path Data="{StaticResource IconXCircle}" Fill="White" Stretch="Uniform"/>
                                            </Button>
                                        </StackPanel>

                                        <!-- Case: Checked In -->
                                        <Button x:Name="checkOutBtn" Command="{Binding DataContext.MarkCheckOutCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:AttendanceConsoleView}}}" 
                                                CommandParameter="{Binding}" ToolTip="Ra ca" Width="32" Height="32" Style="{StaticResource PrimaryButtonStyle}" Background="#3B82F6" Padding="6" Visibility="Collapsed">
                                            <Path Data="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z" Fill="White" Stretch="Uniform"/>
                                        </Button>

                                        <!-- Case: Mistake correction -->
                                        <Button x:Name="resetBtn" Command="{Binding DataContext.ResetAttendanceCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:AttendanceConsoleView}}}" 
                                                CommandParameter="{Binding}" ToolTip="Hủy trạng thái để sửa sai" Margin="8,0,0,0" Width="32" Height="32" Style="{StaticResource GhostButtonStyle}" BorderThickness="1" BorderBrush="#E2E8F0" Padding="6" Visibility="Collapsed">
                                            <Path Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" Fill="#94A3B8" Stretch="Uniform"/>
                                        </Button>
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Record}" Value="{x:Null}">
                                            <Setter TargetName="checkInActions" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="checkOutBtn" Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="resetBtn" Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsCheckedIn}" Value="True">
                                            <Setter TargetName="checkInActions" Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="checkOutBtn" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="resetBtn" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsCheckedOut}" Value="True">
                                            <Setter TargetName="checkOutBtn" Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="resetBtn" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsAbsent}" Value="True">
                                            <Setter TargetName="checkInActions" Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="resetBtn" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Pagination Bar -->
            <Border Grid.Row="1" Background="White" BorderThickness="0,1,0,0" BorderBrush="#E2E8F0" Padding="32,16">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Hiển thị trang " VerticalAlignment="Center" Foreground="#64748B"/>
                        <TextBlock Text="{Binding CurrentPage}" FontWeight="Bold" VerticalAlignment="Center" Foreground="#1E293B"/>
                        <TextBlock Text=" / " VerticalAlignment="Center" Foreground="#64748B"/>
                        <TextBlock Text="{Binding TotalPages}" FontWeight="Bold" VerticalAlignment="Center" Foreground="#1E293B"/>
                        <TextBlock Text=" (Tổng " VerticalAlignment="Center" Foreground="#64748B" Margin="8,0,0,0"/>
                        <TextBlock Text="{Binding TotalCount}" FontWeight="Bold" VerticalAlignment="Center" Foreground="#1E293B"/>
                        <TextBlock Text=" nhân viên)" VerticalAlignment="Center" Foreground="#64748B"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Trang trước" Style="{StaticResource SecondaryButtonStyle}" Width="120" Height="36" Margin="0,0,12,0"
                                Command="{Binding PrevPageCommand}"/>
                        <Button Content="Trang tiếp" Style="{StaticResource PrimaryButtonStyle}" Width="120" Height="36"
                                Command="{Binding NextPageCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
