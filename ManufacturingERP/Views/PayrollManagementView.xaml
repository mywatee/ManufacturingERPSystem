<UserControl x:Class="ManufacturingERP.Views.PayrollManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ManufacturingERP.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Tính lương theo sản lượng" FontSize="18" FontWeight="Bold" Foreground="#1e293b"/>
            <TextBlock FontSize="13" Foreground="#64748b">
                <Run Text="Lương "/>
                <Run Text="{Binding CurrentMonthText}"/>
                <Run Text=" - Dựa trên sản phẩm đạt chất lượng"/>
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
            <Button Content="Lưu tạm" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0"
                    Command="{Binding SaveDraftCommand}"/>
            <Button x:Name="btnApproveAll" Content="Duyệt lương" Style="{StaticResource PrimaryButtonStyle}" 
                    Background="#2563EB" Tag="{StaticResource IconCheckCircle}"
                    Command="{Binding ApprovePayrollCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="20,10">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconCheckCircle}" Fill="White" Width="14" Height="14" Margin="0,0,8,0" Stretch="Uniform"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <!-- Payroll KPIs -->
        <Grid Grid.Row="1" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,16,0">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#F0FDF4" Width="48" Height="48" CornerRadius="24" Margin="0,0,16,0">
                        <Path Data="{StaticResource IconDollar}" Fill="#16A34A" Width="22" Height="22" Stretch="Uniform"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Tổng lương tháng này" FontSize="12" Foreground="#64748b"/>
                        <TextBlock Text="{Binding TotalSalaryText}" FontSize="20" FontWeight="Bold" Foreground="#16A34A"/>
                        <TextBlock FontSize="11" Foreground="#94a3b8">
                            <Run Text="{Binding TotalEmployees}"/>
                            <Run Text=" nhân viên"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,16,0">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#EFF6FF" Width="48" Height="48" CornerRadius="24" Margin="0,0,16,0">
                        <Path Data="{StaticResource IconTrendingUp}" Fill="#2563EB" Width="22" Height="22" Stretch="Uniform"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Tổng sản lượng đạt" FontSize="12" Foreground="#64748b"/>
                        <TextBlock Text="{Binding TotalProductionQty}" FontSize="20" FontWeight="Bold" Foreground="#2563EB"/>
                        <TextBlock Text="Sản phẩm đạt QC" FontSize="11" Foreground="#94a3b8"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0,0,16,0">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#F0FDF4" Width="48" Height="48" CornerRadius="24" Margin="0,0,16,0">
                        <Path Data="{StaticResource IconCheckCircle}" Fill="#16A34A" Width="22" Height="22" Stretch="Uniform"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Đã duyệt" FontSize="12" Foreground="#64748b"/>
                        <TextBlock Text="{Binding ApprovedCount}" FontSize="20" FontWeight="Bold" Foreground="#1e293b"/>
                        <TextBlock Text="Nhân viên" FontSize="11" Foreground="#94a3b8"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource CardStyle}">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#F3F4F6" Width="48" Height="48" CornerRadius="24" Margin="0,0,16,0">
                        <Path Data="{StaticResource IconClock}" Fill="#6B7280" Width="22" Height="22" Stretch="Uniform"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Chưa duyệt" FontSize="12" Foreground="#64748b"/>
                        <TextBlock Text="{Binding WaitingCount}" FontSize="20" FontWeight="Bold" Foreground="#1e293b"/>
                        <TextBlock Text="Cần xác nhận" FontSize="11" Foreground="#94a3b8"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Chart and Top 3 -->
        <Grid Grid.Row="2" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Năng suất nhân viên xuất sắc trong tháng" FontWeight="SemiBold" Margin="0,0,0,24"/>
                    <ItemsControl ItemsSource="{Binding ProductivityChart}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="5" Height="200"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Bottom" Margin="10,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Width="40" Background="#3B82F6" CornerRadius="4,4,0,0" 
                                            Height="{Binding NormalizedHeight, FallbackValue=20}" VerticalAlignment="Bottom" MaxHeight="160">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding NormalizedHeight}" Value="0">
                                                        <Setter Property="Height" Value="5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    
                                    <TextBlock Grid.Row="1" Text="{Binding Value}" HorizontalAlignment="Center" FontSize="11" Margin="0,8,0,4"/>
                                    <TextBlock Grid.Row="2" Text="{Binding Name}" HorizontalAlignment="Center" FontSize="10" Foreground="#64748b" TextWrapping="Wrap" TextAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Top 3 năng suất nhất" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <ItemsControl ItemsSource="{Binding TopPerformers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,12" Padding="12,10" CornerRadius="12" Background="#F8FAFC" BorderThickness="1" BorderBrush="#E2E8F0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="36" Height="36" CornerRadius="18" Background="#DBEAFE" Margin="0,0,12,0">
                                            <Path Data="{StaticResource IconTrophy}" Fill="#2563EB" Width="18" Height="18" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="#1E293B"/>
                                            <TextBlock Text="{Binding Value, StringFormat={}{0} sản phẩm}" FontSize="12" Foreground="#64748B"/>
                                        </StackPanel>
                                        <Border Grid.Column="2" VerticalAlignment="Center" Padding="10,4" CornerRadius="12" Background="#DBEAFE">
                                            <TextBlock Text="TOP" FontSize="10" FontWeight="ExtraBold" Foreground="#1E40AF"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Payroll Details Table -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding PayrollRecords}" 
                      Style="{StaticResource ModernDataGridStyle}"
                      VerticalScrollBarVisibility="Disabled"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã NV" Binding="{Binding EmployeeId}" Width="80"/>
                    <DataGridTextColumn Header="Tên nhân viên" Binding="{Binding Name}" Width="1.5*"/>
                    <DataGridTextColumn Header="Bộ phận" Binding="{Binding Department}" Width="*"/>
                    <DataGridTextColumn Header="Sản lượng đạt" Binding="{Binding ProductionQty}" Width="100"/>
                    <DataGridTextColumn Header="Đơn giá SP" Binding="{Binding UnitPrice, StringFormat={}{0:N0} đ}" Width="100"/>
                    <DataGridTextColumn Header="Lương SP" Binding="{Binding ProductionSalary, StringFormat={}{0:N0} đ}" Width="100"/>
                    <DataGridTextColumn Header="Thưởng chuyên cần" Binding="{Binding AttendanceBonus, StringFormat={}{0:N0} đ}" Width="120"/>
                    <DataGridTextColumn Header="Thưởng chất lượng" Binding="{Binding QualityBonus, StringFormat={}{0:N0} đ}" Width="120"/>
                    <DataGridTemplateColumn Header="Tổng lương" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TotalSalary, StringFormat={}{0:N0} đ}" FontWeight="Bold" Foreground="#16A34A" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Trạng thái" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="badge" Style="{StaticResource StatusBadgeStyle}">
                                    <TextBlock x:Name="txt" Text="{Binding Status}"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Đã duyệt">
                                        <Setter TargetName="badge" Property="Style" Value="{StaticResource StatusDoneStyle}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Thao tác" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Button Content="Duyệt" Visibility="Collapsed" x:Name="btnDuyet"
                                            Background="#2563EB" Foreground="White" Padding="12,4"
                                            Command="{Binding DataContext.ApproveSingleCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                 <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                     <ContentPresenter HorizontalAlignment="Center"/>
                                                 </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Chưa duyệt">
                                        <Setter TargetName="btnDuyet" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
