<UserControl x:Class="ManufacturingERP.Views.WarehouseReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:core="clr-namespace:ManufacturingERP.Core"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#F8FAFC">

    <UserControl.Resources>
        <core:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <core:BooleanToStringConverter x:Key="BooleanToStringConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Back Button -->
            <Button Grid.Column="0" Command="{Binding BackCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE112;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Foreground="#64748B" Margin="0,0,8,0"/>
                    <TextBlock Text="Quay lại Kho bãi" Foreground="#64748B" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Center: Title -->
            <TextBlock Grid.Column="1" Text="{Binding PageTitle}" FontSize="28" FontWeight="Bold" Foreground="#0F172A" 
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- Right: Action Button -->
            <Button Grid.Column="2" Command="{Binding ProcessCommand}" 
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                    Background="#2563EB" Foreground="White" Padding="25,12" FontSize="14" FontWeight="SemiBold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE105;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ActionButtonText}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Loading Indicator -->
        <ProgressBar Grid.Row="1" VerticalAlignment="Top" Height="4" IsIndeterminate="True" 
                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Foreground="#2563EB" Background="Transparent" BorderThickness="0" Panel.ZIndex="10"/>

        <!-- Main Content Layout -->
        <Grid Grid.Row="1" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Configuration Form -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,30,0">
                <StackPanel>
                    <!-- Mode Selection -->
                    <Border Background="White" CornerRadius="16" Padding="25" Margin="0,0,0,25">
                        <Border.Effect><DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="0"/></Border.Effect>
                        <StackPanel>
                            <TextBlock Text="LOẠI THAO TÁC" FontSize="12" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,20"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <RadioButton Grid.Column="0" Content="Xuất báo cáo dữ liệu" IsChecked="{Binding IsExportMode}" FontSize="14" FontWeight="Medium"/>
                                <RadioButton Grid.Column="1" Content="Nhập dữ liệu từ Excel" IsChecked="{Binding IsImportMode}" FontSize="14" FontWeight="Medium"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Export Configurations -->
                    <Border Background="White" CornerRadius="16" Padding="25" Margin="0,0,0,25" Visibility="{Binding IsExportMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="0"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="CẤU HÌNH XUẤT BÁO CÁO KHO" FontSize="12" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,20"/>
                            
                            <TextBlock Text="Loại báo cáo" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <ComboBox Height="45" Margin="0,0,0,25" 
                                      ItemsSource="{Binding ReportTypes}"
                                      SelectedItem="{Binding SelectedReportType}">
                                <ComboBox.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style>
                                </ComboBox.Resources>
                            </ComboBox>

                            <TextBlock Text="Nhà kho áp dụng" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <ComboBox Height="45" Margin="0,0,0,25" 
                                      ItemsSource="{Binding Warehouses}"
                                      SelectedItem="{Binding SelectedWarehouse}"
                                      DisplayMemberPath="Name">
                                <ComboBox.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style>
                                </ComboBox.Resources>
                            </ComboBox>

                            <TextBlock Text="Khoảng thời gian" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,25">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <DatePicker Grid.Column="0" Height="40" SelectedDate="{Binding StartDate}"/>
                                <TextBlock Grid.Column="1" Text="đến" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#94A3B8"/>
                                <DatePicker Grid.Column="2" Height="40" SelectedDate="{Binding EndDate}"/>
                            </Grid>

                            <TextBlock Text="Định dạng tệp tin" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                <RadioButton Content="Excel (.xlsx)" IsChecked="{Binding IsExcelSelected}" Margin="0,0,30,0" VerticalAlignment="Center"/>
                                <RadioButton Content="PDF (.pdf)" IsChecked="{Binding IsPdfSelected}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="Chọn các cột thông tin cần xuất" FontWeight="SemiBold" Margin="0,0,0,15"/>
                            <ItemsControl ItemsSource="{Binding ExportColumns}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="0,0,25,15" FontSize="13" Foreground="#475569"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Import Configurations -->
                    <Border Background="White" CornerRadius="16" Padding="25" Margin="0,0,0,25" Visibility="{Binding IsImportMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.Effect><DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="0"/></Border.Effect>
                        <StackPanel>
                            <TextBlock Text="CẤU HÌNH NHẬP DỮ LIỆU" FontSize="12" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,20"/>
                            
                            <TextBlock Text="Chọn tệp tin Excel nguồn" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,25">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <Border BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="10" Padding="15,10">
                                    <TextBlock Text="{Binding SelectedFilePath}" VerticalAlignment="Center" Foreground="#94A3B8" FontStyle="Italic"/>
                                </Border>
                                <Button Grid.Column="1" Content="Chọn file..." Command="{Binding SelectFileCommand}" Margin="10,0,0,0" Padding="20,0" Height="45" Background="#F1F5F9" BorderBrush="#E2E8F0">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style></Button.Resources>
                                </Button>
                            </Grid>

                             <TextBlock Text="Chế độ nhập" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <StackPanel Margin="0,0,0,10">
                                <RadioButton Content="Cập nhật tồn kho (Cộng dồn)" IsChecked="{Binding IsUpdateMode}" Margin="0,0,0,10"/>
                                <RadioButton Content="Ghi đè số liệu (Dùng cho kiểm kê)" IsChecked="{Binding IsUpdateMode, Converter={StaticResource InverseBooleanConverter}}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>


            <!-- Right Panel: Instructions -->
            <StackPanel Grid.Column="1">
                <Border Background="White" CornerRadius="16" Padding="25">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="0"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="#DBEAFE" Width="30" Height="30" CornerRadius="15" Margin="0,0,12,0">
                                <TextBlock Text="?" Foreground="#2563EB" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="TRỢ GIÚP XUẤT BÁO CÁO" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Instructions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8FAFC" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,5"/>
                                            <TextBlock Text="{Binding Content}" FontSize="12" Foreground="#64748B" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
