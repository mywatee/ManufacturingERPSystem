<Window x:Class="ManufacturingERP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:ManufacturingERP.ViewModels"
        xmlns:components="clr-namespace:ManufacturingERP.Views.Components"
        mc:Ignorable="d"
        Title="Manufacturing ERP - Hệ thống điều hành sản xuất" 
        Height="720" Width="1280"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FB"
        FontFamily="Segoe UI">

    <Grid Background="{StaticResource MainBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition>
                <ColumnDefinition.Style>
                    <Style TargetType="ColumnDefinition">
                        <Setter Property="Width" Value="260"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsUserLoggedIn}" Value="False">
                                <Setter Property="Width" Value="0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ColumnDefinition.Style>
            </ColumnDefinition>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}"
                Visibility="{Binding IsUserLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Hệ thống ERP Sản xuất" 
                               Foreground="White" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               HorizontalAlignment="Center"
                               Margin="0,35,0,25"/>
                    <Rectangle Height="1" Fill="White" Opacity="0.1" Margin="20,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,15,0,0">
                    <StackPanel Margin="10,0">
                        <Button Content="Bảng điều khiển" 
                                Tag="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"
                                Command="{Binding NavigateDashboardCommand}"
                                Visibility="{Binding CanViewDashboard, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NavigationService.CurrentView, Converter={StaticResource ViewModelTypeToBooleanConverter}, ConverterParameter=DashboardViewModel}" Value="True">
                                            <Setter Property="Background" Value="#2C4263"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Quản trị hệ thống" 
                                Tag="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"
                                Command="{Binding NavigateAdminCommand}"
                                Visibility="{Binding CanViewSystemAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NavigationService.CurrentView, Converter={StaticResource ViewModelTypeToBooleanConverter}, ConverterParameter=AdminViewModel}" Value="True">
                                            <Setter Property="Background" Value="#2C4263"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Dữ liệu gốc" 
                                Tag="M12 2C6.48 2 2 4.02 2 6.5s4.48 4.5 10 4.5 10-2.02 10-4.5S17.52 2 12 2zm0 13c-5.52 0-10-2.02-10-4.5V11c0 2.48 4.48 4.5 10 4.5s10-2.02 10-4.5v-.5c0 2.48-4.48 4.5-10 4.5zm0 4c-5.52 0-10-2.02-10-4.5V15c0 2.48 4.48 4.5 10 4.5s10-2.02 10-4.5v-.5c0 2.48-4.48 4.5-10 4.5z"
                                Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding NavigateMasterDataCommand}"
                                Visibility="{Binding CanViewMasterData, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <Button Content="Sản xuất" 
                                Tag="M3.5 18.49l6-6.01 4 4L22 6.92l-1.41-1.41-7.09 7.97-4-4L2 17.08l1.5 1.41z"
                                Command="{Binding NavigateProductionCommand}"
                                Visibility="{Binding CanViewProduction, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NavigationService.CurrentView, Converter={StaticResource ViewModelTypeToBooleanConverter}, ConverterParameter=ProductionViewModel}" Value="True">
                                            <Setter Property="Background" Value="#2C4263"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Kiểm soát chất lượng" Command="{Binding NavigateQualityControlCommand}" 
                                Tag="M19 3h-4.18C14.4 1.84 13.3 1 12 1s-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"
                                Visibility="{Binding CanViewQualityControl, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NavigationService.CurrentView, Converter={StaticResource ViewModelTypeToBooleanConverter}, ConverterParameter=QualityControlViewModel}" Value="True">
                                            <Setter Property="Background" Value="#2C4263"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>


                        <Button Content="Kho bãi" 
                                Tag="M12 3L2 12h3v8h14v-8h3L12 3zm0 13c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z"
                                Command="{Binding NavigateWarehouseCommand}"
                                Visibility="{Binding CanViewWarehouse, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NavigationService.CurrentView, Converter={StaticResource ViewModelTypeToBooleanConverter}, ConverterParameter=WarehouseViewModel}" Value="True">
                                            <Setter Property="Background" Value="#2C4263"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Nhân sự &amp; Lương" 
                                Tag="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                                Command="{Binding NavigateHRCommand}"
                                Visibility="{Binding CanViewHumanResources, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NavigationService.CurrentView, Converter={StaticResource ViewModelTypeToBooleanConverter}, ConverterParameter=HRViewModel}" Value="True">
                                            <Setter Property="Background" Value="#2C4263"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Tài chính" 
                                Tag="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"
                                Command="{Binding NavigateFinanceCommand}"
                                Visibility="{Binding CanViewFinance, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NavigationService.CurrentView, Converter={StaticResource ViewModelTypeToBooleanConverter}, ConverterParameter=FinanceViewModel}" Value="True">
                                            <Setter Property="Background" Value="#2C4263"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="10,0,10,20">
                    <Button Content="Cài đặt hệ thống" 
                            Tag="M19.43 12.98c.04-.32.07-.64.07-.98s-.03-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.07.65-.07.98s.03.66.07.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.59 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65zM12 15.5c-1.93 0-3.5-1.57-3.5-3.5s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z"
                            Style="{StaticResource SidebarButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition>
                    <RowDefinition.Style>
                        <Style TargetType="RowDefinition">
                            <Setter Property="Height" Value="70"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsUserLoggedIn}" Value="False">
                                    <Setter Property="Height" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </RowDefinition.Style>
                </RowDefinition>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TopBar / Header -->
            <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    Visibility="{Binding IsUserLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Chào buổi sáng, Admin" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                    </StackPanel>

                    <!-- Search Bar -->
                    <Border Grid.Column="1" 
                            Background="#F3F4F6" 
                            CornerRadius="8" 
                            Height="40" 
                            Width="350" 
                            HorizontalAlignment="Left" 
                            Margin="40,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔍" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#9CA3AF"/>
                            <TextBox Grid.Column="1" 
                                     Text="Tìm nhanh Lệnh sản xuất..." 
                                     Background="Transparent" 
                                     BorderThickness="0" 
                                     VerticalContentAlignment="Center"
                                     Foreground="#9CA3AF"
                                     FontSize="14"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Notification Bell -->
                        <Border Width="40" Height="40" CornerRadius="20" Background="Transparent" Margin="0,0,10,0" Cursor="Hand">
                            <TextBlock Text="🔔" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>

                        <!-- User Profile Dropdown -->
                        <Grid>
                            <ToggleButton x:Name="ProfileButton" 
                                          IsChecked="{Binding IsProfilePopupOpen}"
                                          Cursor="Hand" Background="Transparent" BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" Padding="4,4,12,4" CornerRadius="8" x:Name="border">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="40" Height="40" CornerRadius="20" Background="#F3F4F6" Margin="0,0,12,0">
                                                    <TextBlock Text="👤" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding CurrentUser.Employee.FullName, TargetNullValue='Huy Hoàng', FallbackValue='Huy Hoàng'}" 
                                                               FontWeight="Bold" 
                                                               Foreground="{StaticResource PrimaryTextBrush}"/>
                                                    <TextBlock Text="Quản trị viên" 
                                                               FontSize="12" 
                                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F9FAFB"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F3F4F6"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup IsOpen="{Binding IsProfilePopupOpen}" 
                                   PlacementTarget="{Binding ElementName=ProfileButton}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade"
                                   HorizontalOffset="-140"
                                   VerticalOffset="10">
                                <Border Style="{StaticResource ProfilePopupBorderStyle}" Width="240">
                                    <StackPanel Margin="8">
                                        <TextBlock Text="Tài khoản của tôi" 
                                                   Margin="16,12,16,8" 
                                                   FontSize="12" 
                                                   FontWeight="SemiBold" 
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                        
                                        <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="8,4"/>

                                        <Button Content="Thông tin cá nhân" 
                                                Style="{StaticResource ProfileMenuItemStyle}"
                                                Tag="{StaticResource IconUser}"
                                                Command="{Binding NavigateProfileCommand}"/>
                                        
                                        <Button Content="Cài đặt thông báo" 
                                                Style="{StaticResource ProfileMenuItemStyle}"
                                                Tag="{StaticResource IconBell}"
                                                Command="{Binding NavigateNotificationSettingsCommand}"/>

                                        <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="8,4"/>

                                        <Button Content="Đăng xuất" 
                                                Style="{StaticResource ProfileMenuItemStyle}"
                                                Tag="{StaticResource IconLogout}"
                                                Foreground="#EF4444"
                                                Command="{Binding LogoutCommand}"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Application Content -->
            <ContentControl Grid.Row="1" Content="{Binding NavigationService.CurrentView}"/>
        </Grid>
        <!-- Toast Notification Overlay layer (Global) -->
        <components:ToastOverlayView VerticalAlignment="Top" HorizontalAlignment="Right" 
                                     Margin="0,20,20,0" Grid.ColumnSpan="2" Panel.ZIndex="9999"
                                     DataContext="{Binding NotificationService}"/>
    </Grid>

    <Window.Resources>
        <!-- Resource definitions moved to DesignSystem.xaml, keeping this empty or for window-specific resources -->
    </Window.Resources>
</Window>
